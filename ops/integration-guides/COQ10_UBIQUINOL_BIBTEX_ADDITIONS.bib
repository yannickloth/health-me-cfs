@article{Deng2025CoQ10ExercisePerformance,
  author = {Deng, Han and Song, Tong and Yin, Ming and Xu, Kai and Zhong, Yue and Mohd, Nizam B. and Naharudin, Mohd N. B. and Yusof, Amar and Fan, Xiao},
  title = {Coenzyme Q10 supplementation increases blood concentrations but shows limited and inconsistent effects on exercise performance: a systematic review and meta-analysis},
  journal = {British Journal of Nutrition},
  year = {2025},
  month = {December},
  volume = {ahead of print},
  pages = {1-21},
  doi = {10.1017/S0007114525106211},
  pmid = {41457257},
  url = {https://doi.org/10.1017/S0007114525106211},
  keywords = {CoQ10, exercise performance, subjective fatigue, meta-analysis, systematic review, bioavailability, randomized controlled trial},
  research_stream = {q10-ubiquinol},
  certainty = {0.60},
  note = {Meta-analysis of 24 studies assessing CoQ10 on exercise performance, subjective fatigue, and circulating CoQ10 levels. CoQ10 consistently increases blood concentrations but provides at most modest and context-dependent exercise performance benefits. Evidence for reduced subjective fatigue suggestive. No stable dose-response pattern. Certainty very low to low.}
}

