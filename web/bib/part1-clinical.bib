  pmid = {40927423},
  pmcid = {PMC12415031},
  keywords = {ME/CFS, Gulf War Illness, central sensitization, nociplastic pain, interoception, descending inhibition, dolorimetry, tenderness, fatigue, post-exertional malaise},
  note = {Georgetown University cohort study (ME/CFS, GWI, sedentary controls). ME/CFS and GWI patients significantly more tender than controls (females p<0.0045, males p<1e-6 by dolorimetry). Pain and interoception highly correlated. Proposes midbrain/medullary regulatory pathway injury causing dual loss of descending antiinteroceptive and antinociceptive inhibition. Coins "interoplastic distress" parallel to nociplastic pain for visceral hypersensitivity. Disease reconceptualized as chronic disabling fatigue with heightened interoceptive and nociceptive symptoms.}
}

