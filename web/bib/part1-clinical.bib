@article{Gotts2015napCFS,
  author       = {Gotts, Zoe M. and Ellis, Jason G. and Deary, Vincent and Barclay, Nicola L. and Newton, Julia L.},
  title        = {The association between daytime napping and cognitive functioning in chronic fatigue syndrome},
  journal      = {PLoS ONE},
  year         = {2015},
  volume       = {10},
  number       = {1},
  pages        = {e0117136},
  doi          = {10.1371/journal.pone.0117136},
  pmid         = {25575044},
  url          = {https://doi.org/10.1371/journal.pone.0117136},
  keywords     = {ME/CFS, napping, cognitive dysfunction, sleep diary, daytime sleepiness},
  certainty    = {0.50},
  research_stream = {sleep-nap-pathophysiology},
  note         = {N=118 CFS (Fukuda). 14-day sleep diary + neuropsychological testing. Afternoon napping predicted worse objective cognitive dysfunction (25.6\% variance, p<.001); morning napping predicted worse subjective cognitive dysfunction (32.2\% variance). Observational — cannot determine direction of causation (napping may reflect severity, not cause impairment). No physiological nap characterisation (no EEG). First study to quantify nap-cognition association in CFS.}
}

@article{Tassi2000sleepInertia,
  author       = {Tassi, Patricia and Muzet, Alain},
  title        = {Sleep inertia},
  journal      = {Sleep Medicine Reviews},
  year         = {2000},
  volume       = {4},
  number       = {4},
  pages        = {341--353},
  doi          = {10.1053/smrv.2000.0098},
  pmid         = {12531174},
  url          = {https://doi.org/10.1053/smrv.2000.0098},
  keywords     = {sleep inertia, post-sleep performance, arousal, napping, slow-wave sleep},
  certainty    = {0.75},
  research_stream = {sleep-nap-pathophysiology},
  note         = {Narrative review of sleep inertia physiology. Duration: 1 min to 4 hours depending on conditions; rarely exceeds 30 min without major sleep deprivation. Most severe after SWS awakening (naps >30 min entering deep sleep produce worse inertia than <20 min naps). Dose-dependent with prior sleep debt. Circadian modulation (worse near core body temperature trough). Different cognitive tasks show different sensitivity. Foundational reference for ME/CFS nap guidance — predicts amplified sleep inertia in patients with pre-existing energy deficits and sleep architecture disruption.}
}

