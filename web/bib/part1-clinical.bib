@article{Workinger2018,
  author  = {Workinger, Jayme L and Doyle, Robert P and Bortz, Jonathan},
  title   = {Challenges in the diagnosis of magnesium status},
  journal = {Nutrients},
  year    = {2018},
  volume  = {10},
  number  = {9},
  pages   = {1202},
  doi     = {10.3390/nu10091202},
  pmid    = {30200431},
  url     = {https://pmc.ncbi.nlm.nih.gov/articles/PMC6163803/},
  keywords = {magnesium, serum magnesium, intracellular magnesium, RBC magnesium, testing limitations, reference range, deficiency},
  note    = {Narrative review. Only ~1\% of body magnesium is in serum; 99\% is intracellular. Serum levels are tightly defended by renal excretion and do not reflect total body or tissue stores. No validated rapid test for true magnesium status exists. RBC magnesium is better proxy but not standardized. Estimated 45\% of Americans are magnesium-deficient by dietary standards.}
}

@article{RussellJones2022,
  author  = {Russell-Jones, Gregory},
  title   = {Functional vitamin {B12} deficiency in chronic fatigue syndrome},
  journal = {International Journal of Psychiatry},
  year    = {2022},
  volume  = {7},
  number  = {3},
  pages   = {153--158},
  doi     = {10.33140/IJP},
  url     = {https://www.opastpublishers.com/peer-review/functional-vitamin-b12-deficiency-in-chronic-fatigue-syndrome-1771.html},
  keywords = {ME/CFS, vitamin B12, functional deficiency, methylmalonic acid, riboflavin, reference range, paradoxical B12 deficiency},
  note    = {Observational study (n=350 CFS individuals). Majority showed functional B12 deficiency markers (elevated methylmalonic acid, urinary metabolites) despite normal to elevated serum B12. Termed "paradoxical vitamin B12 deficiency." B2 (riboflavin) co-deficiency proposed as mechanistic explanation. Not PubMed-indexed; low-tier journal — treat as hypothesis-generating only.}
