  title = {Association of postural orthostatic tachycardia syndrome, hypermobility spectrum disorders, and mast cell activation syndrome in young patients; prevalence, overlap and response to therapy depends on the definition},
  journal = {Frontiers in Neurology},
  year = {2025},
  volume = {16},
  pages = {1513199},
  doi = {10.3389/fneur.2025.1513199},
  pmid = {40352770},
  pmcid = {PMC12063504},
  keywords = {POTS, MCAS, hEDS, HSD, hypermobility, diagnostic criteria, therapy response, triad},
  certainty = {0.52},
  research_stream = {mcas-primary-driver},
  note = {Prospective study; n=100 young patients (mean age 17.2 years) meeting POTS criteria. MCAS prevalence varied enormously by criteria: 2\% (consensus-1), 37\% (conservative consensus-2), 87\% (clinical). Therapy response to MCAS-targeted treatment: 75--91\% across all diagnostic groups, including those without laboratory confirmation. Most commonly positive lab: plasma histamine then chromogranin A. Demonstrates that overly restrictive diagnostic criteria risk missing therapeutic opportunities. Confirms mast cell--dysautonomia triad in young patients.}
}

