@article{Wirth2026prodromalICD,
  author   = {Wirth, Marielle and Haastert, Burkhard and Linnenkamp, Ute and Andrich, Silke and Icks, Andrea and Pricoco, Rafael and Behrends, Uta and De Bock, Freia},
  title    = {{ICD}-10 Diagnoses prior to {ME/CFS} diagnosis in children and young people suggest potential early diagnostic indicators},
  journal  = {Scientific Reports},
  year     = {2026},
  doi      = {10.1038/s41598-026-40848-1},
  pmid     = {41741569},
  pmcid    = {PMC12949141},
  url      = {https://pmc.ncbi.nlm.nih.gov/articles/PMC12949141/},
  keywords = {ME/CFS, pediatric, prodromal, ICD-10, pre-illness, diagnostic delay, fatigue, pain, cognitive impairment, children, adolescents, retrospective},
  certainty = {0.70},
  research_stream = {lower-baseline-predisposition},
  note     = {Retrospective matched case-control study. n=6,077 pediatric ME/CFS cases matched 1:5 to 30,255 controls (N=36,332 total). German statutory health insurance data 2020--2022. 48 ICD-10 code classes significantly associated with later ME/CFS diagnosis. High-prevalence associations: fatigue (OR 2.19), pain disorders (OR 1.55), somatoform disorders (OR 1.32), depression (OR 1.21). Rare but strong associations: post-COVID condition (OR 3.84), mild cognitive impairment (OR 2.93), fibromyalgia (OR 2.08). Pre-illness diagnoses span fatigue, pain, sleep, cognitive, and mental health categories. INTERPRETATION CAVEAT: pre-Dx mental health codes (depression, somatoform) may partly represent misattributed prodromal ME/CFS symptoms rather than true psychiatric comorbidities. Documents 5-year window of elevated medical utilization before formal ME/CFS diagnosis in children.}
}

@article{Collin2018sleepCFS,
  author   = {Collin, Simon M and Norris, Tom and Gringras, Paul and Blair, Peter S and Tilling, Kate and Crawley, Esther},
  title    = {Childhood sleep and adolescent chronic fatigue syndrome ({CFS/ME}): evidence of associations in a {UK} birth cohort},
  journal  = {Sleep Medicine},
  year     = {2018},
  volume   = {47},
  pages    = {85--91},
  doi      = {10.1016/j.sleep.2018.01.005},
  pmid     = {29773208},
  pmcid    = {PMC5974860},
  url      = {https://pmc.ncbi.nlm.nih.gov/articles/PMC5974860/},
  keywords = {ME/CFS, sleep, childhood, adolescent, prodromal, prospective, ALSPAC, birth cohort, chronic disabling fatigue, unrefreshing sleep, sleep duration},
  certainty = {0.65},
  research_stream = {lower-baseline-predisposition},
  note     = {Prospective population-based birth cohort (ALSPAC, UK). N=13,978 children followed birth to age 18; 242 developed chronic disabling fatigue (CDF). Sleep abnormalities 4--7 years before ME/CFS diagnosis: shorter nighttime sleep duration across ages 6 months--11 years, difficulty falling asleep (OR 1.74), later bedtimes (mean 11 min later), more frequent nighttime awakenings. Quantified: each additional hour sleep at age 9 reduced CDF odds at age 13 by 39\%; at age 11 reduced odds at age 16 by 51\%. PRODROMAL SIGNAL: sleep disruption predates diagnosis by years, suggesting common pathophysiological cause (likely autonomic dysregulation) rather than consequence of illness. LIMITATION: CDF definition may not fully align with strict ME/CFS criteria.}
}

@article{Wyller2007thermoregCFS,
  author   = {Wyller, Vegard Bruun and Godang, Kristin and M{\o}rkrid, Lars and Saul, Jerome Philip and Thaulow, Erik and Wall{\o}e, Lars},
  title    = {Abnormal thermoregulatory responses in adolescents with chronic fatigue syndrome: relation to clinical symptoms},
  journal  = {Pediatrics},
  year     = {2007},
  volume   = {120},
  number   = {1},
  pages    = {e129--e137},
  doi      = {10.1542/peds.2006-2759},
  pmid     = {17606539},
  url      = {https://pubmed.ncbi.nlm.nih.gov/17606539/},
  keywords = {ME/CFS, adolescent, thermoregulation, dysautonomia, sympathetic, catecholamines, cold extremities, vasoconstriction, pediatric},
  certainty = {0.50},
  research_stream = {lower-baseline-predisposition},
  note     = {Comparative clinical study. n=15 adolescent CFS patients (ages 12--18) vs 57 healthy controls. Abnormal catecholaminergic-dependent thermoregulatory responses at rest and during cooling. During hand cooling, acral skin blood flow less reduced and vasoconstriction events occurred at lower temperatures than controls. Elevated basal norepinephrine, epinephrine, heart rate at rest. Catecholamine cooling responses comparable between groups, suggesting central rather than peripheral sympathetic impairment. Patients reported more shivering, sweating, skin color changes. Cold extremities in adolescent ME/CFS reflect documentable sympathetic dysfunction, not benign circulatory variation. LIMITATION: very small n=15, single center, cross-sectional design.}
}

@article{Moak2024SFNpediatric,
  author   = {Moak, Jeffrey P and Ramwell, Carolyn B and Gordish-Dressman, Heather and Sule, Sangeeta D and Bettini, Elizabeth},
  title    = {Small fiber neuropathy in children, adolescents, and young adults with chronic orthostatic intolerance and postural orthostatic tachycardia syndrome: {A} retrospective study},
  journal  = {Autonomic Neuroscience},
  year     = {2024},
  volume   = {253},
  pages    = {103163},
  doi      = {10.1016/j.autneu.2024.103163},
  pmid     = {38537312},
  url      = {https://pubmed.ncbi.nlm.nih.gov/38537312/},
  keywords = {small fiber neuropathy, SFN, POTS, orthostatic intolerance, pediatric, adolescent, skin biopsy, dysautonomia, autoimmune, fatigue, tremor},
  certainty = {0.50},
  research_stream = {lower-baseline-predisposition},
  note     = {Retrospective cohort, n=109 children, adolescents, and young adults with POTS/OI and neuropathic symptoms. Skin biopsy for SFN abnormal in 53\%. Patients with SFN had 3x probability of positive ANA or anti-thyroid antibody, suggesting autoimmune substrate. Combined presentation: OI + fatigue + paresthesia + brain fog + pain. SFN causes autonomic dysfunction that manifests as exercise intolerance, cold extremities, and postural tremor in young patients. Provides mechanistic basis for subtle neurological symptoms (tremor, unsteadiness) in adolescents with subclinical dysautonomia predating ME/CFS diagnosis. LIMITATION: single center specialty clinic, retrospective, no healthy control biopsy group.}
}

@article{Kato2006premorbid,
  author   = {Kato, Kenji and Sullivan, Patrick F and Eveng{\aa}rd, Birgitta and Pedersen, Nancy L},
  title    = {Premorbid Predictors of Chronic Fatigue},
  journal  = {Archives of General Psychiatry},
  year     = {2006},
  volume   = {63},
  number   = {11},
  pages    = {1267--1272},
  doi      = {10.1001/archpsyc.63.11.1267},
  pmid     = {17088507},
  url      = {https://pubmed.ncbi.nlm.nih.gov/17088507/},
  keywords = {chronic fatigue, premorbid, stress, emotional instability, twin study, Swedish Twin Registry, prospective, predictors, genetics, environment},
  certainty = {0.50},
  research_stream = {lower-baseline-predisposition},
  note     = {Prospective nested case-control in Swedish Twin Registry. N=19,192 twins; pre-illness measures taken 25 years before fatigue onset. Emotional instability: 55--72\% increased risk in initial analyses, but effect disappeared in discordant MZ pairs, indicating genetic basis. Perceived stress: 64--65\% elevated risk; strengthened to 5.81-fold after genetic control, indicating true environmental causal factor. Extraversion: no association. LIMITATION: outcome is ``chronic fatigue'' broadly defined, not strictly ME/CFS; predictors are psychological instruments not physiological biomarkers; 25-year lead time may miss onset-proximate prodromal factors. CAUTION: emotional instability as premorbid predictor may partly reflect subclinical autonomic dysregulation mislabeled as personality trait.}
}

@article{Jason2015CFSvsME,
  author   = {Jason, Leonard A and Evans, Meredyth and Brown, Abigail and Sunnquist, Madison and Newton, Julia L},
  title    = {Chronic Fatigue Syndrome Versus Sudden Onset Myalgic Encephalomyelitis},
  journal  = {Journal of Prevention \& Intervention in the Community},
  year     = {2015},
  volume   = {43},
  number   = {1},
  pages    = {6--12},
  doi      = {10.1080/10852352.2014.973233},
  pmid     = {25584529},
  url      = {https://pubmed.ncbi.nlm.nih.gov/25584529/},
  keywords = {ME/CFS, sudden onset, gradual onset, myalgic encephalomyelitis, chronic fatigue syndrome, post-exertional malaise, functional impairment, case definition, onset},
  certainty = {0.55},
  research_stream = {lower-baseline-predisposition},
  note     = {Comparative study. N=285 (DePaul n=189; Newcastle n=96). Compared ME (sudden onset within 24h--1 week) vs standard CFS criteria groups. ME patients had more severe functional limitations on Physical Functioning, Role Physical, Bodily Pain measures; greater PEM severity. NULL RESULT FOR PRODROME: sudden-onset ME subtype by definition excludes gradual prodromal deterioration. Study confirms a substantial subpopulation of ME/CFS has no identifiable prodromal phase. Prodromal evidence from other studies applies to gradual-onset CFS subtype; not universal. LIMITATION: retrospective onset categorization subject to recall bias.}
}

@article{Geraghty2019diagnosticAccuracy,
  author   = {Geraghty, Keith James and Adeniji, Charles},
  title    = {The Importance of Accurate Diagnosis of {ME/CFS} in Children and Adolescents: {A} Commentary},
  journal  = {Frontiers in Pediatrics},
  year     = {2019},
  volume   = {7},
  pages    = {435},
  doi      = {10.3389/fped.2018.00435},
  pmid     = {30719431},
  url      = {https://pmc.ncbi.nlm.nih.gov/articles/PMC6348258/},
  keywords = {ME/CFS, pediatric, diagnosis, misdiagnosis, diagnostic accuracy, children, adolescents, overdiagnosis, underdiagnosis},
  certainty = {0.40},
  research_stream = {lower-baseline-predisposition},
  note     = {Commentary/narrative review. Key data points: 40\% diagnostic error rate among children referred to specialist ME/CFS clinics. Misdiagnosis categories: 47\% other chronic disease, 20\% primary sleep disorder (consistent with Collin 2018 prodromal sleep data), 15\% psychiatric, 4\% cardiovascular (likely OI/POTS). Adult ME/CFS: average 5 years to diagnosis; pediatric: increased medical consultations up to 5 years before diagnosis. 80\% of pediatric broad-criteria cases recovered by age 18 -- significant overdiagnosis risk with loose criteria. PEM identified as cardinal symptom most frequently missed. IMPORTANT CAVEAT: this dual error rate (under- AND over-diagnosis) means the prodromal period data reflects genuine ME/CFS cases being missed early, but also non-ME/CFS fatigue being prematurely labeled.}
}

