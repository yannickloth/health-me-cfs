  url = {https://doi.org/10.3390/nu13082658},
  keywords = {ME/CFS, CoQ10, NADH, mitochondrial support, fatigue, quality of life, RCT},
  note = {Prospective RCT (n=207, 104 active, 103 placebo) testing 200 mg CoQ10 + 20 mg NADH daily for 12 weeks. Significant improvements: cognitive fatigue (p<0.001), overall FIS-40 (p=0.022), QoL SF-36 (p<0.05), sleep duration at 4 weeks (p=0.018), sleep efficiency at 8 weeks (p=0.038). Benefits persisted 4 weeks post-treatment. No serious adverse events. High-quality evidence for mitochondrial support in ME/CFS}
}

