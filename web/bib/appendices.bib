  number = {2},
  pages = {264--266},
  doi = {10.1016/j.bbrc.2003.09.207},
  pmid = {14592408},
  url = {https://pubmed.ncbi.nlm.nih.gov/14592408/},
  keywords = {ME/CFS, serotonin transporter, 5-HTT, SLC6A4, gene polymorphism, HPA axis, CFS biomarker},
  abstract = {Examination of serotonin transporter gene promoter in 78 CFS patients found significant increase of longer L and XL allelic variants compared to controls. Longer variants may reduce extracellular serotonin availability, increasing vulnerability to CFS. Authors propose connection between serotonergic dysfunction and HPA axis disruption observed in CFS patients.}
}

