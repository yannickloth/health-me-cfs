@article{Lansky2025trpv3dynamics,
  author   = {Lansky, Shifra and Wang, Zhaokun and Clarke, Oliver B and Chipot, Christophe and Scheuring, Simon},
  title    = {Structural dynamics and permeability of the {TRPV3} pentamer},
  journal  = {Nature Communications},
  year     = {2025},
  volume   = {16},
  pages    = {4347},
  doi      = {10.1038/s41467-025-59798-9},
  pmid     = {40374654},
  url      = {https://doi.org/10.1038/s41467-025-59798-9},
  keywords = {TRPV3, pentamer, cryo-EM, molecular dynamics, pore permeability, large cations, domain-swapped},
  certainty = {0.78},
  research_stream = {trp-pentamer-vascular},
  note     = {Improved cryo-EM at 4.07 Å plus MD simulations. Pentamer has domain-swapped architecture, collapsed vanilloid binding site, selectivity filter 5.3-fold wider than closed tetramer, gate 7.3-fold wider. MD shows free passage of large cations (Tris+, NMDG+, 2-MAE+). Agonists (2-APB, camphor, propofol) destabilize TRPV3 tetramers and facilitate pentamer formation. Authors classify pentamer as a "hyper-activated state." Follow-up to Lansky 2023 from same group; provides the mechanistic underpinning of large-cation permeability in dilated state.}
}

% --- Cavanaugh et al. 2011: TRPV1 in arteriolar smooth muscle ---

@article{Cavanaugh2011trpv1vascular,
