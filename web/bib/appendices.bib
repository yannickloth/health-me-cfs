  keywords = {chronic fatigue syndrome, acylcarnitine, carnitine palmitoyltransferase-I, fatty acid oxidation, mitochondrial dysfunction},
  note = {Study of 44 CFS patients vs 49 healthy controls. Found long-chain acylcarnitines (oleyl-L-carnitine C18:1 and linoleyl-L-carnitine C18:2) 30-40\% lower in CFS patients (p<0.0001). Suggests reduced CPT-I activity preventing long-chain fatty acid transport into mitochondria for beta-oxidation. Demonstrates impaired carnitine shuttle function in ME/CFS}
}

@article{Nelson2019,
  author = {Nelson, Libby D and Temkin, Nancy R and Barber, Jason and Brett, Barbara L and Okonkwo, David O and McCrea, Michael and Whyte, John and Giacino, Joseph T and Markowitz, Amy J and Korley, Frederick K and Diaz-Arrastia, Ramon and Sun, Xiaoying and Taylor, Sabrina R and Manley, Geoffrey T},
