  keywords = {ME/CFS, lactate, post-exertional malaise, lactic acid, metabolic dysfunction},
  note = {Study of 123 ME/CFS patients in France. Found 44.7\% (55 patients) had elevated resting blood lactate levels ≥2 mmol/L on one or more measurements. Patients with elevated lactate at rest showed significantly more severe post-exertional malaise after adjusting for age, sex, and comorbidities. Demonstrates subset of ME/CFS patients with baseline metabolic dysfunction manifesting as elevated lactate even at rest}
