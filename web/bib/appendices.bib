% --- Weymann et al.\ 2014: Orexin in chemotherapy-induced fatigue ---
@article{Weymann2014orexinChemoFatigue,
  author   = {Weymann, K. B. and Wood, L. J. and Zhu, X. and Marks, D. L.},
  title    = {A role for orexin in cytotoxic chemotherapy-induced fatigue},
  journal  = {Brain, Behavior, and Immunity},
  year     = {2014},
  volume   = {37},
  pages    = {84--94},
  doi      = {10.1016/j.bbi.2013.11.003},
  pmid     = {24216337},
  url      = {https://doi.org/10.1016/j.bbi.2013.11.003},
  keywords = {orexin, fatigue, chemotherapy, cancer, inflammation, hypothalamus, IL-1, TNF, cytokine},
  research_stream = {orexin-hypothalamic-dysfunction},
  certainty = {0.55},
  note     = {Rodent study. CAF chemotherapy (cyclophosphamide/adriamycin/5-FU) induces hypothalamic neuroinflammation (IL-1R1, IL-6, TNF$\alpha$, MCP-1 upregulation), suppresses orexin neuron activity (reduced cFos and CSF orexin-A), and causes fatigue behaviors. Central orexin-A administration restores locomotor activity in treated animals. Demonstrates cytokine-mediated orexin suppression as causal driver of inflammation-associated fatigue — directly relevant to ME/CFS neuroimmune fatigue model.},
}

% --- Ruhrländer et al.\ 2025: Orexin system and autonomic/cardiometabolic effects in PASC ---
@article{Ruhrländer2025orexinPASC,
  author   = {Ruhrländer, Jana and Syntila, Styliani and Schieffer, Elisabeth and Schieffer, Bernhard},
  title    = {The orexin system and its impact on the autonomic nervous and cardiometabolic system in post-acute sequelae of {COVID-19}},
