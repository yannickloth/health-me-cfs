  research_stream = {trp-pentamer-vascular},
  note     = {TRPV1 reporter mouse (genetic lineage tracing). Neuronal TRPV1 is restricted to nociceptors in primary sensory ganglia and a discrete hypothalamic band. TRPV1 is also expressed in arteriolar smooth muscle cells in thermoregulatory tissues (cremaster, dura, tongue, trachea, skin). Capsaicin in smooth muscle cells increases calcium and causes vasoconstriction, counteracting the vasodilation from neuronal TRPV1. Distribution pattern conserved across mouse, rat, monkey, human. Julius/Basbaum group (Nobel context). High certainty for vascular expression; ME/CFS relevance via arteriolar tone during exercise is a speculative extension.}
}

% --- Phan et al. 2020: TRPV1 throughout arterial circulation ---

@article{Phan2020trpv1arterial,
  author   = {Phan, Thieu X and Ton, Hoai T and Guly{\'a}s, Hajnalka and P{\'o}rszász, R{\'o}bert and
              T{\'o}th, Attila and Russo, Rebekah and Kay, Matthew W and Sahibzada, Niaz and Ahern, Gerard P},
  title    = {{TRPV1} expressed throughout the arterial circulation regulates vasoconstriction and blood pressure},
  journal  = {The Journal of Physiology},
  year     = {2020},
  volume   = {598},
  number   = {24},
  pages    = {5639--5659},
  doi      = {10.1113/JP279909},
  pmid     = {32944976},
  url      = {https://doi.org/10.1113/JP279909},
  keywords = {TRPV1, vascular smooth muscle, vasoconstriction, blood pressure, arteriole, lysophosphatidic acid, inflammatory lipids},
  certainty = {0.72},
  research_stream = {trp-pentamer-vascular},
  note     = {Pharmacological antagonism + genetic knockout. TRPV1 localizes to terminal arterioles throughout circulation (skeletal muscle, heart, adipose). Capsaicin causes dose-dependent vasoconstriction and elevated systemic blood pressure; effect persists after sensory nerve ablation (confirming vascular-intrinsic, not neuronal). Arteriolar TRPV1 resistant to activity-induced desensitization (unlike sensory neurons). Lysophosphatidic acid (endogenous inflammatory lipid) activates arteriolar TRPV1. Mechanistically: depolarizing current -> L-type Ca2+ channel activation -> sustained vasoconstriction. Relevant to PEM hypothesis: inflammatory lipids during exercise-induced tissue damage could activate arteriolar TRPV1 causing inappropriate sustained vasoconstriction.}
}

