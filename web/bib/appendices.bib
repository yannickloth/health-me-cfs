@article{Huang2024Adenosine,
  author = {Huang, Li and Zhu, Wei and Li, Na and Zhang, Bo and Dai, Wei and Li, Shuai and Xu, Hua},
  title = {Functions and mechanisms of adenosine and its receptors in sleep regulation},
  journal = {Sleep Medicine},
  year = {2024},
  volume = {115},
  pages = {210--217},
  doi = {10.1016/j.sleep.2024.02.012},
  pmid = {38373361},
  url = {https://doi.org/10.1016/j.sleep.2024.02.012},
  keywords = {adenosine, sleep homeostasis, A1 receptor, A2A receptor, astrocyte, sleep pressure, sleep regulation},
  note = {Comprehensive review establishing that adenosine promotes sleep by inhibiting arousal systems and activating sleep-promoting systems. Astrocyte-derived adenosine is critical for sleep homeostasis. A1 and A2A receptors mediate distinct aspects of sleep pressure accumulation. Documents that caffeine's wake-promoting effect operates through adenosine receptor blockade. Key mechanistic reference for adenosine as the primary homeostatic sleep signal.}
}

@article{Retey2007ADORA2A,
  author = {R{\'e}tey, Julia V and Adam, Martin and Khatami, Ramin and Luhmann, Ulrich F O and Jung, Hans H and Berger, Wolfgang and Landolt, Hans-Peter},
  title = {A genetic variation in the adenosine {A2A} receptor gene ({ADORA2A}) contributes to individual sensitivity to caffeine effects on sleep},
  journal = {Clinical Pharmacology \& Therapeutics},
  year = {2007},
  volume = {81},
  number = {5},
  pages = {692--698},
  doi = {10.1038/sj.clpt.6100102},
  pmid = {17329997},
  url = {https://doi.org/10.1038/sj.clpt.6100102},
  keywords = {ADORA2A, caffeine, adenosine A2A receptor, sleep, individual sensitivity, pharmacogenetics},
  note = {Pharmacogenetic study demonstrating that the ADORA2A c.1083T>C single nucleotide polymorphism determines individual sensitivity to caffeine-induced sleep disruption. The ADORA2A genotype determines how closely caffeine-induced changes in brain electrical activity during sleep resemble insomnia patterns. Caffeine sensitivity is a functional readout of A2A receptor sensitivity, establishing genetic variation as a modulator of adenosine sleep signaling. Relevant to understanding ME/CFS patients' variable caffeine responses.}
}

