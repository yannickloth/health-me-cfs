  url      = {https://pubmed.ncbi.nlm.nih.gov/38537312/},
  keywords = {small fiber neuropathy, SFN, POTS, orthostatic intolerance, pediatric, adolescent, skin biopsy, dysautonomia, autoimmune, fatigue, tremor},
  certainty = {0.50},
  research_stream = {lower-baseline-predisposition},
  note     = {Retrospective cohort, n=109 children, adolescents, and young adults with POTS/OI and neuropathic symptoms. Skin biopsy for SFN abnormal in 53\%. Patients with SFN had 3x probability of positive ANA or anti-thyroid antibody, suggesting autoimmune substrate. Combined presentation: OI + fatigue + paresthesia + brain fog + pain. SFN causes autonomic dysfunction that manifests as exercise intolerance, cold extremities, and postural tremor in young patients. Provides mechanistic basis for subtle neurological symptoms (tremor, unsteadiness) in adolescents with subclinical dysautonomia predating ME/CFS diagnosis. LIMITATION: single center specialty clinic, retrospective, no healthy control biopsy group.}
}

@article{Kato2006premorbid,
