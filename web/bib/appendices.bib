  year = {2014},
  volume = {171},
  number = {8},
  pages = {2099--2122},
  doi = {10.1111/bph.12369},
  pmid = {23991830},
  url = {https://doi.org/10.1111/bph.12369},
  note = {Biochemical review with experimental evidence. H2S has biphasic mitochondrial effects: at low-physiological concentrations donates electrons via SQR stimulating ETC; at high-toxic concentrations competitively inhibits Complex IV (cytochrome c oxidase) at cytochrome a3, blocking O2 binding, causing electron backup, inner membrane potential collapse, and cessation of aerobic ATP synthesis. Mechanism identical to cyanide at high dose. Colonocytes normally metabolise H2S as barrier; ISO (intestinal sulfide overproduction) overwhelms this barrier. Relevance: SIBO-derived H2S → systemic exposure → Complex IV inhibition → ME/CFS-relevant mitochondrial dysfunction},
  keywords = {hydrogen sulfide, H2S, mitochondria, Complex IV, cytochrome c oxidase, SQR, ATP, SIBO, ISO, electron transport chain},
  certaintyscore = {0.80},
  research_stream = {pathophysiology}
}

