  volume   = {17},
  number   = {1},
  pages    = {16},
  doi      = {10.1038/s41419-025-08162-2},
  pmid     = {41513611},
  pmcid    = {PMC12789617},
  url      = {https://doi.org/10.1038/s41419-025-08162-2},
  note     = {Theoretical framework proposing virus-induced endothelial senescence (and the resulting SASP: proinflammatory, pro-oxidative, procoagulant, vasoconstriction-primed) as the unifying mechanistic cause of ME/CFS and long COVID. Central insight: NK cell dysfunction and T cell exhaustion (documented in ME/CFS) prevent clearance of senescent endothelial cells, creating a self-sustaining bidirectional loop between SASP and immune dysfunction. Tissue-specific endothelial senescence at the BBB, cerebral arteries, GI tract, and skeletal muscle microvasculature maps to specific ME/CFS symptom clusters. Implies senolytics and immune restoration as therapeutic targets. Review/theory paper — endothelial senescence not yet directly measured in ME/CFS patient tissue.},
  keywords = {ME/CFS, long COVID, endothelial senescence, SASP, endothelial dysfunction, post-viral, NK cell, immune dysfunction, cerebral blood flow, PEM, senolytics, vascular}
}

