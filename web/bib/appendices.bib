@article{Zhao2026exercise,
  author  = {Zhao, Liping and Gou, Bo and Zhang, Meng},
  title   = {The efficacy of exercise in patients with myalgic encephalomyelitis/chronic fatigue syndrome: {A} systematic review and meta-analysis},
  journal = {Journal of Psychosomatic Research},
  year    = {2026},
  doi     = {10.1016/j.jpsychores.2026.112136},
  url     = {https://www.sciencedirect.com/science/article/abs/pii/S0022399926001613},
  keywords = {ME/CFS, exercise therapy, meta-analysis, fatigue, subjective outcomes, cardiopulmonary function, risk of bias},
  note    = {Systematic review and meta-analysis; 17 RCTs, n=1,944. Exercise improves subjective outcomes (fatigue SMD=0.85, sleep, QoL, depression, anxiety) but NOT objective outcomes (cardiopulmonary function, functional capacity). Authors' own RoB 2.0 assessment found ``prevalent high risk of bias across included studies'' but dismissed bias as ``inherent challenges of the field rather than fatal flaws.'' Used mixed diagnostic criteria including Oxford (no PEM required) and Fukuda (PEM optional). Pooled aerobic exercise with yoga, qigong, tai chi. The subjective-only improvement pattern is the predicted signature of blinding bias per Savović 2012 and Hróbjartsson 2014.}
}

@article{Hrobjartsson2014blinding,
  author  = {Hróbjartsson, Asbjørn and Emanuelsson, Frida and Thomsen, Ann Sofia Skou and Hilden, Jørgen and Brorson, Stig},
  title   = {Bias due to lack of patient blinding in clinical trials. {A} systematic review of trials randomizing patients to blind and nonblind sub-studies},
