  number   = {7},
  pages    = {1651--1666},
  doi      = {10.1113/JP281873},
  pmid     = {35020949},
  url      = {https://doi.org/10.1113/JP281873},
  keywords = {TRPV1, myogenic tone, arteriole, stretch, mechanosensation, PKC, PLC, TRPM4, blood flow},
  certainty = {0.72},
  research_stream = {trp-pentamer-vascular},
  note     = {Pharmacological + genetic (TRPV1 KO). TRPV1 antagonists dilate skeletal muscle arterioles in vitro and in vivo, increase coronary flow, transiently decrease blood pressure. Stretch activates TRPV1 via PLC/PKC + temperature. TRPM4 contributes remaining tone. TRPV1 disruption slows tone development and impairs post-constriction vasodilation. Same Ahern group as Phan 2020; companion mechanistic paper. Relevant to PEM: TRPV1-driven myogenic tone in skeletal muscle arterioles during exercise; sensitized TRPV1 could impair normal exercise vasodilation.}
}

