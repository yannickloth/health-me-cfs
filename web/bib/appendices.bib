@article{Yamashita2020fatigue,
  author = {Yamashita, Masatoshi},
  title = {Potential Role of Neuroactive Tryptophan Metabolites in Central Fatigue: Establishment of the Fatigue Circuit},
  journal = {International Journal of Tryptophan Research},
  year = {2020},
  volume = {13},
  pages = {1178646920936279},
  doi = {10.1177/1178646920936279},
  pmid = {32647476},
  pmcid = {PMC7325545},
  url = {https://pmc.ncbi.nlm.nih.gov/articles/PMC7325545/},
  keywords = {central fatigue, tryptophan, kynurenine, serotonin, fatigue circuit, hypothalamus, hippocampus, kynurenic acid},
  abstract = {Proposes a three-stage fatigue circuit in which tryptophan and kynurenine enter the brain and accumulate within the hypothalamus-hippocampal circuit, driving glial-neuronal kynurenic acid production (not serotonin) as the dominant mediator of central fatigue. Serotonin shows only transient release in exercise models and does not track fatigue duration. Kynurenic acid suppresses glutamate signaling and dopamine release, causing cognitive impairment. Blood-brain barrier breakdown in central fatigue allows free tryptophan entry. Challenges the classic serotonin-fatigue hypothesis and shifts emphasis to kynurenine pathway.}
}

@article{Maes2013serotonin,
  author = {Maes, Michael and Ringel, Karl and Kubera, Marta and Anderson, George and Morris, Gerwyn and Galecki, Piotr and Geffard, Michel},
  title = {In myalgic encephalomyelitis/chronic fatigue syndrome, increased autoimmune activity against 5-{HT} is associated with immuno-inflammatory pathways and bacterial translocation},
  journal = {Journal of Affective Disorders},
  year = {2013},
  volume = {150},
  number = {2},
  pages = {223--230},
  doi = {10.1016/j.jad.2013.03.029},
  pmid = {23664637},
  url = {https://www.sciencedirect.com/science/article/abs/pii/S0165032713002541},
  keywords = {ME/CFS, anti-5-HT autoantibodies, serotonin, autoimmunity, inflammatory pathways, bacterial translocation, hyperalgesia, neurocognitive},
  abstract = {Anti-5-HT autoantibody positivity was significantly higher in ME/CFS (61.5\%) than in chronic fatigue patients (13.9\%) and healthy controls (5.7\%). In ME/CFS patients with anti-5-HT antibodies, TNF-alpha, IL-1, and neopterin were elevated, and IgA responses to gram-negative LPS were increased (evidence of bacterial translocation). Anti-5-HT antibody positivity correlated with greater severity of hyperalgesia, fatigue, neurocognitive dysfunction, autonomic disturbances, mood symptoms, and flu-like malaise.}
}

@article{Noda2018glial,
  author = {Noda, Mami and Ifuku, Masataka and Hossain, Md Shamim and Katafuchi, Toshihiko},
  title = {Glial Activation and Expression of the Serotonin Transporter in Chronic Fatigue Syndrome},
  journal = {Frontiers in Psychiatry},
  year = {2018},
  volume = {9},
  pages = {589},
  doi = {10.3389/fpsyt.2018.00589},
  pmid = {30505285},
  pmcid = {PMC6250825},
  url = {https://pmc.ncbi.nlm.nih.gov/articles/PMC6250825/},
  keywords = {ME/CFS, glial activation, serotonin transporter, astrocyte, microglia, IL-1beta, neuroinflammation, blood-brain barrier},
  abstract = {Proposes a mechanistic pathway for immunologically-induced CFS: viral mimics increase blood-brain barrier permeability, activate microglia via TLR3 signaling, causing IL-1beta secretion. IL-1beta upregulates serotonin transporter (5-HTT) expression in astrocytes, reducing extracellular serotonin and impairing 5-HT1A receptor signaling. Neuroinflammation, especially via microglia and astrocyte activation, is proposed as a central mechanism in CFS pathogenesis.}
}

@article{Smith2008HTR2A,
  author = {Smith, Alicia K and Dimulescu, Irina and Falkenberg, Virginia R and Narasimhan, Supraja and Heim, Christine and Vernon, Suzanne D and Rajeevan, Mangalathu S},
  title = {Genetic evaluation of the serotonergic system in chronic fatigue syndrome},
  journal = {Psychoneuroendocrinology},
  year = {2008},
  volume = {33},
  number = {2},
  pages = {188--197},
  doi = {10.1016/j.psyneuen.2007.11.001},
  pmid = {18079067},
  url = {https://pubmed.ncbi.nlm.nih.gov/18079067/},
  keywords = {ME/CFS, HTR2A, serotonin receptor, genetic polymorphism, 5-HT2A, CFS, fatigue, disability},
  abstract = {Genetic study of 77 polymorphisms across serotonin-related genes in 137 subjects (40 CFS, 55 insufficient fatigue, 42 controls). Three HTR2A markers showed significant associations with CFS versus non-fatigued controls. The A allele of -1438G/A (rs6311) demonstrates increased promoter activity and creates a binding site for the Th1/E47 transcription factor involved in neural development. Sequence variation in HTR2A, potentially causing enhanced activity, may contribute to CFS pathophysiology.}
}

@article{Narita2003transporter,
  author = {Narita, Masaaki and Nishigami, Naoko and Narita, Naoko and Yamaguti, Kouzi and Okado, Nobuo and Watanabe, Yasuyoshi and Kuratsune, Hirohiko},
