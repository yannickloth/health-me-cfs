}

@article{LangIllievich2023PEA,
  author = {Lang-Illievich, Kordula and Klivinyi, Christoph and Lasser, Christine and Brenna, Christian T. A. and Szilagyi, Istvan S. and Rumpold-Seitlinger, Gudrun and Dorn, Claudia and Bornemann-Cimenti, Helmar},
