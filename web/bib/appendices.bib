@article{Valent2021criteria,
  author = {Valent, Peter and Akin, Cem and Bonadonna, Patrizia and Hartmann, Karin and Brockow, Knut and Niedoszytko, Marek and Nedoszytko, Boguslaw and Sperr, Wolfgang R. and Zink, Andrea and Franchini, Massimo and Nilsson, Gunnar and Oude Elberink, Hanneke N. G. and Austen, K. Frank and Escribano, Luis and Lange, Martin and Sotlar, Karl and Hornick, Jason L. and Kluin-Nelemans, Hanneke C. and Hermine, Olivier and Gotlib, Jason and Broesby-Olsen, Sigurd and Orfao, Alberto and Siebenhaar, Frank and Triggiani, Massimo and Arock, Michel and Schwartz, Lawrence B. and Horny, Hans-Peter and Metcalfe, Dean D. and Galli, Stephen J. and Magerl, Markus and Maurer, Marcus},
  title = {Updated Diagnostic Criteria and Classification of Mast Cell Disorders: A Consensus Proposal},
  journal = {HemaSphere},
  year = {2021},
  volume = {5},
  number = {11},
  pages = {e646},
  doi = {10.1097/HS9.0000000000000646},
  pmid = {34901755},
  keywords = {MCAS, mastocytosis, diagnostic criteria, consensus, tryptase, classification},
  certainty = {0.85},
  research_stream = {mcas-primary-driver},
  note = {International consensus from 2020 Working Conference. MCAS criteria: (1) episodic symptoms affecting $\geq$2 organ systems; (2) serum tryptase $\geq$20\% above individual baseline + 2 ng/mL within 4-hour window; (3) symptom improvement with mast cell--directed treatment. New additions: CD30 qualifies as SM minor criterion; bone marrow mastocytosis (BMM) as distinct entity; hereditary alpha-tryptasemia recognized. This is the primary international diagnostic reference for MCAS vs.\ systemic mastocytosis vs.\ idiopathic mast cell activation.}
}

@article{Lee2025CanadaMCAS,
  author = {Lee, Erika and Picard, Matthieu},
  title = {Diagnosis and management of mast cell activation syndrome ({MCAS}) in {Canada}: a practical approach},
  journal = {Allergy, Asthma \& Clinical Immunology},
