  pmid = {41790576},
  keywords = {mast cells, neuropathy, Long COVID, spike protein, TLR4, neuroinflammation, small-fiber neuropathy, ME/CFS},
  certainty = {0.55},
  research_stream = {long-covid},
  note = {Narrative review. SARS-CoV-2 spike protein activates mast cells via ACE2 and TLR4, triggering release of IL-1beta, IL-6, TNF-alpha, histamine, tryptase. Mast cell activation mirrors patterns in small-fiber neuropathy and ME/CFS. MCs near nerves/vessels regulate neuroimmune/neurovascular processes. Mediators sensitize peripheral nerves, disrupt BBB, recruit microglia → small-fiber injury, neuroinflammation, dysautonomia. MC-directed treatments show variable response.}
}

