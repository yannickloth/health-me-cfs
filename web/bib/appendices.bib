@article{BillingRoss2016mtDNA,
  author    = {Billing-Ross, Paul and Germain, Arnaud and Ye, Ketian and Keinan, Alon and Gu, Zhenglong and Hanson, Maureen R},
  title     = {Mitochondrial {DNA} variants correlate with symptoms in myalgic encephalomyelitis/chronic fatigue syndrome},
  journal   = {Journal of Translational Medicine},
  year      = {2016},
  volume    = {14},
  pages     = {19},
  doi       = {10.1186/s12967-016-0771-6},
  pmid      = {26791940},
  pmcid     = {PMC4719218},
  url       = {https://doi.org/10.1186/s12967-016-0771-6},
  keywords  = {ME/CFS, mtDNA, mitochondrial DNA, haplogroup, heteroplasmy, symptoms, susceptibility},
  certainty = {0.55},
  research_stream = {mitochondrial-predisposition},
  note      = {Complete mitochondrial genome sequencing, 193 ME/CFS cases vs 196 controls. No association between mtDNA variants and ME/CFS susceptibility (disease onset). However, haplogroups J, U, H and 8 specific SNPs significantly associated with symptom severity and type (joint pain, bloating, post-exertional "feeling dead"). Heteroplasmy levels low and comparable. Key null finding: inherited mtDNA variants do not predispose to ME/CFS but may modulate symptom expression. Requires independent replication.}
}

@article{Venter2019mtDNA,
  author    = {Venter, Mareke and Tomas, Cara and Pienaar, Ilse S and Strassheim, Victoria and Erasmus, Engela and Ng, Wan-Fai and Howell, Neil and Newton, Julia L and van der Westhuizen, Francois H and Elson, Joanna L},
  title     = {{MtDNA} population variation in Myalgic Encephalomyelitis/{Chronic} Fatigue Syndrome in two populations: a study of mildly deleterious variants},
  journal   = {Scientific Reports},
  year      = {2019},
  volume    = {9},
  pages     = {2914},
  doi       = {10.1038/s41598-019-39060-1},
  pmid      = {30814539},
  pmcid     = {PMC6393470},
  url       = {https://doi.org/10.1038/s41598-019-39060-1},
  keywords  = {ME/CFS, mtDNA, mildly deleterious variants, haplogroup, population genetics, UK, South Africa},
  certainty = {0.52},
  research_stream = {mitochondrial-predisposition},
  note      = {Whole mitochondrial genome sequencing in two independent cohorts: UK (118 patients, 64 controls), South Africa (143 patients, 98 controls). No clinically proven pathogenic mutations. Unexpected finding: ME/CFS patients had significantly fewer computationally-predicted mildly deleterious variants (UK: 55\% vs 27\% controls p=0.0008; SA: 56\% vs 41\% p=0.03). Suggests protective purifying selection or altered susceptibility landscape rather than classic mitochondrial disease mechanism. Replication of pattern across independent cohorts strengthens reliability.}
}

@article{Albright2011heritability,
  author    = {Albright, Frederick and Light, Kathleen and Light, Alan and Bateman, Lucinda and Cannon-Albright, Lisa A},
  title     = {Evidence for a heritable predisposition to Chronic Fatigue Syndrome},
  journal   = {BMC Neurology},
  year      = {2011},
  volume    = {11},
  pages     = {62},
  doi       = {10.1186/1471-2377-11-62},
  pmid      = {21619629},
  pmcid     = {PMC3128000},
  url       = {https://doi.org/10.1186/1471-2377-11-62},
  keywords  = {ME/CFS, CFS, heritability, family clustering, genealogy, Utah Population Database, genetic predisposition},
  certainty = {0.62},
  research_stream = {mitochondrial-predisposition},
  note      = {Population-based genealogical study using Utah Population Database, 811 CFS cases. First-degree relatives: RR=2.70 (p=0.001); second-degree: RR=2.34 (p=0.008); third-degree: RR=1.93 (p=0.009). Excess relatedness persisted when excluding close relatives (p=0.010), arguing against purely shared-environment explanation. Does not distinguish maternal vs paternal inheritance, so mitochondrial contribution cannot be inferred directly. Establishes that a heritable component exists; molecular basis undetermined.}
}

@article{Chang2020haploADHD,
  author    = {Chang, Xiao and Liu, Yichuan and Mentch, Frank and Glessner, Joseph and Qu, Huiqi and Nguyen, Kenny and Sleiman, Patrick M A and Hakonarson, Hakon},
  title     = {Mitochondrial {DNA} haplogroups and risk of attention deficit and hyperactivity disorder in {European Americans}},
  journal   = {Translational Psychiatry},
  year      = {2020},
  volume    = {10},
  pages     = {370},
  doi       = {10.1038/s41398-020-01064-1},
  pmid      = {33139694},
  pmcid     = {PMC7608630},
  url       = {https://doi.org/10.1038/s41398-020-01064-1},
  keywords  = {ADHD, mtDNA, haplogroup, European, K, U, HHV, mitochondrial dysfunction, risk, protective},
  certainty = {0.65},
  research_stream = {mitochondrial-predisposition},
  note      = {Case-control study, 2076 ADHD cases and 5078 controls across three independent European cohorts; haplogroups inferred from SNP arrays. Meta-analysis: haplogroups K and U protective (reduced ADHD risk); haplogroup HHV* increased risk. Haplogroups K/U overlap with ME/CFS symptom-modifying haplogroups from Billing-Ross 2016 (haplogroup U associated with less severe bloating in ME/CFS). Limitation: all cohorts from same institution; haplogroups inferred not sequenced.}
}

@article{Giannoulis2024sysrevmtADHD,
  author    = {Giannoulis, Stavroula V and M{\"u}ller, Daniel and Kennedy, James L and Gon{\c{c}}alves, Vanessa},
  title     = {Systematic review of mitochondrial genetic variation in attention-deficit/hyperactivity disorder},
  journal   = {European Child \& Adolescent Psychiatry},
  year      = {2024},
  volume    = {33},
  number    = {6},
  pages     = {1675--1685},
  doi       = {10.1007/s00787-022-02030-6},
  pmid      = {35796884},
  url       = {https://doi.org/10.1007/s00787-022-02030-6},
  keywords  = {ADHD, mtDNA, mitochondrial genetic variation, copy number, haplogroup, SNP, systematic review},
  certainty = {0.58},
  research_stream = {mitochondrial-predisposition},
  note      = {Systematic review; 507 articles screened, 10 primary studies selected. Findings: increased mtDNA copy number, specific SNP associations, and haplogroup effects documented across ADHD populations. Mitochondrial genetic variation in both mtDNA and nuclear-encoded mitochondrial genes may contribute to ADHD pathophysiology. Methodological limitations of primary studies noted (small samples, diverse populations, different measurement methods). Identifies the field as underdeveloped relative to other psychiatric disorders.}
}

@article{Verma2016ADHDcybrid,
  author    = {Verma, Poonam and Singh, Alpana and Nthenge-Ngumbau, Dominic Ngima and Rajamma, Usha and Sinha, Swagata and Mukhopadhyay, Kanchan and Mohanakumar, Kochupurackal P},
  title     = {Attention deficit-hyperactivity disorder suffers from mitochondrial dysfunction},
  journal   = {BBA Clinical},
  year      = {2016},
  volume    = {6},
  pages     = {153--158},
  doi       = {10.1016/j.bbacli.2016.10.003},
  pmid      = {27896136},
  pmcid     = {PMC5121149},
  url       = {https://doi.org/10.1016/j.bbacli.2016.10.003},
  keywords  = {ADHD, mitochondrial dysfunction, cybrid, Complex V, ATPase, oxidative stress, bioenergetics},
  certainty = {0.30},
  research_stream = {mitochondrial-predisposition},
  note      = {Cybrid cell lines created by fusing ADHD patient platelets with mitochondria-depleted neuroblastoma cells (n=3 ADHD, 4 controls, ages 5--13). Found significantly lower cellular and mitochondrial respiration, reduced ATPase6/8 transcripts, decreased Complex V activity, loss of mitochondrial membrane potential, elevated oxidative stress. First direct evidence that ADHD-associated mitochondrial dysfunction is transferable via patient mitochondria. Very small sample; cybrid model limitations include nuclear-cytoplasmic mismatch artifacts. Low certainty due to n=3, but mechanistically important.}
}

@article{Ogutlu2022ADHDmito,
  author    = {{\"O}g{\"u}tl{\"u}, Hakan and Ka{\c{s}}ak, Meryem and Tabur, Selin Tutku},
  title     = {Mitochondrial Dysfunction in Attention Deficit Hyperactivity Disorder},
  journal   = {Eurasian Journal of Medicine},
  year      = {2022},
  volume    = {54},
  number    = {Suppl 1},
  pages     = {S187--S195},
  doi       = {10.5152/eurasianjmed.2022.22187},
  pmid      = {36655466},
  pmcid     = {PMC11163340},
  url       = {https://doi.org/10.5152/eurasianjmed.2022.22187},
  keywords  = {ADHD, mitochondrial dysfunction, mtDNA copy number, oxidative stress, haplogroup B4, haplogroup K, haplogroup U, cybrid, biomarker},
  certainty = {0.45},
  research_stream = {mitochondrial-predisposition},
  note      = {Narrative review synthesizing human and animal studies on ADHD and mitochondrial dysfunction. Key data points: mtDNA copy number ~1.3x higher in ADHD vs controls; haplogroup B4 increases ADHD risk; haplogroups K and U reduce risk in European populations; 10398 A/G polymorphism significantly associated with ADHD in Korean cohort. Mitochondrial apoptotic signaling identified as second strongest mechanism in ADHD cases via GWAS. Notes parallel with ME/CFS: both conditions share reduced spare respiratory capacity, elevated oxidative stress, altered monoaminergic function. Haplogroup U appears protective in both ADHD (Chang 2020) and symptom-modifying in ME/CFS (Billing-Ross 2016).}
}

@article{Fanet2021BH4neuro,
  author    = {Fanet, Ha{\"i}l and Capuron, Lucile and Castanon, Nathalie and Calon, Fr{\'e}d{\'e}ric and Vancassel, Sylvie},
  title     = {Tetrahydrobiopterin ({BH4}) pathway: from metabolism to neuropsychiatry},
  journal   = {Current Neuropharmacology},
  year      = {2021},
  volume    = {19},
  number    = {5},
  pages     = {591--609},
  doi       = {10.2174/1570159X18666200729103529},
  pmid      = {32744952},
  url       = {https://pubmed.ncbi.nlm.nih.gov/32744952/},
  keywords  = {BH4, tetrahydrobiopterin, dopamine, serotonin, nitric oxide, neuropsychiatry, inflammation, oxidative stress, tyrosine hydroxylase},
  certainty = {0.50},
  research_stream = {adhd-energy-mecfs},
  note      = {Narrative review. BH4 cofactor for TH (dopamine/NE synthesis), TPH (serotonin synthesis), and all three NOS isoforms. Inflammatory cytokines paradoxically increase BH4 synthesis but drive its oxidation, causing net monoamine depletion. Reduced CSF BH4 associated with depression, Parkinson's, Alzheimer's, ADHD, autism. BH4 also has anti-inflammatory and anti-oxidant roles independent of neurotransmitter synthesis. Mechanistic bridge: infection/neuroinflammation → BH4 oxidative depletion → catecholamine deficiency → both ADHD-like and ME/CFS symptoms. Complements existing BH4 entries in bib (orthostatic intolerance).}
}

