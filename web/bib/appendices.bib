  pmid     = {40211686},
  keywords = {ME/CFS, post-COVID, autoantibody, immunoadsorption, rituximab, daratumumab, IVIG, efgartigimod, BC007, therapy, GPCR},
  note     = {Editorial review of autoantibody-targeting therapeutic approaches in ME/CFS and post-COVID syndrome. Covers: immunoadsorption (removes circulating IgG including disease autoantibodies); efgartigimod (FcRn blocker, enhances IgG degradation); BC007/rovunaptabin (neutralises GPCR autoantibodies); rituximab (B-cell depletion); daratumumab (plasma cell depletion). Reports promising but inconsistent results from first trials. Immunoadsorption in 20 post-COVID ME/CFS patients with elevated beta2-AR antibodies: 14/20 showed improvement in key symptoms and hand grip strength after 5 sessions. Discusses GPCR autoantibodies (beta2-adrenergic, muscarinic) as primary targets; ANT autoantibodies not discussed. Relevant as treatment-target framework: if anti-ANT antibodies are confirmed in ME/CFS, immunoadsorption and B-cell depletion would be the logical therapeutic approaches. Limitations: editorial; no abstract in PubMed; full text behind paywall; ANT autoantibodies not addressed.},
  certainty = {0.50},
  research_stream = {ant-autoantibodies}
}

