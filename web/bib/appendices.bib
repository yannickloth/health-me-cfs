  note = {Systematic review and meta-analysis of 13 double-blind RCTs of PEA for chronic pain. Pooled effect favors PEA with mean pain reduction of 1.68 points on 11-point scale. Pain reductions documented at 6 weeks, 8 weeks, and 24--26 weeks. Safety profile excellent with minimal side effects. Regarding micronized vs standard PEA: evidence for superiority of micronized formulations on analgesic outcomes is unclear; particle size effects may be relevant to absorption but clinical superiority not definitively established.}
}

@article{Roberts2004,
  author = {Roberts, David M and Okpalauwaekwe, Ugonma and Kellie, Scott and Drummond, Leanne M and Stowe, Alan M and Barber, P. Alan},
