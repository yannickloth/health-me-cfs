  research_stream = {ant-autoantibodies}
}

@article{ManchadoEtAl2002,
  author   = {Manchado, Carlos and Or{\'u}s, Josefina and Villarroya, Francesc and Roig, Eulalia and Heras, Magda and Giralt, Marta and Iglesias, Roser and Sanz, Gin{\'e}s and Mampel, Teresa and Vi{\~n}as, Octavi},
  title    = {Epitope mapping of mitochondrial adenine nucleotide translocase-1 in idiopathic dilated cardiomyopathy},
  journal  = {Journal of Molecular and Cellular Cardiology},
  year     = {2002},
  volume   = {34},
  number   = {5},
  pages    = {571--582},
  doi      = {10.1006/jmcc.2002.1538},
  keywords = {adenine nucleotide translocase, ANT1, autoantibody, epitope mapping, dilated cardiomyopathy, IDCM, M2 loop, M3 loop},
  note     = {Epitope mapping study in idiopathic DCM (IDCM). 16/45 (36\%) IDCM patients showed anti-ANT1 antibodies above controls. Primary epitopes located in C-terminal 146 amino acids; construct lacking these residues failed to react. Most significant epitopes in M2 and M3 hydrophilic loops of ANT1 (membrane-facing regions). At least three distinct epitopes identified. Distinguishes IDCM from ischemic dysfunction. Provides structural basis for understanding how surface-accessible ANT regions become immunogenic. Limitations: IDCM only; epitope accessibility to serum antibodies (i.e.\ in vivo vs.\ in vitro) not fully established; PMID not confirmed from available source.},
  certainty = {0.60},
  research_stream = {ant-autoantibodies}
}

@article{NilssonEtAl2020,
  author   = {Nilsson, Ingrid and Palmer, Johan and Apostolou, Eirini and Gottfries, Johan and Rizwan, Muhammad and Dahle, Charlotte and Ros{\'e}n, Anders},
  title    = {Metabolic Dysfunction in Myalgic Encephalomyelitis/Chronic Fatigue Syndrome Not Due to Anti-mitochondrial Antibodies},
  journal  = {Frontiers in Medicine},
  year     = {2020},
  volume   = {7},
  pages    = {108},
  doi      = {10.3389/fmed.2020.00108},
  pmid     = {32296708},
  pmcid    = {PMC7136523},
  keywords = {ME/CFS, anti-mitochondrial antibody, AMA, anti-PDC, anti-cardiolipin, metabolic dysfunction, null finding, primary biliary cholangitis, PBC},
  note     = {Cross-sectional study; 161 ME/CFS patients across 3 cohorts + controls (44 healthy donors, 15 PBC, 14 fibromyalgia, 29 MS). Antibodies tested: anti-PDC (pyruvate dehydrogenase complex), general AMA (inner/outer mitochondrial membrane by IIF), anti-cardiolipin (IgG/IgM/IgA). Results: only 1/161 ME/CFS patients positive for anti-PDC (vs.\ 15/15 PBC patients). General AMA negative in ME/CFS cohort. Anti-cardiolipin not significantly different from healthy donors. CRITICAL CAVEAT: anti-ANT was NOT specifically tested in this study. The study tests general inner mitochondrial membrane AMA by IIF, which may not detect ANT-specific antibodies with sufficient sensitivity. Conclusion: metabolic dysfunction in ME/CFS is not explained by the anti-mitochondrial autoantibodies tested. G28 gap remains open because this paper did not use ANT-specific ELISA. Limitations: anti-ANT not tested with isoform-specific assay; IIF may miss low-titre ANT-specific antibodies.},
  certainty = {0.70},
  research_stream = {ant-autoantibodies}
}

@article{GermainEtAl2025,
  author   = {Germain, Arnaud and Jaycox, Jillian R. and Emig, Christopher J. and Ring, Aaron M. and Hanson, Maureen R.},
  title    = {An In-Depth Exploration of the Autoantibody Immune Profile in {ME/CFS} Using Novel Antigen Profiling Techniques},
  journal  = {International Journal of Molecular Sciences},
  year     = {2025},
  volume   = {26},
  number   = {6},
  pages    = {2799},
  doi      = {10.3390/ijms26062799},
  pmid     = {40141440},
  pmcid    = {PMC11943395},
  keywords = {ME/CFS, autoantibody, proteome array, REAP, GPCR, beta-adrenergic, antigen profiling, Luminex, null finding},
  note     = {Comprehensive autoantibody profiling; n=172 unique participants (up to 95 ME/CFS, 69 controls). Platforms: (1) Oncimmune/Augmenta Luminex panel covering 1,134 autoantibodies; (2) REAP covering 6,183 extracellular human proteins + 225 viral antigens. Results: no significant differences in any of 1,134 autoantibody reactivities between ME/CFS patients and controls. No elevation in beta2-adrenergic, alpha1A-adrenergic, or muscarinic receptor antibodies (contradicting Loebel 2016). Elevated herpesvirus antigen reactivity (EBV gp42, HSV1 gL) in ME/CFS. CRITICAL CAVEAT: anti-ANT was NOT specifically measured; REAP platform covers extracellular antigens only, not intramitochondrial proteins like ANT. This is the most comprehensive null finding for GPCR autoantibodies in ME/CFS to date. Limitations: REAP restricted to extracellular proteome; intramitochondrial targets (ANT, PDC) excluded by platform design; cannot address G28 directly.},
  certainty = {0.65},
  research_stream = {ant-autoantibodies}
}

@article{WohlrabEtAl2025,
  author   = {Wohlrab, Felix and Eltity, Mailam and Ufer, Friederike and Paul, Friedemann and Scheibenbogen, Carmen and Bellmann-Strobl, Judith},
