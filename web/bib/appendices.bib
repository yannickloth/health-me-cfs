@article{SchultheissBolte1985,
  author   = {Schultheiss, Heinz-Peter and Bolte, Hans-Dieter},
  title    = {Immunological analysis of auto-antibodies against the adenine nucleotide translocator in dilated cardiomyopathy},
  journal  = {Journal of Molecular and Cellular Cardiology},
  year     = {1985},
  volume   = {17},
  number   = {6},
  pages    = {603--617},
  doi      = {10.1016/S0022-2828(85)80029-8},
  pmid     = {2991541},
  keywords = {adenine nucleotide translocase, ANT, autoantibody, dilated cardiomyopathy, ADP/ATP carrier, ELISA, mitochondria, cardiac},
  note     = {Landmark study establishing ANT as cardiac autoantigen in dilated cardiomyopathy (DCM). n=18 histologically confirmed DCM patients. 17/18 (94\%) showed significant binding to isolated ANT; no binding in coronary heart disease, alcoholic heart disease, or healthy donors. Organ-specific antigenic determinants confirmed by crossed immunoelectrophoresis and immunoadsorption. Close correlation between antibody titre and hemodynamic function. Functionally active antibodies decreased ADP/ATP exchange rate from cardiac mitochondria. First demonstration that anti-ANT autoimmunity has functional energy-metabolism consequences. Limitations: small sample (n=18); single uncontrolled study; 94\% prevalence was not replicated at this magnitude in later studies.},
  certainty = {0.60},
  research_stream = {ant-autoantibodies}
}

@article{SchulzeEtAl1999,
  author   = {Schulze, Karsten and Witzenbichler, Bernhard and Christmann, Claudia and Schultheiss, Heinz-Peter},
  title    = {Disturbance of myocardial energy metabolism in experimental virus myocarditis by antibodies against the adenine nucleotide translocator},
  journal  = {Cardiovascular Research},
  year     = {1999},
  volume   = {44},
  number   = {1},
  pages    = {91--100},
  doi      = {10.1016/S0008-6363(99)00204-7},
  pmid     = {10615393},
  keywords = {adenine nucleotide translocase, ANT, autoantibody, myocarditis, Coxsackie B3, virus, energy metabolism, ATP trapping, cardiac},
  note     = {Animal model study (A.SW/SnJ mice, Coxsackie B3 myocarditis). Anti-ANT antibodies detected in 14/19 infected animals by Western blot. Hearts with detectable antibodies showed: cytosolic ATP/ADP ratio decreased from 136+/-20 to 59+/-18 (55\% reduction); mitochondrial ATP/ADP ratio elevated from 1.1+/-0.3 to 4.2+/-1.0 (fourfold increase), demonstrating ATP trapping in the mitochondrial matrix. Reduced left ventricular pressure, rate-pressure product, and oxygen consumption (all p<0.05). This is the strongest direct evidence that anti-ANT antibodies functionally impair ATP export across the inner mitochondrial membrane, causing the trapping mechanism hypothesised in G28. Limitations: animal model, not human; myocarditis-induced antibodies, not spontaneous autoimmunity; small n.},
  certainty = {0.65},
  research_stream = {ant-autoantibodies}
}

@article{TakemotoEtAl1993,
  author   = {Takemoto, Masao and Kusachi, Shozo and Urabe, Naoya and Inoue, Koichi and Tsuji, Takao},
  title    = {Auto-antibody against adenine nucleotide translocator in dilated cardiomyopathy and myocarditis: incidence and relation to cardiac function and morphology},
  journal  = {Japanese Circulation Journal},
  year     = {1993},
