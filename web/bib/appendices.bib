@article{LugoHuitron2013quinolinic,
  author = {Lugo-Huitr\'on, Rafael and Ugalde Mu\~niz, Perla and Pineda, Benjam\'in and Pedraza-Chaverr\'i, Jos\'e and R\'ios, Camilo and P\'erez-de la Cruz, Ver\'onica},
