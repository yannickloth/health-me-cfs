  year    = {2014},
  volume  = {43},
  number  = {4},
  pages   = {1272--1283},
  doi     = {10.1093/ije/dyu115},
  pmid    = {24881045},
  keywords = {blinding, bias, patient-reported outcomes, RCT methodology, unblinded trials, effect size},
  note    = {12 trials, n=3,869. Internal design: patients randomized to blinded vs. unblinded sub-studies within same trial. Unblinded patients exaggerated treatment effect by mean SMD 0.56 (95\% CI -0.71 to -0.41) for patient-reported outcomes. No exaggeration for observer-reported outcomes. Gold-standard methodology for quantifying patient blinding bias.}
}

