@article{Szabo2014H2Smito,
  author = {Szabo, Csaba and Ransy, Céline and Módis, Katalin and Andriamihaja, Miadana and Murghes, Béla and Coletta, Ciro and Olah, Gabor and Yanagi, Kazunori and Bouillaud, Frédéric},
