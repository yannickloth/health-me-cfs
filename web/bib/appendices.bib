}

@article{Csecs2022hypermobility,
  author   = {Csecs, Jenny L L and Iodice, Valeria and Rae, Charlotte L and Brooke, Anna and Simmons, Rosie and Quadt, Lisa and Savage, Ginny K and Dowell, Nicholas G and Prowse, Florence and Themelis, Konstantinos and Mathias, Christopher J and Critchley, Hugo D and Eccles, Jessica A},
