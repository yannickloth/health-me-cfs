@article{Kimura2012DNMT1review,
  author       = {Kimura, Masashi and Sasaki, Hiroyuki},
  title        = {An insight into the various regulatory mechanisms modulating human {DNA} methyltransferase 1 stability and function},
  journal      = {Epigenetics},
  year         = {2012},
  volume       = {7},
  number       = {7},
  pages        = {686--696},
  doi          = {10.4161/epi.20157},
  pmid         = {22647247},
  note         = {Comprehensive review of DNMT1 regulatory mechanisms including the allosteric binary switch: DNMT1 is processive on highly methylated substrates but becomes inactivated on poorly methylated or unmethylated sites. Documents MeCP2-DNMT1 interaction via TRD domain, UHRF1-dependent maintenance recruitment, and PCNA-enhanced processivity (~2-fold). Supports the concept of a methylation density threshold for maintenance fidelity. Certainty: 0.65 (well-cited review, mechanism well-established).},
