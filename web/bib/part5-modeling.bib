@article{Strom2017HP1phaseseparation,
  author       = {Strom, Amy R. and Emelyanov, Alexander V. and Mir, Mustafa and Fyodorov, Dmitry V. and Darzacq, Xavier and Karpen, Gary H.},
  title        = {Phase separation drives heterochromatin domain formation},
  journal      = {Nature},
  year         = {2017},
  volume       = {547},
  pages        = {241--245},
  doi          = {10.1038/nature22989},
  keywords     = {heterochromatin, phase separation, HP1a, liquid-liquid demixing, 3D genome, nucleation},
  note         = {Demonstrates that HP1a protein undergoes liquid-liquid phase separation in vitro and nucleates into foci with liquid properties during early heterochromatin domain formation in Drosophila embryos. Heterochromatin domains exhibit phase-separation dynamics: sensitivity to hydrophobic disruption, reduced probe diffusion, and inert probe exclusion at domain boundaries. Provides biophysical evidence for a nucleation threshold in heterochromatin assembly---domains form via phase separation and mature into structure with liquid and stable compartments. Supports the sigmoidal (not linear) functional form for B_strength = f(ProB methylation)---below a critical HP1 density, liquid domain nucleation fails. Certainty: 0.75 (Nature, two-lab independent, Drosophila + mammalian cell validation).},
  research_stream = {methylation-vector-model},
  certainty    = {0.75}
}

@article{Larson2017HP1droplet,
  author       = {Larson, Adam G. and Elnatan, Daniel and Keenen, Madeline M. and Trnka, Michael J. and Johnston, Jonathan B. and Burlingame, Alma L. and Agard, David A. and Redding, Sy and Narlikar, Geeta J.},
  title        = {Liquid droplet formation by {HP1α} suggests a role for phase separation in heterochromatin},
  journal      = {Nature},
  year         = {2017},
  volume       = {547},
  pages        = {236--240},
  doi          = {10.1038/nature22822},
  keywords     = {HP1α, phase separation, liquid droplet, heterochromatin, phosphorylation, DNA binding},
  note         = {Demonstrates that human HP1α protein forms phase-separated droplets. Phosphorylation or DNA binding promotes HP1α partitioning from soluble phase into droplets; specific ligands can promote or reverse this. Nucleosomes and DNA preferentially partition into HP1α droplets. HP1α phase-separation mutant forms fewer and smaller nuclear foci in mammalian cells. Establishes the concentration-dependent nucleation threshold: below a critical HP1α concentration, no droplets form. Companion paper to Strom 2017. Certainty: 0.75 (Nature, independent lab, human protein).},
  research_stream = {methylation-vector-model},
  certainty    = {0.75}
}

@article{Chayama2026BrainClearance,
  author       = {Chayama, Yuki and Rao, Narsimha R. and Perla, Dheeraj and
                  Bowers, Ian and Cho, Seung Eon and Das, Malabika and
                  Etemadi, Shabnam and Huang, Hui and Kim, Seul-Ki and
                  Lee, Won-Seok and Odoi, Wilfred and Roth, Sara M. and
                  Sadovsky, Igor and Schulz, Alexander M. and Shen, Yang and
                  Suzuki, Yumi and Tang, Bo and Truell, Megan and Wang, Zhe and
                  Yang, Anne C.},
  title        = {Physiological brain clearance architecture revealed by
                  neuronal protein tracing},
  journal      = {Cell},
  year         = {2026},
  volume       = {189},
  pages        = {1--19},
  doi          = {10.1016/j.cell.2026.04.048},
  url          = {https://doi.org/10.1016/j.cell.2026.04.048},
  keywords     = {brain clearance, glymphatic system, neuronal protein tracing,
                  Syn-ZsG, skull border compartment, meningeal lymphatics,
                  neuroinflammation, blood-brain barrier, waste disposal},
  research_stream = {brain-clearance-architecture},
  certainty    = {0.85},
  note         = {Novel genetic tracing system (Syn-ZsG) revealed distinct brain
                  protein clearance routes from CSF tracers: primarily dura,
                  skull, nasal cavity with minimal drainage to cervical lymph
                  nodes. Demonstrated compartmentalized clearance following
                  nearest-exit principle. Skull-resident B cells sample neuronal
                  antigens and drive tolerogenic immune responses. Acute LPS
                  inflammation shunts proteins into blood via vascular leakage.
                  Amyloid pathology (5XFAD) causes parenchymal retention and
                  border exit obstruction. Animal model; human translation
                  requires validation.}
}

