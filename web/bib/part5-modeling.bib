@article{ChalderMoreau2026ptprn2,
  author       = {Chalder, Lynda and Elremaly, Wesam and Li, Dawei and
                  Fang, Yanjia and Caraus, Ion and Leveau, Charles and
                  Elbakry, Mohamed and Franco, Alexandre and Godbout, Cecile
                  and Di Tomasso, Giulia and Nepotchatykh, Evguenia and
                  Rostami-Afshari, Bita and Gimenez, Marthe and Moreau, Alain},
  title        = {{PTPRN2} hypomethylation and {PHB2}-associated {miR-153-3p}
                  maturation define dual epigenetic features linked to symptom
                  variability in myalgic encephalomyelitis},
  journal      = {Journal of Translational Medicine},
  year         = {2026},
  doi          = {10.1186/s12967-026-08162-6},
  url          = {https://doi.org/10.1186/s12967-026-08162-6},
  keywords     = {ME/CFS, epigenetics, DNA methylation, PTPRN2, miR-153-3p,
                  PHB2, brain fog, cognitive symptoms, epigenetics-mecfs},
  research_stream = {epigenetics-mecfs},
  certainty    = {0.47},
  note         = {EWAS in saliva (Illumina EPIC ~850k CpG sites);
                  n=54 ME/CFS vs 21 sedentary controls (University of Montreal group).
                  Primary finding: PTPRN2 hypomethylation survives multiple-testing
                  correction; enables patient subgrouping by epigenetic profile.
                  PTPRN2 hypomethylation associated with brain fog / cognitive
                  difficulties; respiratory symptoms association in males only
                  (sex-stratified, exploratory). Secondary finding: reduced
                  circulating miR-153-3p in patient blood; lower levels correlate
                  with poorer delayed memory recognition. PHB2 proposed to impair
                  miR-153-3p maturation post-transcriptionally (cytoplasmic
                  mechanism). Proposed multi-level axis: PTPRN2 epigenetic
                  modification -> reduced miR-153-3p (modulated by PHB2) ->
                  cognitive/respiratory symptoms. LIMITATIONS: cross-sectional
                  design; small n; saliva proxy (not blood/brain); associations
                  only, no causal proof; sex-stratified subanalyses exploratory.}
}

