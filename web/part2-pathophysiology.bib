@article{Moneghetti2018,
  author = {Moneghetti, Kegan J and Skhiri, Mounir and Contrepois, Kévin and Bhatt, Ami S and Tuzson, Elaine and Montoya, Jose G and Wheeler, Matthew T and Froelicher, Victor and Snyder, Michael P and Ashley, Euan A and Haddad, François},
  title = {Value of Circulating Cytokine Profiling During Submaximal Exercise Testing in Myalgic Encephalomyelitis/Chronic Fatigue Syndrome},
  journal = {Scientific Reports},
  year = {2018},
  volume = {8},
  number = {1},
  pages = {2779},
  doi = {10.1038/s41598-018-20941-w},
  pmid = {29426834},
  keywords = {ME/CFS, cytokines, exercise, post-exertional malaise, IL-1beta, IFN-alpha, CXCL1, CD40L, biomarkers, PEM},
  note = {n=24 ME/CFS vs. n=24 sedentary controls; submaximal CPET with multiplex cytokine profiling. Cytokine profiles 18 hours post-exercise most discriminatory. Key post-exercise markers: IL-1beta, IFN-alpha, CXCL1, CD40L. Demonstrates PEM-associated cytokine surge: IL-1beta and IFN-alpha specifically elevated post-exercise in ME/CFS but not controls. Stanford/Montoya group.}
}

@article{Corbitt2019,
  author = {Corbitt, Matthew and Eaton-Fitch, Natalie and Staines, Donald and Cabanas, Hélène and Marshall-Gradisnik, Sonya},
  title = {A systematic review of cytokines in chronic fatigue syndrome/myalgic encephalomyelitis/systemic exertion intolerance disease ({CFS/ME/SEID})},
  journal = {BMC Neurology},
  year = {2019},
  volume = {19},
  pages = {207},
  doi = {10.1186/s12883-019-1433-0},
  pmid = {31445522},
  keywords = {ME/CFS, CFS, SEID, cytokines, systematic review, biomarkers, immune},
  note = {Systematic review of 15 case-control studies (screened 16,702 publications). Conclusion: cytokine findings are inconclusive for diagnostic use due to high heterogeneity across studies. No universal cytokine signature established. Supports cautious language when describing ME/CFS cytokine elevations: findings are subset-specific and study-dependent.}
}

@article{RenzPolster2022,
  author = {Renz-Polster, Herbert and Tremblay, Marie-Eve and Bienzle, Dorothee and Fischer, Johannes E},
  title = {The Pathobiology of Myalgic Encephalomyelitis/Chronic Fatigue Syndrome: The Case for Neuroglial Failure},
  journal = {Frontiers in Cellular Neuroscience},
  year = {2022},
  volume = {16},
  pages = {888232},
  doi = {10.3389/fncel.2022.888232},
  pmid = {35614970},
  pmcid = {PMC9126235},
  url = {https://pubmed.ncbi.nlm.nih.gov/35614970/},
  keywords = {ME/CFS, microglia, astrocytes, oligodendrocytes, neuroglial failure, neuroinflammation, post-exertional malaise, Long COVID},
  note = {Comprehensive hypothesis paper arguing that impaired or pathologically reactive neuroglia (astrocytes, microglia, oligodendrocytes) represent the common pathobiological denominator in ME/CFS. Proposes neuroglial dysfunction explains PEM, reduced cerebral blood flow, and cognitive symptoms. Mechanistic detail on microglial reactivity states (M1/M2-like), complement activation, synaptic pruning dysregulation, and relevance to Long COVID. High-quality theoretical synthesis.}
}

@article{Gottschalk2022ATG13,
  author = {Gottschalk, Carl G and Peterson, Daniel and Knox, Konstance and Maynard, Mary and Whelan, Robert J},
  title = {Elevated {ATG13} in serum of patients with {ME/CFS} stimulates oxidative stress response in microglial cells via activation of receptor for advanced glycation end products ({RAGE})},
  journal = {Molecular and Cellular Neuroscience},
  year = {2022},
  volume = {120},
  pages = {103731},
  doi = {10.1016/j.mcn.2022.103731},
  pmid = {35487443},
  url = {https://pubmed.ncbi.nlm.nih.gov/35487443/},
  keywords = {ME/CFS, microglia, ATG13, autophagy, RAGE, oxidative stress, reactive oxygen species, neuroinflammation, serum},
  note = {Mechanistic study demonstrating ME/CFS patient serum stimulates reactive oxygen species (ROS) and nitric oxide production in human HMC3 microglial cells. ATG13 (autophagy-related protein 13), elevated in ME/CFS serum, activates RAGE receptors to trigger microglial oxidative stress; ATG13 neutralization substantially reduced this response. Provides direct ex vivo evidence for circulating factors driving microglial activation in ME/CFS.}
}

@article{Huang2020IDO,
  author = {Huang, Yu-Sheng and Ogbechi, Joy and Clanchy, Felix I. and Williams, Richard O. and Stone, Trevor W.},
  title = {{IDO} and Kynurenine Metabolites in Peripheral and {CNS} Disorders},
  journal = {Frontiers in Immunology},
  year = {2020},
  volume = {11},
  pages = {388},
  doi = {10.3389/fimmu.2020.00388},
  pmid = {32194572},
  pmcid = {PMC7076627},
  keywords = {IDO1, kynurenine pathway, quinolinic acid, kynurenic acid, neuroinflammation, tryptophan, CNS disorders, autoimmune},
  note = {Comprehensive review of IDO1/IDO2 activity in peripheral and CNS inflammatory disorders. Inflammatory cytokines (IFN-gamma, IL-1beta, TNF-alpha) induce IDO1, diverting tryptophan toward kynurenine metabolites. Quinolinic acid (NMDA agonist) drives excitotoxicity; kynurenic acid (NMDA antagonist) is neuroprotective. Covers role in Huntington's, Alzheimer's, multiple sclerosis, and autoimmune conditions. KMO inhibitors reduce quinolinic acid synthesis as a therapeutic strategy.}
}

@article{Pall2000Peroxynitrite,
  author = {Pall, Martin L},
  title = {Elevated, Sustained Peroxynitrite Levels as the Cause of Chronic Fatigue Syndrome},
  journal = {Medical Hypotheses},
  year = {2000},
  volume = {54},
  number = {1},
  pages = {115--125},
  doi = {10.1054/mehy.1998.0825},
  pmid = {10790736},
  keywords = {ME/CFS, peroxynitrite, nitric oxide, iNOS, oxidative stress, cytokines, vicious cycle, NO/ONOO cycle},
  note = {Original hypothesis paper proposing that infection-induced cytokines (IL-1beta, IL-6, TNF-alpha, IFN-gamma) induce iNOS, elevating nitric oxide which reacts with superoxide to form peroxynitrite. Multiple positive feedback loops proposed to sustain elevated peroxynitrite. Lowers HPA axis activity via glucocorticoid suppression. Links ME/CFS to autoimmune and oxidative disease patterns. Foundation for the NO/ONOO- vicious cycle model. Published in Medical Hypotheses -- low certainty, hypothesis only, but widely cited.}
}

@article{Tsai2022CoQ10fatigue,
  author  = {Tsai, I-Chen and Hsu, Chih-Wei and Chang, Chun-Hung and Tseng, Ping-Tao and Chang, Ke-Vin},
  title   = {Effectiveness of Coenzyme {Q10} Supplementation for Reducing Fatigue: A Systematic Review and Meta-Analysis of Randomized Controlled Trials},
  journal = {Frontiers in Pharmacology},
  year    = {2022},
  volume  = {13},
  pages   = {883251},
  doi     = {10.3389/fphar.2022.883251},
  pmid    = {36091835},
  pmcid   = {PMC9449413},
  url     = {https://pmc.ncbi.nlm.nih.gov/articles/PMC9449413/},
  keywords = {coenzyme Q10, fatigue, systematic review, meta-analysis, supplementation},
  research_stream = {q10-ubiquinol},
  certainty = {0.85},
  note = {Meta-analysis of 13 RCTs (n=1,126). CoQ10 significantly reduces fatigue (Hedges' g = -0.398, p = 0.001). Dose-response: coefficient = -0.0017 per mg (p < 0.001). Duration-response: coefficient = -0.0042 per day (p = 0.007). CoQ10-only formulations more effective than compounds. Safety: 1 adverse event in 602 participants (0.17%).}
}

