  note         = {Review article. mtDNA release via VDAC oligomerization macropores activates cGAS-STING innate immune pathway. NLRP3 inflammasome requires oxidized mtDNA. VDAC oligomerization inhibition mitigates inflammatory response. Implications for ALS and neurodegeneration. Experimental and Molecular Medicine (Nature Portfolio). ME/CFS relevance: provides mechanistic bridge between ROS-damaged mtDNA (from sympathetic overactivation) and innate immune activation sustained in ME/CFS.}
}

@article{Park2023AMPK,
  author       = {Park, Ji-Man and Lee, Da-Hye and Kim, Do-Hyung},
  title        = {Redefining the role of {AMPK} in autophagy and the energy stress response},
  journal      = {Nature Communications},
  year         = {2023},
  volume       = {14},
  number       = {1},
  pages        = {2994},
  doi          = {10.1038/s41467-023-38401-z},
  pmid         = {37225695},
  pmcid        = {PMC10209092},
  url          = {https://doi.org/10.1038/s41467-023-38401-z},
  keywords     = {AMPK, autophagy, ULK1, LKB1, energy stress, mitochondria, cell biology},
  certainty    = {0.65},
  research_stream = {ans-aging},
  note         = {Cell/mouse study. AMPK has dual role: inhibits ULK1 (suppresses autophagy during energy depletion via LKB1-AMPK axis) while protecting autophagy machinery from caspase degradation. Challenges prior model that AMPK promotes autophagy. Study used HCT116, HEK293T, MEFs, HeLa cells and mouse liver/muscle. Nature Communications. ME/CFS relevance: if PKA/cAMP (from SNS activation) inhibits AMPK, this cascades to blocked autophagy — mitochondrial quality control impaired, consistent with ME/CFS mitochondrial dysfunction.}
}

@article{Rajeevan2018telomere,
  author       = {Rajeevan, Mangalathu S. and Murray, Janna and Oakley, Lisa and Lin, Jin-Mann S. and Unger, Elizabeth R.},
  title        = {Association of chronic fatigue syndrome with premature telomere attrition},
  journal      = {Journal of Translational Medicine},
  year         = {2018},
  volume       = {16},
  number       = {1},
  pages        = {44},
  doi          = {10.1186/s12967-018-1414-x},
  pmid         = {29486769},
  url          = {https://doi.org/10.1186/s12967-018-1414-x},
  keywords     = {ME/CFS, telomere, accelerated aging, biological age, epigenetics, sex differences},
  certainty    = {0.60},
  research_stream = {ans-aging},
  note         = {Cross-sectional study; n=639 (64 CFS, 77 CFS-X, 302 ISF, 196 controls). Telomere length shorter by 254-957 bp in CFS vs controls; equivalent to 4-20.5 years additional biological aging. Effect largest in females under 45. J Translational Medicine. ME/CFS relevance: provides direct accelerated-aging evidence in ME/CFS, consistent with ANS-driven aging hallmarks framework. Limitations: cross-sectional; 1994 Fukuda criteria; causality unclear.}
}

@article{Luo2025MECFSimmunophysiology,
  author       = {Luo, Yingzhe and Xu, Huimin and Xiong, Shaoquan and Ke, Jianlong},
