  note    = {66 Long COVID patients vs 29 healthy controls. VWF 2.6-fold elevated, platelet factor 4 3.5-fold elevated, plasma kallikrein 4.4-fold decreased. 27 distinct immunoglobulin variants found in Long COVID microclots absent from controls. Documents how microclots obstruct capillaries limiting RBC passage and reducing O2/CO2 exchange.},
  keywords = {Long COVID, fibrin, microclots, proteomics, coagulation, fibrinolysis, VWF, platelet factor 4, capillary obstruction}
}

@article{Flaskamp2022endothelial,
  author  = {Flaskamp, Lena and Roubal, Clemens and Uddin, Shahab and Sotzny, Franziska and Kedor, Claudia and Bauer, Sandra and Scheibenbogen, Carmen and Seifert, Martin},
  title   = {Serum of {Post-COVID-19 Syndrome} Patients with or without {ME/CFS} Differentially Affects Endothelial Cell Function {In Vitro}},
  journal = {Cells},
  year    = {2022},
  volume  = {11},
  number  = {15},
  pages   = {2376},
  doi     = {10.3390/cells11152376},
