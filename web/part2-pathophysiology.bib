@article{GrauRBC2024longcovid,
  author  = {Grau, Marijke and Presche, Anna and Kr{\"u}ger, Anna-Lena and Bloch, Wilhelm and Haiduk, Birgit},
  title   = {Red Blood Cell Morphology Is Associated with Altered Hemorheological Properties and Fatigue in Patients with Long {COVID}},
  journal = {Biology (Basel)},
  year    = {2024},
  volume  = {13},
  number  = {11},
  pages   = {948},
  doi     = {10.3390/biology13110948},
  pmid    = {39596903},
  note    = {Long COVID patients showed 20.8 ± 10.7\% morphologically abnormal RBCs vs 2.9 ± 1.5\% in controls; echinocytes/acanthocytes 16.0 ± 9.9\% vs 2.3 ± 1.4\%. Aggregation index substantially elevated. Samples taken at average 42 weeks post-infection — beyond the 120-day RBC lifespan — indicating ongoing generation of abnormal RBCs, not survival of initially damaged cells. Moderate negative correlation between RBC morphological abnormalities and fatigue severity (r = −0.5131, p = 0.0061).},
  keywords = {Long COVID, red blood cells, RBC morphology, hemorheology, fatigue, echinocytes, acanthocytes, deformability}
}

@article{GuoRBC2025microfluidic,
  author  = {Guo, Yuanbin and Zhou, Sitong and Ren, Shujie and Liu, Xin and Nemat-Gorgani, Mohsen and Gresser, Michael J. and Davis, Ronald W. and Wan, Jiandi},
  title   = {Microfluidic Assessment of {PO2}-Regulated {RBC} Capillary Velocity in {ME/CFS}},
  journal = {Blood: Red Cells \& Iron},
  year    = {2025},
  volume  = {1},
  number  = {3},
  pages   = {100019},
  doi     = {10.1182/bloodrci.2024.100019},
  note    = {Using microfluidic capillaries (5.05 μm × 5.94 μm, mimicking real capillaries) under reduced PO2 (0–34 mmHg), ME/CFS patient RBCs showed significantly compromised capillary velocity compared to healthy controls. Hypoxia-sensing mechanism of RBCs — normally triggering vasodilation and increased flow — is impaired in ME/CFS. Provides strong evidence for a cell-autonomous defect in oxygen delivery independent of tissue mitochondrial state.},
  keywords = {ME/CFS, red blood cells, capillary, microfluidics, oxygen, PO2, deformability, hypoxia sensing}
}

@article{RogersRBC2024covidoxygen,
  author  = {Rogers, Steven C. and Brummet, Marguerite and Safari, Zahra and Wang, Qilong and Rowden, Thomas and Boyer, Tyler and Doctor, Allan},
  title   = {{COVID-19} impairs oxygen delivery by altering red blood cell hematological, hemorheological, and oxygen transport properties},
  journal = {Frontiers in Physiology},
  year    = {2024},
  volume  = {15},
  pages   = {1320697},
  doi     = {10.3389/fphys.2023.1320697},
  pmcid   = {PMC10791868},
  note    = {Hospitalized COVID-19 patients showed significantly reduced blood O2 content, with three rheological defects: reduced RBC deformability, accelerated aggregation kinetics, and loss of osmotic volume regulation. Homeostatic compensation would require cardiac output to increase by ~135\% to maintain equivalent oxygen delivery. Blood type O patients showed greater deformability impairment than blood type A.},
  keywords = {COVID-19, red blood cells, oxygen transport, hemorheology, deformability, cardiac output, blood type}
}

@article{ScheibenbogenWirth2024sarcopenia,
  author  = {Scheibenbogen, Carmen and Wirth, Klaus J.},
  title   = {Key Pathophysiological Role of Skeletal Muscle Disturbance in Post {COVID} and {Myalgic Encephalomyelitis/Chronic Fatigue Syndrome (ME/CFS)}: Accumulated Evidence},
  journal = {Journal of Cachexia, Sarcopenia and Muscle},
  year    = {2024},
  volume  = {16},
  number  = {1},
  pages   = {e13669},
  doi     = {10.1002/jcsm.13669},
  pmcid   = {PMC11671797},
  note    = {Comprehensive review: early PCS is dominated by microvascular disturbance (microclots, inflammatory capillary changes); mitochondrial damage appears later and selectively in patients who develop ME/CFS. Proposed transition mechanism: capillary hypoperfusion → ischemia/reperfusion → proton production → sodium-proton exchange → intracellular Na+ excess → NCX reversal → mitochondrial Ca2+ toxicity → mitochondrial damage. Low ATP and ROS then inhibit Na+/K+-ATPase creating a self-perpetuating cycle. Provides temporal evidence supporting vascular-primary causation.},
  keywords = {ME/CFS, post-COVID, skeletal muscle, microvascular, mitochondria, calcium toxicity, sodium, capillary, PEM, pathophysiology}
}

@article{NunesPlatelets2022mecfs,
  author  = {Nunes, Jo{\~a}o M. and Kruger, Arneaux and Proal, Amy and Kell, Douglas B. and Pretorius, Etheresia},
  title   = {The Occurrence of Hyperactivated Platelets and Fibrinaloid Microclots in {Myalgic Encephalomyelitis/Chronic Fatigue Syndrome (ME/CFS)}},
