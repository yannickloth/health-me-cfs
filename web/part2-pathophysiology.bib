@article{KrugerMicroclot2022longcovid,
  author  = {Kruger, Arneaux and Vlok, Mare and Turner, Simone and Venter, Christiaan and Laubscher, Gert J. and Kell, Douglas B. and Pretorius, Etheresia},
  title   = {Proteomics of fibrin amyloid microclots in long {COVID}/post-acute sequelae of {COVID-19 (PASC)} shows many entrapped pro-inflammatory molecules that may also contribute to a failed fibrinolytic system},
