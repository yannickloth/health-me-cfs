  pmid    = {39014464},
  note    = {Plasma proteomics: 15 ME/CFS vs 10 controls. 24 proteins significantly increased in ME/CFS. Key: thrombospondin-1 (THBS1), platelet factor 4 (PF4), P-selectin elevated; Protein S (endogenous anticoagulant) decreased. Complement components substantially reduced. Prothrombotic, pro-coagulant, endothelially dysfunctional plasma state ongoing in ME/CFS — not a residual acute-phase artifact.},
  keywords = {ME/CFS, proteomics, coagulation, endothelial dysfunction, complement, thrombospondin, THBS1, plasma}
