  volume  = {15},
  number  = {8},
  pages   = {931},
  doi     = {10.3390/ph15080931},
  pmid    = {36015078},
  note    = {First paper to document fibrinaloid microclots in ME/CFS (not just Long COVID). Microclot area in ME/CFS plasma more than 10-fold greater than healthy controls. Platelet hyperactivation confirmed: ME/CFS mean spreading score 2.72 ± 1.24 vs 1.00 for healthy controls (PAC-1 and CD62P markers). Establishes shared haematological pathology between ME/CFS and Long COVID.},
  keywords = {ME/CFS, fibrinaloid microclots, platelet hyperactivation, coagulation, Long COVID, haematology}
}

@article{NunesBloodReviews2023mecfs,
  author  = {Nunes, Jo{\~a}o M. and Kell, Douglas B. and Pretorius, Etheresia},
  title   = {Cardiovascular and haematological pathology in {Myalgic Encephalomyelitis/Chronic Fatigue Syndrome (ME/CFS)}: A role for viruses},
