  note         = {Perspective review (no original data). Examines how age-related ANS imbalance (sympathetic dominance, parasympathetic decline) impairs the cholinergic anti-inflammatory pathway (CAP) and HPA axis. HRV inversely correlates with IL-6 and CRP. Decreased vagal output associated with endothelial dysfunction and macrophage overactivation. GeroScience (high-impact aging journal). Directly supports Errico2025ANSaging framework with mechanistic detail. Limitations: theoretical; limited sex-specific data; no optimal HRV threshold defined for elderly.}
}

@article{Balasubramanian2021glialSenescence,
  author       = {Balasubramanian, Priya and Branen, Lyndee and Sivasubramanian, Mahesh Kumar and Monteiro, Raisa and Subramanian, Madhan},
  title        = {Aging is associated with glial senescence in the brainstem --- implications for age-related sympathetic overactivity},
  journal      = {Aging (Albany NY)},
  year         = {2021},
  volume       = {13},
  number       = {10},
  pages        = {13460--13473},
  doi          = {10.18632/aging.203111},
  url          = {https://doi.org/10.18632/aging.203111},
  keywords     = {glial senescence, brainstem, sympathetic, p16, NF-kB, SASP, norepinephrine, aging, cardiovascular},
  certainty    = {0.50},
  research_stream = {ans-aging},
  note         = {Mouse study (n=4-6/group young vs aged). Aged brainstem showed 32-fold increase p16 mRNA (senescence marker); glial cells 90-fold increase. Elevated NF-kB activity in aged brainstem. Serum norepinephrine elevated in aged animals. Multiple SASP cytokines elevated (IL-1beta, MCP1, TNFalpha). Limitations: associative only; cannot establish causality; mouse model; small n; no neuronal analysis. Provides mechanistic link: brainstem glial senescence may drive age-related sympathetic overactivity — relevant to ME/CFS brainstem findings.}
}

@article{Kim2023cGASSTING,
  author       = {Kim, Jeonghan and Kim, Ho-Shik and Chung, Jay H.},
  title        = {Molecular mechanisms of mitochondrial {DNA} release and activation of the {cGAS-STING} pathway},
  journal      = {Experimental \& Molecular Medicine},
  year         = {2023},
  volume       = {55},
  number       = {3},
  pages        = {510--519},
  doi          = {10.1038/s12276-023-00965-7},
  pmid         = {36964253},
  pmcid        = {PMC10037406},
  url          = {https://doi.org/10.1038/s12276-023-00965-7},
  keywords     = {mtDNA, cGAS, STING, innate immunity, NLRP3, mitochondria, VDAC, oxidative stress, inflammation, aging},
  certainty    = {0.65},
