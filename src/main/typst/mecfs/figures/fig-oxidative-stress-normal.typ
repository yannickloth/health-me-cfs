// Figure: Normal Oxidative Stress Balance
// Healthy balance between ROS production and antioxidant defense
// Original: figures/fig-oxidative-stress-normal.tex

#import "@preview/cetz:0.3.4": canvas, draw

// --- colour palette (normal/healthy green tones) ---
#let node-fill     = rgb("#e0ffe0")
#let node-stroke   = rgb("#338844")
#let dark-fill     = rgb("#c8f0c8")
#let output-fill   = rgb("#b0e8b0")
#let output-stroke = rgb("#2a6e3a")
#let note-colour   = rgb("#4a8855")
#let key-fill      = rgb("#f0fff0")

// --- helpers ---
#let node-width = 4.5
#let node-half  = node-width / 2

#let process-node(x, y, title, subtitle) = {
  draw.rect(
    (x - node-half, y - 0.6), (x + node-half, y + 0.6),
    fill: node-fill, stroke: node-stroke + 1.5pt, radius: 0.2,
  )
  draw.content((x, y + 0.15), text(weight: "bold", size: 9pt, title))
  draw.content((x, y - 0.25), text(size: 7.5pt, subtitle))
}

#let balanced-node(y, title, subtitle, extra) = {
  let w = 5.0 / 2
  draw.rect(
    (-w, y - 0.75), (w, y + 0.75),
    fill: output-fill, stroke: output-stroke + 2pt, radius: 0.2,
  )
  draw.content((0, y + 0.3), text(weight: "bold", size: 9.5pt, title))
  draw.content((0, y - 0.1), text(size: 7.5pt, style: "italic", subtitle))
  draw.content((0, y - 0.45), text(size: 7pt, extra))
}

#let output-node(y, title, subtitle) = {
  let w = 5.0 / 2
  draw.rect(
    (-w, y - 0.6), (w, y + 0.6),
    fill: dark-fill, stroke: node-stroke + 1.5pt, radius: 0.2,
  )
  draw.content((0, y + 0.15), text(weight: "bold", size: 9pt, title))
  draw.content((0, y - 0.25), text(size: 7.5pt, subtitle))
}

#figure(
  canvas(length: 1cm, {
    import draw: *

    // --- Title ---
    content((0, 0), text(size: 13pt, weight: "bold", fill: node-stroke,
      [Normal Oxidative Stress Balance]))

    // --- ROS Production (left) ---
    let y-top = -2.5
    let x-left = -3.5
    let x-right = 3.5
    process-node(x-left, y-top, "ROS Production", [\<2% ETC leakage, normal byproduct])

    // --- Antioxidant Defense (right) ---
    process-node(x-right, y-top, "Antioxidant Defense", "SOD, Catalase, GPx, Glutathione")

    // --- Balance point ---
    let y-bal = -5.0
    balanced-node(y-bal, "ROS BALANCE", "Equilibrium achieved", "Production = Neutralization")

    // Arrows from both sources to balance
    line((x-left, y-top - 0.6), (0, y-bal + 0.75),
      stroke: node-stroke + 1.5pt, mark: (end: ">"))
    line((x-right, y-top - 0.6), (0, y-bal + 0.75),
      stroke: node-stroke + 1.5pt, mark: (end: ">"))

    // --- Minor Damage / Repair ---
    let y-rep = -7.0
    output-node(y-rep, "Minor Damage", "Rapid repair, maintained function")
    line((0, y-bal - 0.75), (0, y-rep + 0.6),
      stroke: node-stroke + 1.5pt, mark: (end: ">"))

    // --- Cellular Homeostasis ---
    let y-hom = -9.0
    output-node(y-hom, "Cellular Homeostasis", "Healthy membranes, proteins and DNA protected")
    line((0, y-rep - 0.6), (0, y-hom + 0.6),
      stroke: node-stroke + 1.5pt, mark: (end: ">"))

    // --- Key antioxidant systems box ---
    let y-key = -11.5
    rect((-5.5, y-key - 1.2), (5.5, y-key + 0.8),
      fill: key-fill, stroke: node-stroke + 1pt, radius: 0.2)
    content((0, y-key - 0.1), box(width: 10cm, text(size: 7.5pt, [
      #text(weight: "bold")[Key antioxidant systems:]\
      #sym.bullet #text(weight: "bold")[SOD] (superoxide dismutase): Converts superoxide to H#sub[2]O#sub[2]\
      #sym.bullet #text(weight: "bold")[Catalase]: Converts H#sub[2]O#sub[2] to water\
      #sym.bullet #text(weight: "bold")[Glutathione (GSH)]: Master antioxidant, regenerated by GPx\
      #sym.bullet #text(weight: "bold")[Vitamins E/C, CoQ10]: Lipid protection and ROS scavenging
    ])))
  }),
  caption: [Normal oxidative stress homeostasis with balanced ROS production and neutralization.],
) <fig:oxidative-stress-normal>
