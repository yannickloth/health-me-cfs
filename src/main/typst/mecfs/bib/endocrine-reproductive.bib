  keywords     = {allopregnanolone, GABA-A, biphasic effect, PMDD, progesterone,
                  adverse effects, progesterone-mecfs},
  research_stream = {progesterone-mecfs},
  certainty    = {0.45},
  note         = {Describes biphasic dose-response of allopregnanolone at GABA-A
                  receptors: low concentrations (luteal-phase equivalent) produce
                  paradoxical anxiogenic / negative mood effects via altered receptor
                  subunit composition; higher concentrations produce sedation and
                  anxiolysis. Women with PMDD show altered GABA-A sensitivity.
                  Critical safety signal for ME/CFS hypothesis: low-dose oral
                  progesterone producing luteal-range allopregnanolone may worsen
                  mood/anxiety in sensitive patients. Dose titration essential.}
}

