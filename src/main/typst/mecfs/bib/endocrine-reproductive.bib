  keywords     = {ME/CFS, fibromyalgia, progesterone, cortisol, HPG axis,
                  null result, progesterone-mecfs},
  research_stream = {progesterone-mecfs},
  certainty    = {0.55},
  note         = {Cross-sectional study (n=176: 46 controls, 68 fibromyalgia, 62 CFS).
                  NULL RESULT: no significant differences in FSH, LH, estradiol, or
                  progesterone between CFS/fibromyalgia patients and healthy controls.
                  Cortisol significantly lower in patient groups. Depression correlated
                  with reduced cortisol but not with HPG hormones. Interpretation:
                  ME/CFS is not characterised by abnormal circulating progesterone
                  levels; the therapeutic hypothesis is not based on correcting a
                  deficiency but on pharmacologically elevated progesterone producing
                  immunomodulatory and neurosteroid effects above baseline.}
}

