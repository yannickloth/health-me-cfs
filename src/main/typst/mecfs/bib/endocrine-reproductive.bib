@article{MeltzerBrody2018brexanolone,
  author       = {Meltzer-Brody, Samantha and Colquhoun, Howard and Riesenberg, Robert
                  and Epperson, C Neill and Deligiannidis, Kristina M and Rubinow, David R
                  and Li, Haihong and Sankoh, Abdul J and Clemson, Craig and Schacterle, Amy
                  and Jonas, Jeffrey and Kanes, Stephen J},
  title        = {Brexanolone injection in post-partum depression: two multicentre,
                  double-blind, randomised, placebo-controlled, phase 3 trials},
  journal      = {Lancet},
  year         = {2018},
  volume       = {392},
  number       = {10152},
  pages        = {1058--1070},
  doi          = {10.1016/S0140-6736(18)31551-4},
  pmid         = {30177236},
  url          = {https://doi.org/10.1016/S0140-6736(18)31551-4},
  keywords     = {brexanolone, allopregnanolone, GABA-A, postpartum depression,
                  neurosteroid, clinical trial, progesterone-mecfs},
  research_stream = {progesterone-mecfs},
  certainty    = {0.82},
  note         = {Pivotal phase 3 RCTs (n=246 combined) establishing brexanolone
                  (synthetic IV allopregnanolone) as first FDA-approved rapid-acting
                  treatment for PPD. Provides proof-of-concept for the allopregnanolone
                  route: GABA-A positive allosteric modulation produces clinically
                  meaningful antidepressant and presumably anti-inflammatory effects.
                  Mechanism is directly relevant to oral micronized progesterone hypothesis
                  in ME/CFS (progesterone → allopregnanolone → GABA-A potentiation).
                  IV administration limits direct translation to oral route.}
}

