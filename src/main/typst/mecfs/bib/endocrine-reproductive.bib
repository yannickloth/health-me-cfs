  keywords     = {ME/CFS, endometriosis, meta-analysis, systematic review,
                  comorbidity, women's health, odds ratio},
  research_stream = {pregnancy-reproductive-health},
  certainty    = {0.58},
  note         = {Systematic review and meta-analysis (PRISMA 2020); 13 studies
                  included (8 cross-sectional, 2 case-control, 3 cohort); sample
                  sizes 84 to 134,805; studies published 2002-2024. Main finding:
                  endometriosis associated with 2.79-fold higher odds of ME/CFS
                  (OR 2.52, 95\% CI 2.45-2.60). ME/CFS prevalence in endometriosis
                  patients: 17\%; endometriosis prevalence in ME/CFS patients: 13\%.
                  Limitations: predominantly cross-sectional designs; 54\% used
                  self-reported endometriosis diagnosis; extreme heterogeneity
                  I-squared >98\% for prevalence estimates; US-centric sample.}
}

