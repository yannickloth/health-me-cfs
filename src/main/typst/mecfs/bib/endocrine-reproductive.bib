  number       = {1--2},
  pages        = {91--99},
  doi          = {10.1016/j.jri.2009.01.004},
  pmid         = {19371956},
  url          = {https://doi.org/10.1016/j.jri.2009.01.004},
  keywords     = {PIBF, Th2, IL-4, IL-10, progesterone, immune shift,
                  progesterone-mecfs},
  research_stream = {progesterone-mecfs},
  certainty    = {0.55},
  note         = {In vitro study (n=72 women; 4 groups) demonstrating PIBF-mediated
                  Th1-to-Th2 cytokine shift: PIBF significantly increased IL-4, IL-6,
                  IL-10 in pregnancy-associated groups. Provides mechanistic evidence
                  that progesterone-driven PIBF production recapitulates the immune
                  shifts observed in pregnancy. Effect absent in non-pregnant controls,
                  raising question whether ME/CFS patients would show similar response.
                  In vitro limitation: systemic effects require in vivo confirmation.}
}

@article{Hierweger2019progesteroneT,
  author       = {Hierweger, Alexander M and Engler, Jan Broder and Friese, Manuel A
                  and Reichardt, Holger M and Lyck, Ruth and G{\"o}rtler, Ivonne
                  and Walcher, Susanne and Schumacher, Anne},
  title        = {Progesterone modulates the {T}-cell response via glucocorticoid
                  receptor-dependent pathways},
  journal      = {American Journal of Reproductive Immunology},
  year         = {2019},
  volume       = {81},
  number       = {4},
  pages        = {e13084},
  doi          = {10.1111/aji.13084},
  pmid         = {30604567},
  url          = {https://doi.org/10.1111/aji.13084},
  keywords     = {progesterone, Treg, glucocorticoid receptor, T-cell apoptosis,
                  immune tolerance, progesterone-mecfs},
  research_stream = {progesterone-mecfs},
  certainty    = {0.38},
  note         = {In vitro murine study. Progesterone and dexamethasone selectively
                  induced effector T-cell death while sparing regulatory T cells (Tregs),
                  resulting in Treg enrichment. Mechanism is GR-dependent (not PR): T
                  cells lacking GR but not PR were resistant. Pharmacological implication:
                  supraphysiological oral progesterone doses may cross-activate GR and
                  produce immunosuppression via selective effector T-cell apoptosis,
                  independent of PIBF pathway. Requires in vivo human validation.}
}

@article{AndreenBackstrom2006pharmacokinetics,
