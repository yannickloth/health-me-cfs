@article{Schacterle2004pregnancy,
  author       = {Schacterle, Richard S and Komaroff, Anthony L},
  title        = {A Comparison of Pregnancies That Occur Before and After the Onset
                  of Chronic Fatigue Syndrome},
  journal      = {Archives of Internal Medicine},
  year         = {2004},
  volume       = {164},
  number       = {4},
  pages        = {401--404},
  doi          = {10.1001/archinte.164.4.401},
  pmid         = {14980991},
  url          = {https://doi.org/10.1001/archinte.164.4.401},
  keywords     = {ME/CFS, pregnancy, spontaneous abortion, miscarriage, offspring,
                  developmental delay, retrospective survey},
  research_stream = {pregnancy-reproductive-health},
  certainty    = {0.42},
  note         = {Retrospective survey; n=86 women, 252 pregnancies (171 pre-onset,
                  75 post-onset). Key findings: spontaneous abortion rate 30\% after
                  CFS onset vs 8\% before (p<0.001); offspring developmental delays
                  21\% vs 8\% after vs before onset; 41\% no symptom change during
                  pregnancy, 30\% improved, 29\% worsened. Limitations: self-report,
                  no age-matched external control group, maternal age confound.
                  Foundational study in the field; unreplicated as of 2025.}
}

