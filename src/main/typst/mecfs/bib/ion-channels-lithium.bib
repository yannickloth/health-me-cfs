% --- Lansky et al. 2023: TRPV3 pentamer discovery ---

@article{Lansky2023trpv3pentamer,
  author   = {Lansky, Shifra and Betancourt, John Michael and Zhang, Jingying and Jiang, Yining and
              Kim, Elizabeth D and Paknejad, Navid and Nimigean, Crina M and Yuan, Peng and Scheuring, Simon},
  title    = {A pentameric {TRPV3} channel with a dilated pore},
  journal  = {Nature},
  year     = {2023},
  volume   = {621},
  number   = {7977},
  pages    = {206--214},
  doi      = {10.1038/s41586-023-06470-1},
  pmid     = {37648856},
  url      = {https://doi.org/10.1038/s41586-023-06470-1},
  keywords = {TRPV3, pentamer, tetramer, pore dilation, ion channel, structural biology, cryo-EM, HS-AFM},
  certainty = {0.80},
  research_stream = {trp-pentamer-vascular},
  note     = {High-speed AFM + cryo-EM. Discovers TRPV3 can form pentamers (not only canonical tetramers) in dynamic equilibrium via membrane diffusive protomer exchange. Pentamer shows ~2.4-fold enlarged pore at selectivity filter, subunit 18-degree hinge motion, and ~3-minute average lifetime. DPBA agonist significantly increases pentamer frequency. Explains the long-known pore-dilation phenomenon (increased large-cation permeability after prolonged activation). First demonstration of non-tetrameric stoichiometry in a TRP channel with functional consequence. Certainty: High for structural finding; implications for other TRP channels (TRPM3, TRPV1) in ME/CFS are speculative extrapolations.}
}

% --- Lansky et al. 2025: TRPV3 pentamer structural dynamics follow-up ---

@article{Lansky2025trpv3dynamics,
  author   = {Lansky, Shifra and Wang, Zhaokun and Clarke, Oliver B and Chipot, Christophe and Scheuring, Simon},
  title    = {Structural dynamics and permeability of the {TRPV3} pentamer},
  journal  = {Nature Communications},
  year     = {2025},
  volume   = {16},
  pages    = {4347},
  doi      = {10.1038/s41467-025-59798-9},
  pmid     = {40374654},
  url      = {https://doi.org/10.1038/s41467-025-59798-9},
  keywords = {TRPV3, pentamer, cryo-EM, molecular dynamics, pore permeability, large cations, domain-swapped},
  certainty = {0.78},
  research_stream = {trp-pentamer-vascular},
  note     = {Improved cryo-EM at 4.07 Å plus MD simulations. Pentamer has domain-swapped architecture, collapsed vanilloid binding site, selectivity filter 5.3-fold wider than closed tetramer, gate 7.3-fold wider. MD shows free passage of large cations (Tris+, NMDG+, 2-MAE+). Agonists (2-APB, camphor, propofol) destabilize TRPV3 tetramers and facilitate pentamer formation. Authors classify pentamer as a "hyper-activated state." Follow-up to Lansky 2023 from same group; provides the mechanistic underpinning of large-cation permeability in dilated state.}
}

