% --- Phan et al. 2020: TRPV1 throughout arterial circulation ---

@article{Phan2020trpv1arterial,
  author   = {Phan, Thieu X and Ton, Hoai T and Guly{\'a}s, Hajnalka and P{\'o}rszász, R{\'o}bert and
              T{\'o}th, Attila and Russo, Rebekah and Kay, Matthew W and Sahibzada, Niaz and Ahern, Gerard P},
  title    = {{TRPV1} expressed throughout the arterial circulation regulates vasoconstriction and blood pressure},
  journal  = {The Journal of Physiology},
