@article{LinanPonce2024RFandFibromyalgia,
  author    = {Liñán Ponce, Freddy and Leiva Goicochea, Juan and Sevilla Rodríguez, David and Hidalgo Bravo, Elmer and Obregón Atanacio, Ginna and others},
  title     = {Fibromyalgia with elevated rheumatoid factor is associated with poor therapeutic response but not with progression to rheumatoid arthritis. {Prospective} cohort study},
  journal   = {Reumatología Clínica (English Edition)},
  year      = {2024},
  volume    = {20},
  number    = {9},
  pages     = {476--482},
  doi       = {10.1016/j.reumae.2024.10.001},
  pmid      = {39455297},
  note      = {Prospective cohort: n=124 FM patients, 62 with high RF (>20 U/mL) vs 62 RF-negative (0-20 U/mL). RF+ FM: significantly poorer treatment response at 6 months (24/62 vs 45/62, p<0.001) and 12 months (20/62 vs 38/62, p<0.001). No difference in progression to RA (5 vs 4, ns). First study to demonstrate that RF positivity in FM is clinically meaningful (predicts treatment resistance) rather than merely coincidental. Relevance to ME/CFS: FM and ME/CFS share ~50-75% comorbidity; RF may similarly predict treatment resistance in ME/CFS. Certainty: 0.55.},
  keywords  = {fibromyalgia, rheumatoid factor, treatment response, RF, prospective cohort},
  research_stream = {rf-elevated-mecfs},
  certainty = {0.55}
}

