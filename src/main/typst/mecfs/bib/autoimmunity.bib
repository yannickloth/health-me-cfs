  note         = {n=34 Long COVID patients (UMC Utrecht / Amsterdam UMC; Eijkelkamp and den Dunnen groups). Pooled total IgG transferred to GFAP reporter mice. Induced pronounced persistent mechanical hypersensitivity. IgG from same patients 2 years later still induced symptoms — long-term autoantibody persistence. GFAP activation indicating astrocyte response and neuroinflammation. Independent replication of Santos Guedes 2026 Cell paper. Patient subgroups identified by GFAP/NFL/IFN-beta. Certainty: 0.65 (Cell Reports Medicine, direct replication, experimental design, n=34).},
  research_stream = {lc-autoantibodies-cell2026},
  certainty    = {0.65}
}

