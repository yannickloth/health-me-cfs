  doi = {10.1111/sji.70016},
  keywords = {EBV, Epstein-Barr virus, molecular mimicry, autoimmunity, infectious mononucleosis},
  note = {2025 review demonstrating that when EBV infection occurs during adolescence, it causes infectious mononucleosis in 35--50\% of cases. Shows that EBV nuclear antigen 1 (EBNA1)-mediated molecular mimicry of human autoantigens is a key mechanism by which EBV promotes autoimmunity. Documents three main pathways: molecular mimicry, bystander activation, and epitope spreading. Critical for understanding age-dependent EBV pathogenicity},
