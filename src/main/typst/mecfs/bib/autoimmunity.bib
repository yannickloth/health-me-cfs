  title        = {Risk factors for lichen sclerosus: A Finnish population-based case-control study},
  journal      = {British Journal of Dermatology},
  year         = {2024},
  volume       = {190},
  number       = {3},
  pages        = {678--686},
  doi          = {10.1093/bjd/ljae234},
  note         = {Large case-control study (n = 10,692). No significant association between fibromyalgia and LS (OR 0.85, 95% CI 0.61-1.18). LS associates selectively with cutaneous/mucosal autoimmunity (RA, T1DM, MS are null or protective). Important null result constraining ME/CFS-LS prevalence speculation. Certainty: 0.70 (large population study).},
  research_stream = {dermatology, lichen-sclerosus, autoimmunity},
  certainty    = {0.70}
}

