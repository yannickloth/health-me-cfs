@article{SchultheissBolte1985,
  author   = {Schultheiss, Heinz-Peter and Bolte, Hans-Dieter},
  title    = {Immunological analysis of auto-antibodies against the adenine nucleotide translocator in dilated cardiomyopathy},
  journal  = {Journal of Molecular and Cellular Cardiology},
  year     = {1985},
  volume   = {17},
  number   = {6},
  pages    = {603--617},
  doi      = {10.1016/S0022-2828(85)80029-8},
  pmid     = {2991541},
  keywords = {adenine nucleotide translocase, ANT, autoantibody, dilated cardiomyopathy, ADP/ATP carrier, ELISA, mitochondria, cardiac},
  note     = {Landmark study establishing ANT as cardiac autoantigen in dilated cardiomyopathy (DCM). n=18 histologically confirmed DCM patients. 17/18 (94\%) showed significant binding to isolated ANT; no binding in coronary heart disease, alcoholic heart disease, or healthy donors. Organ-specific antigenic determinants confirmed by crossed immunoelectrophoresis and immunoadsorption. Close correlation between antibody titre and hemodynamic function. Functionally active antibodies decreased ADP/ATP exchange rate from cardiac mitochondria. First demonstration that anti-ANT autoimmunity has functional energy-metabolism consequences. Limitations: small sample (n=18); single uncontrolled study; 94\% prevalence was not replicated at this magnitude in later studies.},
  certainty = {0.60},
  research_stream = {ant-autoantibodies}
}

@article{SchultheissReview1989,
