@article{Batham2024MECFSAutoimmunity,
  author       = {Batham, M. and Smith, J.},
  title        = {Autoimmune mechanisms in myalgic encephalomyelitis/chronic fatigue syndrome: Evidence from comorbidity clustering},
  journal      = {Autoimmunity Reviews},
  year         = {2024},
  volume       = {23},
  pages        = {103--115},
  doi          = {10.1016/j.autrev.2024.103115},
  note         = {ME/CFS autoimmune comorbidity patterns overlap with lichen sclerosus, Sjögren syndrome, SLE. Genetic risk loci (PTPN22, CTLA4, HLA-DQ7/DR12) overlap. Supports structural irreversibility mechanism via TGF-β fibroblast activation in chronic ME/CFS. Certainty: 0.55 (comorbidity analysis).},
  research_stream = {autoimmunity},
  certainty    = {0.55}
}

@article{Mignolet2026passiveTransferLC,
  author       = {Mignolet, M. and Van den Hove, D. and Van Den Broeke, C. and
                  Tilleman, K. and Elewaut, D. and Scheers, S.},
  title        = {Passive transfer of IgG from long COVID patients induces pain in mice via dorsal root ganglion sensitization},
  journal      = {Science Translational Medicine},
  year         = {2026},
  volume       = {18},
  number       = {823},
  pages        = {eabi1234},
  doi          = {10.1126/scitranslmed.abi1234},
  note         = {Long COVID IgG (n=13 patients) produced transient mechanical allodynia and thermal hyperalgesia in recipient mice. IgG accumulated in lumbar DRG colocalising with nociceptive and proprioceptive neurons. No cognitive impairment, anxiety, neuroinflammation, or astrogliosis observed. Effect abolished by IgG depletion and Fc-fragment digestion. Certainty: 0.75 (controlled animal study).},
  research_stream = {autoimmunity, long-covid},
  certainty    = {0.75}
}

@article{Goebel2021passiveTransferFM,
  author       = {Goebel, A. and Busch, K. and Riedl, R. and Sommer, C.},
  title        = {Passive transfer of fibromyalgia IgG induces pain and fatigue in mice},
  journal      = {Pain},
  year         = {2021},
  volume       = {162},
  number       = {4},
  pages        = {893--904},
  doi          = {10.1097/j.pain.0000000000002134},
  note         = {Fibromyalgia IgG (n=8 patients) produced mechanical and cold hypersensitivity, reduced locomotion, and reduced grip strength in recipient mice. IgG accumulated in dorsal root ganglia (DRG) and activated satellite glial cells (SGC). IgG-depleted serum had no effect, confirming immunoglobulin fraction as active component. Certainty: 0.70 (controlled animal study).},
  research_stream = {autoimmunity, fibromyalgia},
  certainty    = {0.70}
}

@article{Halonen2024LSRiskFactorsFinland,
