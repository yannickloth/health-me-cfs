  journal   = {BMC Immunology},
  year      = {2024},
  volume    = {25},
  number    = {1},
  pages     = {71},
  doi       = {10.1186/s12865-024-00665-5},
  pmid      = {39354352},
  note      = {Systematic review of 10 publications examining autoimmunity in ME/CFS. One investigated cytokine signaling; three genetic autoimmunity; one immune lineage; six autoantibody presence and role. Conclusion: inconsistent and insufficient evidence to classify ME/CFS as an autoimmune disease. RF not specifically addressed in any included study. Highlights the challenge of conflicting evidence (e.g., GPCR autoantibodies: Loebel 2016 positive, Germain 2025 null). Supports that autoantibody research in ME/CFS is insufficiently replicated. Certainty: 0.55.},
  keywords  = {ME/CFS, autoimmunity, systematic review, autoantibodies, evidence gap},
  research_stream = {rf-elevated-mecfs},
  certainty = {0.55}
}

