% B cell tolerance and autoimmunity
@article{JExpMed2024bcell,
  author = {Meffre, Eric and O'Connor, Kevin C.},
  title = {B cell tolerance and autoimmunity: Lessons from repertoires},
  journal = {Journal of Experimental Medicine},
  volume = {221},
  number = {9},
  pages = {e20231314},
  year = {2024},
  month = {September},
  doi = {10.1084/jem.20231314},
  pmid = {39115642},
  keywords = {B cells, tolerance, autoimmunity, repertoire, negative selection},
  note = {Comprehensive 2024 review showing that impaired clearance of autoreactive B cells due to disruption of negative selection barriers causes autoantibody-producing B cells to mature and subsequently differentiate into plasma cells. Demonstrates that while immune diversity enables recognition of any pathogen, it also poses risk of self-recognition leading to autoimmunity. Critical for understanding peripheral tolerance checkpoints},
  research_stream = {autoimmunity}
}

% Thymic tolerance and autoimmune disease prevention
@article{FrontImmunol2024thymic,
  author = {Mohtashami, Mahmood and Zú{\~n}iga-Pflücker, Juan Carlos},
  title = {Immune tolerance and the prevention of autoimmune diseases essentially depend on thymic tissue homeostasis},
  journal = {Frontiers in Immunology},
  volume = {15},
  pages = {1339714},
  year = {2024},
  month = {February},
  doi = {10.3389/fimmu.2024.1339714},
  pmid = {38455041},
  pmcid = {PMC10918340},
  keywords = {thymus, immune tolerance, T cells, autoimmunity, negative selection},
  note = {2024 review demonstrating that immune tolerance and prevention of autoimmune diseases essentially depend on thymic tissue homeostasis. Shows that thymus continues generating naive T cells through adolescence with rigorous negative selection against self-antigens. Thymic involution in adults eliminates this regenerative capacity, explaining age-dependent differences in immune tolerance mechanisms},
  research_stream = {autoimmunity}
}

