  journal  = {FASEB Journal},
  year     = {2023},
  volume   = {37},
  pages    = {e22953},
  doi      = {10.1096/fj.202201855RR},
  pmid     = {37224026},
  keywords = {adenine nucleotide translocase, ANT, ANT1, ANT2, ANT3, ANT4, isoforms, post-translational modification, review, diabetes, heart disease, Parkinson, Sengers syndrome, cancer},
  note     = {Comprehensive review of all four ANT isoforms (ANT1--4) covering structure, function, post-translational modifications, and pathological implications. ANT1 (heart/muscle/brain, pro-apoptotic, ATP export); ANT2 (liver/proliferating cells, anti-apoptotic, ATP import in glycolytic mode); ANT3 (ubiquitous); ANT4 (germ cells). Diseases with ANT involvement: diabetes, heart disease, Parkinson's disease, Sengers syndrome, cancer (isoform shift), Alzheimer's, Progressive External Ophthalmoplegia, Facioscapulohumeral muscular dystrophy. ANT1 loss-of-function mutations cause Sengers syndrome (skeletal myopathy, cardiomyopathy, exercise intolerance, lactic acidosis) — relevant phenotypic overlap with ME/CFS. Post-translational modifications (acetylation, nitrosylation, glutathionylation) can inhibit transport activity. No discussion of autoantibodies or ME/CFS. Limitations: review only; ME/CFS context must be inferred.},
  certainty = {0.75},
  research_stream = {ant-autoantibodies}
}

@article{DornerEtAl2006,
  author   = {D{\"o}rner, Andrea and Giessen, Susann and Gaub, Rainer and Grosse Siestrup, Henning and Schwimmbeck, Peter L. and Hetzer, Roland and Poller, Wolfgang and Schultheiss, Heinz-Peter},
  title    = {An isoform shift in the cardiac adenine nucleotide translocase expression alters the kinetic properties of the carrier in dilated cardiomyopathy},
  journal  = {European Journal of Heart Failure},
  year     = {2006},
  volume   = {8},
  number   = {1},
  pages    = {81--89},
  doi      = {10.1016/j.ejheart.2005.05.003},
  pmid     = {16107323},
  keywords = {adenine nucleotide translocase, ANT1, ANT2, isoform shift, dilated cardiomyopathy, kinetics, ATP transport, mitochondria},
  note     = {Study of ANT isoform expression in DCM vs.\ controls. DCM hearts show upregulation of ANT1 with downregulation of ANT2 (relative to controls). Kinetic consequence: maximum ADP/ATP transport velocity decreased from 1112+/-178 to 498+/-113 micromol/min/g (55\% reduction); ATP binding affinity Km shifted from 90.4 to 104.3 microM. G1409T polymorphism in ANT2 identified but not associated with disease. No autoantibody data. Relevance to G28: demonstrates that even without autoantibodies, ANT expression/kinetic changes can severely impair ATP export in diseased heart; in ME/CFS, both autoantibody and expression-level mechanisms may co-exist. Limitations: DCM cardiac tissue; no ME/CFS data; no autoantibody measurement.},
  certainty = {0.65},
  research_stream = {ant-autoantibodies}
}

@article{WohlrabEtAl2025,
  author   = {Wohlrab, Felix and Eltity, Mailam and Ufer, Friederike and Paul, Friedemann and Scheibenbogen, Carmen and Bellmann-Strobl, Judith},
