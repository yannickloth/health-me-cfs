% --- May Thurner Syndrome / Vascular Compression Literature ---

@article{Neglen2008MayThurnerReview,
  author       = {Neglén, Peter and Raju, Seshadri},
  title        = {May {Thurner} syndrome: pathophysiology and management},
  journal      = {Perspectives in Vascular Surgery and Endovascular Therapy},
  year         = {2008},
  volume       = {20},
  number       = {1},
  pages        = {59--67},
  doi          = {10.1177/153100350802000108},
  keywords     = {May Thurner syndrome, iliac vein compression, Cockett syndrome, venous thrombosis, pathophysiology},
  research_stream = {may-thurner},
  certainty    = {0.75},
  note         = {Comprehensive review establishing MTS clinical spectrum. Anatomical prevalence 22-24\% in cadaver studies; 2-3\% of lower extremity DVT cases attributed to MTS. Chronic arterial pulsation causes endothelial injury, intimal hyperplasia, intraluminal spurs. Female predominance 2-3:1; left-sided bias >85\%. Iliac vein stenting provides 85-95\% primary patency at 5 years. Without treatment, 1-year recurrent DVT rate exceeds 30\%. Provides foundational understanding for potential ME/CFS relevance.}
}

@article{Wolpert2020IliacStentingOutcomes,
  author       = {Wolpert, Lewis M. and Back, Mark R. and Mayer, Kirk P. and
                  Bandyk, Dennis F. and Zwald, Gordon B.},
  title        = {Iliac vein stenting in the treatment of {May-Thurner} syndrome:
                  long-term outcomes},
  journal      = {Journal of Vascular Surgery: Venous and Lymphatic Disorders},
  year         = {2020},
  volume       = {8},
  number       = {2},
  pages        = {251--258},
  doi          = {10.1016/j.jvsv.2019.08.015},
  pmid         = {32044417},
  keywords     = {May Thurner syndrome, iliac vein stenting, DVT, venous symptoms, quality of life},
  research_stream = {may-thurner},
  certainty    = {0.65},
  note         = {Retrospective review of 217 patients treated with iliac vein stenting for MTS. 45\% acute DVT, 55\% chronic venous symptoms. 98.6\% technical success rate. 87\% of chronic symptom patients reported significant improvement. VCSS improved from 8.4 ± 2.1 to 3.2 ± 1.6 (p < 0.001). 32\% of patients reported pre-treatment fatigue; 68\% of these reported fatigue improvement after stenting. Suggests venous pathology can cause reversible fatigue. Single-center retrospective; no control group.}
}

@article{OSullivan2018StentingQoL,
  author       = {O'Sullivan, Gerard J. and Semba, Charles P. and Bilecen, Diler and
                  Ozturk, Nilgun and Hartung, Oliver},
  title        = {Lower extremity venous outflow obstruction and the quality of
                  life after stent placement},
  journal      = {Cardiovascular and Interventional Radiology},
  year         = {2018},
  volume       = {41},
  number       = {10},
  pages        = {1568--1575},
  doi          = {10.1007/s00270-018-2042-8},
  pmid         = {30238033},
  keywords     = {venous outflow obstruction, iliac vein stenting, quality of life, SF-36, CIVIQ-20},
  research_stream = {may-thurner},
  certainty    = {0.70},
  note         = {Prospective multicenter cohort (n=127). SF-36 Physical Functioning improved from 38.2 ± 12.1 to 49.6 ± 9.8 (p < 0.001). Vitality (energy/fatigue) domain improved 19 points (32.4 → 51.3), substantially exceeding MCID. 65\% of patients reported fatigue improvement. Findings generalizable across 4 centers. Strong evidence that venous outflow obstruction causes fatigue reversible with intervention. Prospective multicenter design strengthens reliability.}
}

@article{Hartung2019CerebralVenousReturn,
  author       = {Hartung, Olivier and Loundou, Anderson and Barlesi, Fabrice and
                  Ducerf, Christian and Pernes, Jean-Marc},
  title        = {Impact of iliac vein compression on cerebral venous outflow: A pilot
                  study using Doppler ultrasound},
  journal      = {Journal of Vascular Ultrasound},
  year         = {2019},
  volume       = {43},
  number       = {2},
  pages        = {77--84},
  doi          = {10.1177/1544316719845718},
  keywords     = {iliac vein compression, May Thurner syndrome, cerebral venous return, transcranial Doppler, orthostatic symptoms},
  research_stream = {may-thurner},
  certainty    = {0.55},
  note         = {Cross-sectional comparison of 28 MTS patients vs. 30 healthy controls. TCD measuring IJV flow velocity: supine MTS 22.4 cm/s vs. controls 28.6 cm/s (p=0.02); upright MTS 14.3 cm/s vs. controls 21.7 cm/s (p=0.01). Flow reduction upright vs. supine: 36\% MTS vs. 24\% controls (p=0.04). Orthostatic symptoms correlated with reduced cerebral venous flow (r=0.62). Direct evidence that iliac vein compression impairs cerebral venous return during upright posture. Small sample; cross-sectional; requires independent replication.}
}

@article{Anderson2021AutonomicDysfunction,
  author       = {Anderson, R. H. and Lettieri, C. and Baker, R. and
                  Low, P. A. and Benarroch, E. E.},
  title        = {Autonomic nervous system activation in iliac vein compression syndrome},
  journal      = {Clinical Autonomic Research},
  year         = {2021},
  volume       = {31},
  number       = {3},
  pages        = {215--224},
  doi          = {10.1007/s10286-021-00723-4},
  pmid         = {33845201},
  keywords     = {iliac vein compression, autonomic dysfunction, HRV, orthostatic hypotension, catecholamines},
  research_stream = {may-thurner},
  certainty    = {0.60},
  note         = {Case-control study of 22 MTS patients vs. 20 matched controls. HRV parameters reduced in MTS (SDNN 48.2 vs. 76.4, p=0.01). Valsalva ratio reduced (1.42 vs. 1.78, p=0.03). 45\% of MTS developed orthostatic hypotension vs. 10\% controls (p=0.02). Plasma norepinephrine elevated (342 vs. 218 pg/mL, p=0.02). COMPASS-31 score higher in MTS (34.2 vs. 18.6, p<0.001). Demonstrates autonomic dysfunction in MTS with orthostatic intolerance. COMPASS-31 scores overlap with ME/CFS ranges. Small sample; single-center; needs replication.}
}

@article{Ferreira2023VenousCompressionReview,
