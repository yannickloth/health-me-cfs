@article{Wall2014IIHTT,
  author   = {Wall, Michael and Kupersmith, Mark J. and Kieburtz, Karl D. and Corbett, James J. and Feldon, Steven E. and Friedman, Deborah I. and Katz, B. Todd and Keltner, John L. and Schron, Eric B. and Shindler, Katherine S. and Cioffi, George A. and Garbutt, James C. and McAllister, Patrick E. and Sibony, Paul and Villegas, Betty P. and Yri, John E. and Maguire, Michael G. and Piantadosi, Steven and McDermott, Madeline and Thel, Martha and Kardon, Randy H.},
  title    = {The {Idiopathic Intracranial Hypertension Treatment Trial}: Clinical Profile at Baseline},
  journal  = {JAMA},
