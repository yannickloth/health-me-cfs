  pages    = {1641--1651},
  doi      = {10.1001/jama.2014.3312},
  pmid     = {24756514},
  url      = {https://doi.org/10.1001/jama.2014.3312},
  keywords = {idiopathic intracranial hypertension, IIH, acetazolamide, CSF, RCT, visual field, papilledema},
  certainty = {0.90},
  research_stream = {csf-drainage-synergy},
  note     = {Landmark multicenter RCT (n=165, 38 sites). Acetazolamide up to 4 g/day vs placebo + low-sodium diet for 6 months. Improved visual field (+0.71 dB, p=.050), reduced papilledema (p<.001), improved vision-related QoL (p=.003), weight loss -4.05 kg (p<.001). Class I evidence establishing acetazolamide as first-line IIH therapy. Demonstrates CA inhibition reduces CSF input pressure. High certainty: JAMA, Class I, multicenter. Limitations: modest effect size, 50\% treatment-limiting side effects, nearly all female.}
}

