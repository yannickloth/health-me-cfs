  year = {2012},
  volume = {85},
  number = {1015},
  pages = {e270--e273},
  doi = {10.1259/bjr/93889091},
  pmid = {22128128},
  url = {https://doi.org/10.1259/bjr/93889091},
  keywords = {ME/CFS, VBM, voxel-based morphometry, gray matter, white matter, occipital cortex, parahippocampal gyrus},
  note = {VBM 3T MRI study in ME/CFS patients demonstrating reduced gray matter volume in occipital lobes (bilateral occipital poles, left lateral occipital cortex, left supracalcrine cortex), right angular gyrus, and posterior left parahippocampal gyrus. White matter volume also reduced in the left occipital lobe. The parahippocampal changes are consistent with the memory impairment commonly reported in ME/CFS. Results complement but differ from other VBM studies, reflecting heterogeneity in ME/CFS neuroanatomy.},
  research_stream = {pathophysiology-general}
}

