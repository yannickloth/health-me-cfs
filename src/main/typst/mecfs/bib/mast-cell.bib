  keywords = {mast cells, autonomic nervous system, dysautonomia, neuroinflammation, POTS, ME/CFS, Long COVID, CRH, histamine},
  certainty = {0.62},
  research_stream = {mcas-primary-driver},
  note = {Mechanistic review: mast cells are located perivascularly near nerve endings in carotid bodies, heart, and hypothalamus, positioning them to trigger dysautonomia and neuroinflammation. CRH activates hypothalamic mast cells via CRHR-1; mediators released include VEGF, tryptase, neurotensin, CXCL8. Identifies POTS, ASD, ME/CFS, Long COVID as target conditions. No effective treatment currently available. First review to systematically map mast cell--ANS interactions as upstream driver of dysautonomia.}
}

