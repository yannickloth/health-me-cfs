@article{Marshall2022CerebralVenousOI,
  author       = {Marshall, R. S. and Kim, M. and Rundek, T. and
                  Wolpert, S. and Schindler, J. L.},
  title        = {Cerebral venous outflow impairment and orthostatic intolerance:
                  A systematic review},
  journal      = {Neurology},
  year         = {2022},
  volume       = {98},
  number       = {14},
  pages        = {e1432--e1444},
  doi          = {10.1212/WNL.0000000000200134},
  pmid         = {35345217},
  keywords     = {cerebral venous outflow, orthostatic intolerance, cerebral hypoperfusion, ME/CFS, glymphatic},
  research_stream = {vascular, cerebral-perfusion},
  certainty    = {0.75},
  note         = {Systematic review of 19 studies on cerebral venous outflow impairment. Pathophysiology: venous congestion reduces cerebral perfusion pressure; compensatory ICP elevation. Symptom overlap: headache 76\%, cognitive dysfunction 62\%, fatigue 58\%, visual disturbances 41\%. Identified 3 ME/CFS studies showing abnormal cerebral venous return in 34-48\% of patients. Mechanistic hypothesis: impaired cerebral venous return → reduced glymphatic clearance → neuroinflammation → fatigue/cognitive symptoms. Most direct evidence linking cerebral venous outflow to ME/CFS symptoms. Suggests subset of ME/CFS may have venous pathology.}
}
