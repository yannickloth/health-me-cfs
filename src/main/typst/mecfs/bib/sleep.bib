  keywords     = {sleep deprivation, salivary metabolomics, machine learning,
                  LC-HRMS, oral fluid, metabolic fingerprint, sleep restriction,
                  forensic applications},
  research_stream = {sleep-deprivation-saliva},
  certainty    = {0.65},
  note         = {n=20 young men, randomized controlled crossover trial.
                  24h total sleep deprivation produced unique metabolic
                  fingerprint detectable with F0.5=0.90 using 12 molecular
                  features. 4-night sleep restriction to 6h produced NO
                  significant metabolic changes. Fingerprint more pronounced
                  in morning/midday samples. Critical finding: chronic sleep
                  restriction does not produce exploitable metabolic changes,
                  suggesting ME/CFS unrefreshing sleep may not match acute
                  deprivation model.}
}

