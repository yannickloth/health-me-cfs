  pmid = {39237911},
  pmcid = {PMC11375890},
  keywords = {melatonin, NK cell, natural killer cell, JAK3, STAT5, T-bet, innate immunity, immunomodulation, aging},
  note = {Mouse model (aged mice). Melatonin significantly increased NK cell number and function: proliferation, degranulation, and IFN-gamma secretion. Mechanism: JAK3/STAT5 signalling leads to increased T-bet expression, driving NK cell maturation and activation. Relevant to ME/CFS context of NK cell hypofunctionality: melatonin deficit from circadian disruption may contribute to reduced NK cytotoxicity. Erratum published 2024 Oct (minor correction). No conflicts of interest.},
