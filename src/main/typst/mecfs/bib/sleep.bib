@article{Huang2024Adenosine,
  author = {Huang, Li and Zhu, Wei and Li, Na and Zhang, Bo and Dai, Wei and Li, Shuai and Xu, Hua},
  title = {Functions and mechanisms of adenosine and its receptors in sleep regulation},
  journal = {Sleep Medicine},
  year = {2024},
  volume = {115},
  pages = {210--217},
  doi = {10.1016/j.sleep.2024.02.012},
  pmid = {38373361},
  url = {https://doi.org/10.1016/j.sleep.2024.02.012},
  keywords = {adenosine, sleep homeostasis, A1 receptor, A2A receptor, astrocyte, sleep pressure, sleep regulation},
  note = {Comprehensive review establishing that adenosine promotes sleep by inhibiting arousal systems and activating sleep-promoting systems. Astrocyte-derived adenosine is critical for sleep homeostasis. A1 and A2A receptors mediate distinct aspects of sleep pressure accumulation. Documents that caffeine's wake-promoting effect operates through adenosine receptor blockade. Key mechanistic reference for adenosine as the primary homeostatic sleep signal.},
  research_stream = {sleep}
}

@article{Retey2007ADORA2A,
  author = {R{\'e}tey, Julia V and Adam, Martin and Khatami, Ramin and Luhmann, Ulrich F O and Jung, Hans H and Berger, Wolfgang and Landolt, Hans-Peter},
  title = {A genetic variation in the adenosine {A2A} receptor gene ({ADORA2A}) contributes to individual sensitivity to caffeine effects on sleep},
  journal = {Clinical Pharmacology \& Therapeutics},
  year = {2007},
  volume = {81},
  number = {5},
  pages = {692--698},
  doi = {10.1038/sj.clpt.6100102},
  pmid = {17329997},
  url = {https://doi.org/10.1038/sj.clpt.6100102},
  keywords = {ADORA2A, caffeine, adenosine A2A receptor, sleep, individual sensitivity, pharmacogenetics},
  note = {Pharmacogenetic study demonstrating that the ADORA2A c.1083T>C single nucleotide polymorphism determines individual sensitivity to caffeine-induced sleep disruption. The ADORA2A genotype determines how closely caffeine-induced changes in brain electrical activity during sleep resemble insomnia patterns. Caffeine sensitivity is a functional readout of A2A receptor sensitivity, establishing genetic variation as a modulator of adenosine sleep signaling. Relevant to understanding ME/CFS patients' variable caffeine responses.},
  research_stream = {sleep}
}

@article{RabagoMonzon2025SleepGlia,
  author = {R{\'a}bago-Monz{\'o}n, {\'A}ngel R and Osuna-Ramos, Juan F and Armienta-Rojas, Diego A and Camberos-Barraza, Josue and Camacho-Zamora, Alejandro and Maga{\~n}a-G{\'o}mez, Javier A and De la Herr{\'a}n-Arita, Alberto K},
  title = {Stress-Induced Sleep Dysregulation: The Roles of Astrocytes and Microglia in Neurodegenerative and Psychiatric Disorders},
  journal = {Biomedicines},
  year = {2025},
  volume = {13},
  number = {5},
  pages = {1121},
  doi = {10.3390/biomedicines13051121},
  pmid = {40426947},
  url = {https://doi.org/10.3390/biomedicines13051121},
  keywords = {astrocytes, microglia, adenosine signaling, glymphatic clearance, sleep dysregulation, neuroinflammation, chronic stress},
  note = {Documents that astrocytes regulate sleep architecture through two primary mechanisms: adenosine signaling modulation and glymphatic clearance control. Chronic stress disrupts both pathways, diminishing restorative sleep quality. Microglial activation via neuroinflammation further degrades sleep quality. The convergence of adenosine dysregulation and glymphatic failure on synaptic dysfunction is central to the sleep disruption observed in stress-related disorders. Directly relevant to ME/CFS in which chronic immune activation mimics a persistent stress state impairing glial-mediated adenosine clearance.},
  research_stream = {sleep}
}

@article{Maksoud2021SleepMECFS,
  author = {Maksoud, Rebekah and Eaton-Fitch, Natalie and Matula, Michael and Cabanas, H{\'e}l{\`e}ne and Staines, Donald and Marshall-Gradisnik, Sonya},
  title = {Systematic Review of Sleep Characteristics in Myalgic Encephalomyelitis/Chronic Fatigue Syndrome},
  journal = {Healthcare},
  year = {2021},
  volume = {9},
  number = {5},
  pages = {568},
  doi = {10.3390/healthcare9050568},
  pmid = {34065013},
  url = {https://doi.org/10.3390/healthcare9050568},
  keywords = {ME/CFS, sleep, polysomnography, systematic review, unrefreshing sleep, microarousal, sleep fragmentation},
  note = {Systematic review of sleep characteristics in ME/CFS. Key finding: increased microarousal index (MAI) is the most consistent polysomnographic abnormality---all five studies measuring MAI found significant increases vs. healthy controls, indicating pathological sleep fragmentation. Major discrepancy between subjective sleep complaints (91\% of patients) and objective polysomnographic measures. Sleep onset latency is consistently normal, suggesting the primary pathology is in sleep maintenance and quality, not initiation. The fragmentation pattern is consistent with an adenosine-mediated sleep pressure abnormality causing intermittent arousal.},
  research_stream = {sleep}
}

