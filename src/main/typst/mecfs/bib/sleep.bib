  author       = {Khanpour Ardestani, Shadi and Karkhaneh, Mohammad and Stein, Elaine and Punja, Salima and Junqueira, Diego R. and Kuzmyn, Taras and Pearson, Megan and Smith, Leslea and Olson, Karin and Vohra, Sunita},
  title        = {Systematic Review of Mind-Body Interventions to Treat Myalgic Encephalomyelitis/Chronic Fatigue Syndrome},
  journal      = {Medicina (Kaunas)},
  year         = {2021},
  volume       = {57},
  number       = {7},
  pages        = {652},
  doi          = {10.3390/medicina57070652},
  pmid         = {34202826},
  url          = {https://doi.org/10.3390/medicina57070652},
  keywords     = {ME/CFS, mind-body, mindfulness, MBSR, yoga, systematic review},
  certainty    = {0.45},
  research_stream = {sleep-rest-meditation},
  note         = {Systematic review, 12 studies (7 RCTs). Interventions: MBSR, MBCT, relaxation, Qigong, CBT-stress management, ACT, isometric yoga. Nine of 12 studies showed fatigue improvement; 8/12 anxiety/depression reduction. Critical limitations: heterogeneous diagnostic criteria, small samples, high risk of bias. Cannot determine which component (cognitive, physical, rest) drives improvement. No adverse event tracking in most studies.}
}

@article{Sampalli2009MBSR,
  author       = {Sampalli, Tara and Berlasso, Emma and Fox, Robert and Petter, Mark},
  title        = {A controlled study of the effect of a mindfulness-based stress reduction technique in women with multiple chemical sensitivity, chronic fatigue syndrome, and fibromyalgia},
