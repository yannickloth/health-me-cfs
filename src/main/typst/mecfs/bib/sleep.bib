  pmid = {38445651},
  pmcid = {PMC11217625},
  keywords = {melatonin, DLMO, delayed sleep-wake phase disorder, low-dose, circadian, behavioural intervention, RCT},
  note = {RCT, n=40 adults with DSWPD, randomised to 0.5mg melatonin 3h before measured DLMO vs. 5h before estimated sleep onset (actigraphy), plus behavioural interventions (evening dim light, time-in-bed scheduling) for 4 weeks. Significant improvements in DLMO timing, sleep-onset/offset, Morningness-Eveningness score, fatigue (MFI), PROMIS sleep disturbance after Bonferroni correction. No group-by-visit interaction: DLMO estimation as effective as measurement. Preliminary; larger trial needed. Conflict: Burgess on advisory board Natrol LLC.},
