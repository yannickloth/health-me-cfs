  keywords     = {ME/CFS, fibromyalgia, MCS, MBSR, mindfulness, controlled trial},
  certainty    = {0.40},
  research_stream = {sleep-rest-meditation},
  note         = {10-week MBSR program. n=50 intervention, n=26 waitlist controls. Women with MCS, CFS, fibromyalgia. Statistically significant improvements on SCL-90R pre-post (p<0.0001) and at 3-month follow-up; controls showed no change. Non-randomized; self-selected groups. MBSR standard format = 2.5h/week sessions + home practice — cognitively demanding for severe ME/CFS patients. No adverse event reporting.}
}

@article{Lakhan2013MBT,
