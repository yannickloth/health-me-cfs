  pages = {100412},
  doi = {10.1016/j.bbih.2022.100412},
  pmid = {35465246},
  pmcid = {PMC9019698},
  keywords = {ME/CFS, circadian rhythm, DLMO, melatonin, TGF-beta, long COVID, PASC, sleep},
  note = {Narrative review linking circadian disruption to ME/CFS and long COVID pathophysiology. Key finding: ME/CFS patients lack the midday temperature increase seen in controls and show distinct evening temperature drop, indicating multi-system circadian decoupling. DLMO timing is dissociated from temperature rhythm (intact in controls, absent in ME/CFS). TGFB dysregulation proposed as mechanistic driver of peripheral clock disruption. Melatonin effective only in phase-delayed subset.},
  research_stream = {sleep}
}

@article{vanHeukelom2006melatonin,
  author = {van Heukelom, R O and Prins, J B and Smits, M G and Bleijenberg, G},
  title = {Influence of melatonin on fatigue severity in patients with chronic fatigue syndrome and late melatonin secretion},
  journal = {European Journal of Neurology},
  year = {2006},
  volume = {13},
  number = {1},
  pages = {55--60},
  doi = {10.1111/j.1468-1331.2006.01132.x},
  pmid = {16420393},
  keywords = {ME/CFS, CFS, melatonin, DLMO, fatigue, circadian, chronotherapy},
  note = {n=29 CFS patients with DLMO later than 21:30h. Open-label: 5mg melatonin orally 5h before DLMO for 3 months. CIS questionnaire: total score and sub-scores for fatigue, concentration, motivation, and activity improved significantly. Fatigue normalised in 8/27 vs. 2/29 pre-treatment (significant). Patients with DLMO later than 22:00h (n=21) showed greater benefit than earlier DLMO group (n=8). Supports DLMO-guided melatonin timing; no control group limits causal inference.},
  research_stream = {sleep}
}

@article{Knook2000melatonin,
  author = {Knook, L and Kavelaars, A and Sinnema, G and Kuis, W and Heijnen, C J},
  title = {High nocturnal melatonin in adolescents with chronic fatigue syndrome},
  journal = {Journal of Clinical Endocrinology \& Metabolism},
  year = {2000},
  volume = {85},
  number = {10},
  pages = {3690--3692},
  doi = {10.1210/jcem.85.10.6857},
  pmid = {11061525},
  keywords = {ME/CFS, CFS, melatonin, adolescent, nocturnal, unrefreshing sleep, amplitude},
  note = {n=13 adolescent CFS vs. n=15 healthy controls. Saliva melatonin hourly 17:00--02:00h. Nocturnal melatonin significantly elevated in CFS at midnight, 01:00h, and 02:00h (p<0.001). Timing of melatonin rise did not differ. All CFS patients reported unrefreshing sleep vs. 1 control. Conclusion: melatonin supplementation not indicated in this subgroup given already elevated levels. Highlights heterogeneity: adult delayed vs. adolescent elevated-amplitude phenotypes.},
  research_stream = {sleep}
}

@article{Mohamed2023sleep,
  author = {Mohamed, Ahmed Z and Andersen, Tor and Radovic, Sanja and Del Fante, Peter and Kwiatek, Richard and Calhoun, Vince and Bhuta, Sandeep and Hermens, Daniel F and Lagopoulos, Jim and Shan, Zack Y},
  title = {Objective sleep measures in chronic fatigue syndrome patients: {A} systematic review and meta-analysis},
  journal = {Sleep Medicine Reviews},
  year = {2023},
  volume = {69},
  pages = {101771},
  doi = {10.1016/j.smrv.2023.101771},
  pmid = {36948138},
  pmcid = {PMC10281648},
  keywords = {ME/CFS, CFS, sleep, polysomnography, meta-analysis, unrefreshing sleep, sleep architecture, sleep efficiency},
  note = {Systematic review and meta-analysis: 24 case-control studies; 20 adult studies (ME/CFS n=426, controls n=375) and 4 adolescent studies (ME/CFS n=242, controls n=235). Adults: longer sleep onset latency, longer WASO, reduced sleep efficiency, decreased stage N2, more stage N3 (SWS), longer REM latency. Adolescents: longer TIB, longer TST, longer SOL, reduced efficiency. Results suggest autonomic (sympathetic/parasympathetic) alterations in ME/CFS. No conflicts of interest.},
  research_stream = {sleep}
}

@article{Burgess2010melatonin,
  author = {Burgess, Helen J and Revell, Victoria L and Molina, Thomas A and Eastman, Charmane I},
  title = {Human phase response curves to three days of daily melatonin: {0.5~mg} versus {3.0~mg}},
  journal = {Journal of Clinical Endocrinology \& Metabolism},
  year = {2010},
  volume = {95},
  number = {7},
  pages = {3325--3331},
  doi = {10.1210/jc.2009-2590},
  pmid = {20410229},
  pmcid = {PMC2928909},
  keywords = {melatonin, dose, phase response curve, DLMO, circadian, low-dose, chronobiology},
  note = {n=34 healthy adults (16M/18F, ages 18--42), double-blind placebo-controlled. Phase response curves for 0.5mg vs 3.0mg oral melatonin. Maximum circadian phase advances with 0.5mg occurred 2--4h before DLMO or 9--11h before sleep midpoint. When each dose given at its optimal time, both 0.5mg and 3.0mg produce similarly sized phase advances and delays. Optimal timing for advances is later for the lower dose. Supports low-dose (0.5mg) melatonin as effective chronobiotic without suppressing endogenous secretion.},
  research_stream = {sleep}
}

@article{Swanson2024DLMO,
  author = {Swanson, Leslie M and de Sibour, Thomas and DuBuc, Kathryn and Conroy, Deirdre A and Raglan, Greta B and Lorang, Kara and Zollars, Jennifer and Hershner, Shelby and Arnedt, J Todd and Burgess, Helen J},
  title = {Low-dose exogenous melatonin plus evening dim light and time in bed scheduling advances circadian phase irrespective of measured or estimated dim light melatonin onset time: preliminary findings},
