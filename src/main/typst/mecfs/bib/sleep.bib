}

@article{Oka2014isometricYoga,
  author       = {Oka, Takakazu and Tanahashi, Tokusei and Chijiwa, Toshiyuki and Lkhagvasuren, Batsaikhan and Sudo, Nobuyuki and Oka, Kagari},
  title        = {Isometric yoga improves the fatigue and pain of patients with chronic fatigue syndrome who are resistant to conventional therapy: a randomized, controlled trial},
  journal      = {Biopsychosocial Medicine},
  year         = {2014},
  volume       = {8},
  number       = {1},
  pages        = {27},
  doi          = {10.1186/s13030-014-0027-8},
  pmid         = {25525457},
  url          = {https://doi.org/10.1186/s13030-014-0027-8},
  keywords     = {ME/CFS, isometric yoga, fatigue, pain, RCT},
  certainty    = {0.50},
  research_stream = {sleep-rest-meditation},
  note         = {RCT, n=30 therapy-resistant CFS patients (Fukuda criteria). Biweekly sessions + daily home practice, 2 months. Chalder Fatigue Scale: yoga group 25.9+-6.1 to 19.2+-7.5 (p=0.002); control no significant change. Isometric yoga = static muscle contractions without movement, performed seated — avoids aerobic exertion and significant cardiovascular demand. Key differentiator from standard yoga: no balance, no movement, no aerobic component. Single center (Japan); short follow-up; no blinding.}
}

@article{Oka2017recumbentYoga,
  author       = {Oka, Takakazu and Wakita, Haruyoshi and Kimura, Kanae},
  title        = {Development of a recumbent isometric yoga program for patients with severe chronic fatigue syndrome/myalgic encephalomyelitis: A pilot study to assess feasibility and efficacy},
  journal      = {Biopsychosocial Medicine},
  year         = {2017},
  volume       = {11},
  pages        = {5},
  doi          = {10.1186/s13030-017-0090-z},
  pmid         = {28270860},
  url          = {https://doi.org/10.1186/s13030-017-0090-z},
  keywords     = {ME/CFS, isometric yoga, recumbent, severe, pilot},
  certainty    = {0.35},
  research_stream = {sleep-rest-meditation},
  note         = {Pilot, n=12 severe CFS/ME patients (unable to attend outpatient). Recumbent format (lying supine) to eliminate postural challenge — critical for OI patients. Both groups showed significant fatigue reduction over 3 months; recumbent preferred by all group 2 patients. No control group; very small sample; single center. Clinical significance: recumbent format removes orthostatic component entirely, making isometric yoga accessible to most severe cases.}
}

@article{Oka2018yogaMechanisms,
  author       = {Oka, Takakazu and Tanahashi, Tokusei and Sudo, Nobuyuki and Lkhagvasuren, Batsaikhan and Yamada, Yoshitsugu},
  title        = {Changes in fatigue, autonomic functions, and blood biomarkers due to sitting isometric yoga in patients with chronic fatigue syndrome},
  journal      = {Biopsychosocial Medicine},
  year         = {2018},
  volume       = {12},
  pages        = {3},
  doi          = {10.1186/s13030-018-0123-2},
  pmid         = {29643935},
  url          = {https://doi.org/10.1186/s13030-018-0123-2},
  keywords     = {ME/CFS, isometric yoga, autonomic, HRV, cortisol, TNF-alpha},
  certainty    = {0.45},
  research_stream = {sleep-rest-meditation},
  note         = {Mechanistic study, n=15 CFS. Single session seated isometric yoga. Reduced POMS fatigue (p<0.01), increased vigor (p<0.01). Physiological changes: reduced HR, increased HF-HRV (vagal tone up), decreased cortisol and TNF-alpha, increased DHEA-S. Mechanism: isometric yoga induces parasympathetic shift and acute anti-inflammatory response. Cortisol decrease without fatigue increase distinguishes from physical exertion. Small n; single time point; no blinding.}
}

@article{OConnor2019energyEnvelope,
  author       = {O'Connor, Kevin and Sunnquist, Madison and Nicholson, Lisa and Jason, Leonard A. and Newton, Julia L. and Strand, Elin B.},
  title        = {Energy envelope maintenance among patients with myalgic encephalomyelitis and chronic fatigue syndrome: Implications of limited energy reserves},
  journal      = {Chronic Illness},
  year         = {2019},
  volume       = {15},
  number       = {1},
  pages        = {51--60},
  doi          = {10.1177/1742395317746470},
  pmid         = {29231037},
  url          = {https://doi.org/10.1177/1742395317746470},
  keywords     = {ME/CFS, pacing, energy envelope, functioning, post-exertional malaise},
  certainty    = {0.55},
  research_stream = {sleep-rest-meditation},
  note         = {Energy envelope theory validation. Six groups stratified by available energy and envelope adherence. Higher available energy + within-envelope activity = better functioning. Overexertion diminishes advantage even for high-energy patients. Applies equally to cognitive and physical exertion — meditation exceeding cognitive envelope triggers PEM. Supports pacing as the foundational framework for all ME/CFS rest interventions including meditation adaptation.}
}

