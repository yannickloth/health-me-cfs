  year         = {2026},
  doi          = {10.1101/2023.10.27.564043},
  keywords     = {3D genome organization, repeat sequences, A/B compartments, CpG methylation, ProB RepSeqs, pericentromeric satellites, DNMT3B, heterochromatin, cancer},
  note         = {Defines ProA/ProB repeat sequences as cis-elements promoting euchromatin/heterochromatin. CpG methylation loss disproportionately impacts ProB RepSeqs (satellites, young LINE-1s, ERVs), weakening the B compartment → genome unfolding. DNMT3B redistribution as driver of methylation erosion in B compartment. SupD Fig 17 shows GSATII (HSAT2) methylation loss in liver cancer — direct experimental validation of satellite repeat hypomethylation in cancer. Proposes a unified molecular mechanism: CpG methylation on ~200bp segments decreases nucleosome mobility, providing a single biophysical mechanism for methylation's context-dependent effects on gene expression (activating in gene bodies, repressing at promoters). Geneviève Fourel, lead contact. Certainty: 0.60 (preprint, computational genomics + multi-omics validation, independent lab co-authorship).},
  research_stream = {methylation-loss-consolidation},
  certainty    = {0.60}
}

