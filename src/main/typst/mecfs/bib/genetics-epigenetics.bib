@article{Frye2024ASDmitochondria,
  author   = {Frye, Richard E and Rincon, Nicole and McCarty, Patrick J and Brister, Danielle and Scheck, Adrienne C and Rossignol, Daniel A},
  title    = {Biomarkers of mitochondrial dysfunction in autism spectrum disorder: {A} systematic review and meta-analysis},
  journal  = {Neurobiology of Disease},
  year     = {2024},
  volume   = {197},
  pages    = {106520},
  doi      = {10.1016/j.nbd.2024.106520},
  pmid     = {38703861},
  url      = {https://pubmed.ncbi.nlm.nih.gov/38703861/},
  keywords = {autism, ASD, mitochondrial dysfunction, lactate, pyruvate, ATP, creatine kinase, energy metabolism, meta-analysis},
  certainty = {0.70},
  research_stream = {lower-baseline-predisposition},
  note     = {Systematic review and meta-analysis, 204 studies. Elevated lactate (17\%), pyruvate (41\%), alanine (15\%), creatine kinase (9\%) in ASD. Significant ATP deficit and elevated lactate:pyruvate ratio (moderate-to-large effect sizes). Mitochondrial dysfunction linked to GI symptoms, oxidative stress, immune dysfunction. Carnitine and ubiquinol showed benefit. Core evidence: ASD involves systemic mitochondrial dysfunction that would reduce metabolic reserve prior to any infectious trigger.}
}

@article{Kindgren2021hEDSadhd,
  author   = {Kindgren, Erik and Qui{\~n}ones Perez, Antonia and Knez, Rajna},
  title    = {Prevalence of {ADHD} and Autism Spectrum Disorder in Children with Hypermobility Spectrum Disorders or Hypermobile {Ehlers-Danlos} Syndrome: A Retrospective Study},
  journal  = {Neuropsychiatric Disease and Treatment},
  year     = {2021},
  volume   = {17},
  pages    = {379--388},
  doi      = {10.2147/NDT.S290494},
  pmid     = {33603376},
  pmcid    = {PMC7882457},
  url      = {https://pmc.ncbi.nlm.nih.gov/articles/PMC7882457/},
  keywords = {hEDS, HSD, hypermobility, ADHD, autism, neurodevelopmental, comorbidity, pediatric},
  certainty = {0.60},
  research_stream = {lower-baseline-predisposition},
  note     = {Retrospective study n=201 children (ages 6--18) with hEDS or HSD. ADHD verified diagnosis 16\%, additional 7\% under investigation. ASD 6\%. In age group 17--18 years, ADHD present in 46\%. hEDS showed significantly higher ADHD rate than HSD. Establishes the neurodivergent-hypermobility axis; children with hEDS/HSD should be routinely screened for neuropsychiatric symptoms.}
}

@article{Csecs2022hypermobility,
  author   = {Csecs, Jenny L L and Iodice, Valeria and Rae, Charlotte L and Brooke, Anna and Simmons, Rosie and Quadt, Lisa and Savage, Ginny K and Dowell, Nicholas G and Prowse, Florence and Themelis, Konstantinos and Mathias, Christopher J and Critchley, Hugo D and Eccles, Jessica A},
  title    = {Joint Hypermobility Links Neurodivergence to Dysautonomia and Pain},
  journal  = {Frontiers in Psychiatry},
  year     = {2022},
  volume   = {12},
  pages    = {786916},
  doi      = {10.3389/fpsyt.2021.786916},
  pmid     = {35185636},
  pmcid    = {PMC8847158},
  url      = {https://pmc.ncbi.nlm.nih.gov/articles/PMC8847158/},
  keywords = {hypermobility, neurodivergence, autism, ADHD, Tourette syndrome, dysautonomia, orthostatic intolerance, pain, connective tissue},
  certainty = {0.65},
  research_stream = {lower-baseline-predisposition},
  note     = {n=109 neurodivergent adults (autism, ADHD, Tourette syndrome). Generalized joint hypermobility 51\% vs.\ 20\% in general population. Female prevalence 69\%. Joint hypermobility mediated the association between neurodivergence and both dysautonomia symptoms and pain. Establishes the neurodivergence--hypermobility--dysautonomia triangle: connective tissue variation as unifying predisposing feature across these comorbid conditions.}
}

@article{BaezaVelasco2025autismEDS,
  author   = {Baeza-Velasco, Carolina and Vergne, Judith and Poli, Marianna and Kalisch, Larissa and Calati, Raffaella},
  title    = {Autism in the context of joint hypermobility, hypermobility spectrum disorders, and {Ehlers-Danlos} syndromes: {A} systematic review and prevalence meta-analyses},
  journal  = {Autism},
  year     = {2025},
  volume   = {29},
  number   = {8},
  pages    = {1939--1958},
  doi      = {10.1177/13623613251328059},
  pmid     = {40145613},
  url      = {https://pubmed.ncbi.nlm.nih.gov/40145613/},
  keywords = {autism, ASD, hypermobility, hEDS, EDS, connective tissue, comorbidity, meta-analysis, prevalence},
  certainty = {0.70},
  research_stream = {lower-baseline-predisposition},
  note     = {Systematic review and meta-analyses, 20 studies. Prevalence of JH in autistic individuals: 22.3\% overall, 31\% when assessed clinically. Prevalence of HSD/EDS in autistic samples: 27.9\% overall, 39\% when assessed clinically. 12/15 studies found significant ASD--JH association. Autistic individuals are 7.4 times more likely to have EDS than comparison groups. Confirms the autism--hypermobility cluster as a high-risk phenotype for ME/CFS-adjacent conditions.}
}

@article{Lau2015migraineCFS,
  author   = {Lau, Chi-In and Lin, Che-Chen and Chen, Wu-Hsien and Wang, Hsin-Chuan and Kao, Chia-Hung},
  title    = {Increased risk of chronic fatigue syndrome in patients with migraine: {A} retrospective cohort study},
