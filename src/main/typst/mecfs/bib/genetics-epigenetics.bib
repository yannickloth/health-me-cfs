@article{BulikSullivan2015LDSC,
  author  = {Bulik-Sullivan, Brendan K and Loh, Po-Ru and Finucane, Hilary K and Ripke, Stephan and Yang, Jian and Patterson, Nick and Daly, Mark J and Price, Alkes L and Neale, Benjamin M},
  title   = {{LD} Score regression distinguishes confounding from polygenicity in genome-wide association studies},
  journal = {Nature Genetics},
  year    = {2015},
  volume  = {47},
  number  = {3},
  pages   = {291--295},
  doi     = {10.1038/ng.3211},
  note    = {Foundational methods paper for LD Score regression (LDSC). Distinguishes polygenic signal from confounding biases (cryptic relatedness, population stratification). LDSC intercept estimates inflation from bias vs true polygenicity. Foundation for subsequent stratified LDSC (Finucane 2018) used in tissue/cell-type enrichment. Highly cited (6,174 citations). Assumes infinitesimal polygenic architecture},
  research_stream = {genetics-methods},
  certainty = {0.92}
}

@article{deLeeuw2015MAGMA,
  author  = {de Leeuw, Christiaan A and Mooij, Joris M and Heskes, Tom and Posthuma, Danielle},
  title   = {{MAGMA}: generalized gene-set analysis of {GWAS} data},
  journal = {PLoS Computational Biology},
  year    = {2015},
  volume  = {11},
  number  = {4},
  pages   = {e1004219},
  doi     = {10.1371/journal.pcbi.1004219},
  pmid    = {25885710},
  pmcid   = {PMC4401657},
  note    = {Multi-marker Analysis of GenoMic Annotation (MAGMA). Gene analysis via multiple regression — better power than single-SNP methods. Gene-set analysis built as separate layer with regression structure allowing continuous gene properties. Significantly outperforms PLINK, ALIGATOR, INRICH, MAGENTA in simulation and Crohn's disease benchmark. Enables competitive gene-set analysis. Corrects for LD, gene size, gene density. >2,000 citations; adopted as default gene-set method in FUMA platform},
  research_stream = {genetics-methods},
  certainty = {0.90}
}

@article{Finucane2018stratifiedLDSC,
  author  = {Finucane, Hilary K and Reshef, Yakir A and Anttila, Verneri and Slowikowski, Kamil and Gusev, Alexander and Byrnes, Andrea and Gazal, Steven and Loh, Po-Ru and Lareau, Caleb and Shoresh, Noam and Genovese, Giulio and Saunders, Arpiar and Macosko, Evan and Pollack, Samuela and Perry, John R B and Buenrostro, Jason D and Bernstein, Bradley E and Raychaudhuri, Soumya and McCarroll, Steven and Neale, Benjamin M and Price, Alkes L},
  title   = {Heritability enrichment of specifically expressed genes identifies disease-relevant tissues and cell types},
  journal = {Nature Genetics},
  year    = {2018},
  volume  = {50},
  number  = {4},
  pages   = {621--629},
  doi     = {10.1038/s41588-018-0081-4},
  note    = {Introduced stratified LD score regression (S-LDSC) to partition SNP heritability by functional annotation. Created 10 cell-type-specific gene sets from GTEx v6, ImmGen, Franke lab data. Tested 48 diseases/traits — correctly identified immune cell enrichment for RA/Crohn's, CNS for schizophrenia/epilepsy, pancreatic for diabetes. Published annotation files on Google Cloud. Pipeline used directly by mecfsscience.org ME/CFS analyses. Robust for broad cell-type families; limited for closely related subtypes},
  research_stream = {genetics-methods},
  certainty = {0.90}
}

