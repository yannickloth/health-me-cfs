}

@article{Wang2023migraineMito,
  author   = {Wang, Yicheng and Wang, Yongli and Yue, Guangxin and Zhao, Yonglie},
  title    = {Energy metabolism disturbance in migraine: {From} a mitochondrial point of view},
  journal  = {Frontiers in Physiology},
  year     = {2023},
  volume   = {14},
  pages    = {1133528},
  doi      = {10.3389/fphys.2023.1133528},
  pmid     = {37123270},
  pmcid    = {PMC10133718},
  url      = {https://pubmed.ncbi.nlm.nih.gov/37123270/},
  keywords = {migraine, mitochondria, energy metabolism, lactate, NAA, cytochrome c oxidase, oxidative phosphorylation, cortical spreading depression},
  certainty = {0.60},
  research_stream = {lower-baseline-predisposition},
  note     = {Narrative review. Migraineurs show elevated blood lactate, lower NAA, decreased activities of NADH dehydrogenase, citrate synthase, and cytochrome c oxidase. 95\% of cellular energy from mitochondrial respiratory chain; impaired oxidative phosphorylation lowers pain threshold and neuronal excitability. Many migraine triggers (stress, sleep deprivation, fasting, exercise) are also ME/CFS triggers — shared energy metabolism vulnerability. Establishes migraine as a condition of reduced mitochondrial reserve.}
}

@article{ColpaniFilho2025BH4ASD,
  author   = {Colpani Filho, C and Melfior, L and Ramos, S L and Pizi, M S O and Taruhn, L F and Muller, M E and Nunes, T K and Schmitt, L O and Gaspar, J M and de Oliveira, M A and Tassinari, G and Cruz, L and Latini, A},
  title    = {Tetrahydrobiopterin and Autism Spectrum Disorder: {A} Systematic Review of a Promising Therapeutic Pathway},
  journal  = {Brain Sciences},
  year     = {2025},
  volume   = {15},
  number   = {2},
  pages    = {151},
  doi      = {10.3390/brainsci15020151},
  pmid     = {40002484},
  pmcid    = {PMC11853471},
  url      = {https://pubmed.ncbi.nlm.nih.gov/40002484/},
  keywords = {BH4, tetrahydrobiopterin, autism, ASD, GCH1, dopamine, serotonin, nitric oxide, neurotransmitter, neurodevelopmental},
  certainty = {0.60},
  research_stream = {lower-baseline-predisposition},
  note     = {Systematic review. Lower BH4 levels consistently found in biological samples from ASD individuals vs.\ controls. Elevated neopterin in plasma/urine but decreased in CSF; elevated NO. BH4 is cofactor for dopamine, serotonin, norepinephrine, and NO synthesis. BH4 supplementation shows potential to improve ASD symptoms. Connects to existing BH4-ME/CFS literature: shared GCH1 pathway may predispose ASD individuals to ME/CFS-like metabolic fragility.}
}

@article{DelRosso2026ironNeurodevelopmental,
  author   = {DelRosso, Lourdes M and Estrada Chaverri, Luis and Ceballos Fuentes, Francisco A},
  title    = {Iron Deficiency Across Neurodevelopmental Disorders: Comparative Insights from {ADHD} and Autism Spectrum Disorder},
  journal  = {Children (Basel)},
