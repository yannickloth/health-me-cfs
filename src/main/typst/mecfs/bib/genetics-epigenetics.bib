@article{BonnetFourel2026ProAB,
  author       = {Bonnet, Konstantinn Acen and Hulo, Nicolas and Mourad, Rapha{\"e}l and Ewing, Adam and Croce, Olivier and Naville, Magali and Vassetzky, Nikita and Gilson, Eric and Picard, Didier and Fourel, Genevi{\`e}ve},
