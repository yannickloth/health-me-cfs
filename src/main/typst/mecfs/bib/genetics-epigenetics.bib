  journal      = {Nature},
  year         = {2017},
  volume       = {547},
  pages        = {236--240},
  doi          = {10.1038/nature22822},
  keywords     = {HP1α, phase separation, liquid droplet, heterochromatin, phosphorylation, DNA binding},
  note         = {Demonstrates that human HP1α protein forms phase-separated droplets. Phosphorylation or DNA binding promotes HP1α partitioning from soluble phase into droplets; specific ligands can promote or reverse this. Nucleosomes and DNA preferentially partition into HP1α droplets. HP1α phase-separation mutant forms fewer and smaller nuclear foci in mammalian cells. Establishes the concentration-dependent nucleation threshold: below a critical HP1α concentration, no droplets form. Companion paper to Strom 2017. Certainty: 0.75 (Nature, independent lab, human protein).},
  research_stream = {methylation-vector-model},
  certainty    = {0.75}
}

