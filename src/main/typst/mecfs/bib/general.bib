@article{Yokoi2017,
  author  = {Yokoi, Katsuhiko and Konomi, Aki},
  title   = {Iron deficiency without anaemia is a potential cause of fatigue: meta-analyses of randomised controlled trials and cross-sectional studies},
  journal = {British Journal of Nutrition},
  year    = {2017},
  volume  = {117},
  number  = {10},
  pages   = {1422--1431},
  doi     = {10.1017/S0007114517001349},
  pmid    = {28625177},
  url     = {https://www.cambridge.org/core/journals/british-journal-of-nutrition/article/iron-deficiency-without-anaemia-is-a-potential-cause-of-fatigue},
  keywords = {iron deficiency without anemia, fatigue, meta-analysis, ferritin, reference range},
  note    = {Meta-analysis of 6 RCTs and 6 cross-sectional studies. RCT pool: iron supplementation significantly reduced fatigue in IDWA (effect size 0.33, p<0.0001). Cross-sectional pool: no significant association (effect size 0.10, p=0.362). Ferritin thresholds in included studies ranged from <12 to <50 µg/L, reflecting absence of consensus on functional cutoff.},
  research_stream = {general}
}

@article{Workinger2018,
  author  = {Workinger, Jayme L and Doyle, Robert P and Bortz, Jonathan},
  title   = {Challenges in the diagnosis of magnesium status},
  journal = {Nutrients},
  year    = {2018},
  volume  = {10},
  number  = {9},
  pages   = {1202},
  doi     = {10.3390/nu10091202},
  pmid    = {30200431},
  url     = {https://pmc.ncbi.nlm.nih.gov/articles/PMC6163803/},
  keywords = {magnesium, serum magnesium, intracellular magnesium, RBC magnesium, testing limitations, reference range, deficiency},
  note    = {Narrative review. Only ~1\% of body magnesium is in serum; 99\% is intracellular. Serum levels are tightly defended by renal excretion and do not reflect total body or tissue stores. No validated rapid test for true magnesium status exists. RBC magnesium is better proxy but not standardized. Estimated 45\% of Americans are magnesium-deficient by dietary standards.},
  research_stream = {general}
}

