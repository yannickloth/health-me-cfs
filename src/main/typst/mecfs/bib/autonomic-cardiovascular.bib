@article{acanfora2026vagaldenervation,
  author  = {Acanfora, Domenico and Nolano, Maria and Acanfora, Chiara and
             Colella, Camillo and Provitera, Vincenzo and Caporaso, Giuseppe and
             Rengo, Giuseppe and Antonelli Incalzi, Raffaele and Casucci, Gerardo},
  title   = {Vagal cholinergic denervation of the gastric mucosa in
             {Long-COVID-19}: in vivo evidence of structural autonomic dysfunction},
  journal = {International Journal of Infectious Diseases},
  year    = {2026},
  volume  = {152},
  pages   = {108973},
  doi     = {10.1016/j.ijid.2026.108973},
  pmid    = {42425362},
  note    = {Seed paper. n=12 Long COVID vs 8 dyspeptic controls. Gastric mucosal biopsies (fundus+antrum), IHC PGP9.5+VIP, Neurolucida 360 3D quantification. Fundus PGP 2.1 vs 3.9 nm/um3 (p<0.01), antrum 1.9 vs 3.9 (p<0.05). VIP (cholinergic) loss more pronounced fundus (p<0.01). IENF (skin) NOT different -> selective visceral autonomic involvement. Nerve density correlated with HRV LF/HF (R=0.50, p<0.05), NT-proBNP (R=0.52, p<0.01), D-dimer (R=0.61, p<0.01). Impaired HRV in LC (LF/HF 1.7 vs 1.1, rMSSD 15.3 vs 48.5, pNN50 0.8 vs 18.8, HF 3.8 vs 5.8 ln ms2; all p<0.01). 66% orthostatic intolerance. First in vivo morphological evidence of selective cholinergic denervation of gastric mucosa in Long COVID. Structural substrate for dysautonomia; disrupts cholinergic anti-inflammatory pathway (CAP).},
  research_stream = {vagal-gastric-denervation-longcovid},
  certainty    = {0.60}
}

@article{woo2023vagusinflammation,
  author  = {Woo, Marcel S and Shafiq, Mohsin and Fitzek, Antonia and
             Dottermusch, Matthias and Altmeppen, Hermann and Mohammadi, Behnam and
             Mayer, Christina and Bal, Lukas C and Raich, Lukas and
             Matschke, Jakob and Krasemann, Susanne and Pfefferle, Susanne and
             Brehm, Thomas Theo and L{\"u}tgehetmann, Marc and
             Sch{\"a}dler, Julia and Addo, Marylyn M and
             Schulze Zur Wiesch, Julian and Ondruschka, Benjamin and
             Friese, Manuel A and Glatzel, Markus},
  title   = {Vagus nerve inflammation contributes to dysautonomia in
             {COVID-19}},
  journal = {Acta Neuropathologica},
  year    = {2023},
  volume  = {146},
  number  = {3},
  pages   = {387--394},
  doi     = {10.1007/s00401-023-02612-x},
  pmid    = {37452829},
  pmcid   = {PMC10412500},
  note    = {Postmortem vagus nerve histopathology. n=not specified directly (autopsy cohort + clinical cohort n=323). SARS-CoV-2 RNA detected in vagus nerves with inflammatory cell infiltration (primarily monocytes). RNAseq showed strong inflammatory response in neurons, endothelial cells, Schwann cells correlating with viral RNA load. Clinical cohort: decreased respiratory rate in non-survivors of critical COVID-19. First direct histological evidence of SARS-CoV-2-induced vagus nerve inflammation. Provides anatomical substrate linking COVID-19 to dysautonomia and Long COVID.},
  research_stream = {vagal-gastric-denervation-longcovid},
  certainty    = {0.75}
}

@article{llados2024vagusdysfunction,
  author  = {Llad{\'o}s, Gemma and Massanella, Marta and Coll-Fern{\'a}ndez, Roser and
             Rodr{\'i}guez, Ra{\'u}l and Hern{\'a}ndez, Electra and
             Lucente, Giuseppe and L{\'o}pez, Cristina and Loste, Cora and
             Santos, Jos{\'e} Ram{\'o}n and Espa{\~n}a-Cueto, Sergio and
             Nevot, Maria and Mu{\~n}oz-L{\'o}pez, Francisco and
             Silva-Arrieta, Sandra and Brander, Christian and
             Dur{\`a}, Maria Jos{\'e} and Cuadras, Patricia and
             Bechini, Jordi and Tenesa, Montserrat and
             Martinez-Pi{\~n}eiro, Alicia and Herrero, Cristina and
             Chamorro, Anna and Garcia, Anna and Grau, Eulalia and
             Clotet, Bonaventura and Paredes, Roger and Mateu, Lourdes},
  title   = {Vagus nerve dysfunction in the post-{COVID-19} condition: a pilot
             cross-sectional study},
  journal = {Clinical Microbiology and Infection},
  year    = {2024},
  volume  = {30},
  number  = {4},
  pages   = {515--521},
  doi     = {10.1016/j.cmi.2023.11.007},
  pmid    = {37984511},
  note    = {Cross-sectional pilot. n=30 PCC with vagal symptoms vs 14 recovered COVID vs 16 never-infected. Neck ultrasound showed vagus nerve thickening/hyperechogenicity in PCC (CSA 2.4 vs 2.0 vs 1.9 mm2; p=0.08). Reduced esophageal-gastric-intestinal peristalsis (34% vs 0% vs 21%; p=0.02). Hemidiaphragm flattening (47% vs 6% vs 14%; p=0.007) and reduced maximum inspiratory pressure (62% vs 6% vs 17%; p<0.001) indicating phrenic nerve involvement. First structural imaging evidence of vagus nerve abnormalities in PCC.},
  research_stream = {vagal-gastric-denervation-longcovid},
  certainty    = {0.65}
}

@article{tracey2002inflammatoryreflex,
  author  = {Tracey, Kevin J},
  title   = {The inflammatory reflex},
  journal = {Nature},
  year    = {2002},
  volume  = {420},
  number  = {6917},
  pages   = {853--859},
  doi     = {10.1038/nature01321},
  pmid    = {12490958},
  note    = {Seminal review defining the cholinergic anti-inflammatory pathway (CAP). Discovery that vagus nerve efferent signalling inhibits pro-inflammatory cytokine release (TNF, IL-1, HMGB1) through alpha7 nicotinic acetylcholine receptor (α7nAChR) on macrophages. Established the concept of 'inflammatory reflex' — neural circuits reflexively regulate immune responses. Foundational for understanding how structural vagal damage (as in Acanfora 2026) would disinhibit inflammation. >3800 citations.},
  research_stream = {vagal-gastric-denervation-longcovid},
  certainty    = {0.85}
}

@article{bonaz2018vagusmicrobiota,
  author  = {Bonaz, Bruno and Bazin, Thomas and Pellissier, Sonia},
  title   = {The vagus nerve at the interface of the microbiota-gut-brain axis},
  journal = {Frontiers in Neuroscience},
  year    = {2018},
  volume  = {12},
  pages   = {49},
  doi     = {10.3389/fnins.2018.00049},
  pmid    = {29467611},
  note    = {Comprehensive review of vagal anti-inflammatory mechanisms. Vagus nerve is 80% afferent, 20% efferent fibres. Anti-inflammatory via HPA axis (afferent) and cholinergic anti-inflammatory pathway (efferent). Vagal efferents synapse with enteric neurons which release ACh onto macrophages via α7nAChR, inhibiting TNF release. Also activates splenic sympathetic anti-TNF pathway. Bioelectronic medicine (VNS) as anti-TNF therapy for IBD. Directly relevant to CAP disruption model.},
  research_stream = {vagal-gastric-denervation-longcovid},
  certainty    = {0.70}
}

@article{vanelzakker2013vagueinfection,
  author  = {VanElzakker, Michael B},
  title   = {Chronic fatigue syndrome from vagus nerve infection: a
             psychoneuroimmunological hypothesis},
  journal = {Medical Hypotheses},
  year    = {2013},
  volume  = {81},
  number  = {3},
  pages   = {414--423},
  doi     = {10.1016/j.mehy.2013.05.034},
  pmid    = {23790471},
  note    = {Influential hypothesis paper. Proposes ME/CFS results from vagus nerve infection: pathogen-infected vagal sensory ganglia/paraganglia generate exaggerated sickness behaviour signal via glial cell activation and sustained proinflammatory cytokine release to the brain. Explains symptom overlap with sickness behaviour (fatigue, myalgia, fever, depression, cognitive dysfunction). Resolves single-pathogen controversy: any pathogen infecting vagus nerve can cause ME/CFS. Directly anticipates Woo 2023 and Acanfora 2026 findings.},
  research_stream = {vagal-gastric-denervation-longcovid},
  certainty    = {0.40}
}

@article{josephoaklander2021mecfssfn,
  author  = {Joseph, Phillip and Arevalo, Carlo and Oliveira, Rudolf K F and
             Faria-Urbina, Mariana and Felsenstein, Donna and
             Oaklander, Anne Louise and Systrom, David M},
  title   = {Insights from invasive cardiopulmonary exercise testing of patients
             with myalgic encephalomyelitis/chronic fatigue syndrome},
  journal = {Chest},
  year    = {2021},
  volume  = {160},
  number  = {2},
  pages   = {642--651},
  doi     = {10.1016/j.chest.2021.01.082},
  pmid    = {33577778},
  note    = {n=160 ME/CFS patients meeting criteria + 36 controls. iCPET + PGP9.5 immunolabeled lower-leg skin biopsy (same PGP9.5 marker as Acanfora 2026). 31% of ME/CFS biopsies consistent with SFN (epidermal innervation ≤5th percentile of predicted; p<0.0001). Denervation severity did not correlate with exertional measures. Two types of peripheral neurovascular dysregulation identified: (1) depressed cardiac output from impaired venous return, (2) impaired peripheral O2 extraction. SFN-associated O2 shunting hypothesis. Establishes PGP9.5 IHC skin biopsy as method for detecting SFN in ME/CFS.},
  research_stream = {vagal-gastric-denervation-longcovid},
  certainty    = {0.70}
}


