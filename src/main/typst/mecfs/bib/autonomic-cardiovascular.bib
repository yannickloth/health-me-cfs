@article{Bu2026VNSReview,
  author  = {Bu, Yifeng and Liang, Alex and Hoffman, Benjamin U and Schiehser, Dawn M and Case, Oliver and Simmons, Alan and Klaming, Ruth and Gottfried-Blackmore, Andres and Mittal, Ravinder K and Puleo, Christopher and Lim, Hubert and Lerman, Imanuel},
  title   = {A Review of Vagus Nerve Stimulation for Disease: Comprehensive Theory and Evidence for Mechanisms of Action},
  journal = {Comprehensive Physiology},
  year    = {2026},
  volume  = {16},
  number  = {2},
  pages   = {e70109},
  doi     = {10.1002/cph4.70109},
  pmid    = {41781173},
  note    = {Comprehensive review of VNS mechanisms. Key contribution: cervical vagus cross-section (Figure 2A) demonstrates multi-fascicle architecture with heterogeneous fibre composition (A, B, and C fibres). Establishes that fibre recruitment follows biophysical thresholds: large myelinated A-fibres first (including laryngeal efferents explaining hoarse-throat side effect at low intensities), then B-fibres (preganglionic autonomic efferents shaping heart rate, bronchomotor tone, gut motility), and lastly C-fibres (visceral/nociceptive/inflammatory signals). Critical implication: VNS is not a volume dial but a fibre-selective neuromodulation problem — electrode geometry, pulse width, frequency, duty cycle, and waveform shape all determine which fibre classes are actually recruited. Studies reporting VNS effects on inflammation, cardiac function, or fatigue must specify which fibre classes were plausibly engaged under those parameters.},
  keywords = {vagus nerve stimulation, VNS, tVNS, fibre selectivity, neuromodulation, autonomic, A-fibre, B-fibre, C-fibre, cervical vagus, bioelectronic medicine, fascicular anatomy},
  research_stream = {autonomic-cardiovascular}
}

