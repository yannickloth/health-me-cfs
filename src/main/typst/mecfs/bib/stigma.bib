% --- Stigmatisation in ME/CFS ---

@article{Froehlich2022CausalStigma,
  author       = {Froehlich, Laura and Hattesohl, Daniel B R and Cotler, Joseph and
                  Jason, Leonard A and Scheibenbogen, Carmen and Behrends, Uta},
  title        = {Causal attributions and perceived stigma for myalgic
                  encephalomyelitis/chronic fatigue syndrome},
  journal      = {Journal of Health Psychology},
  year         = {2022},
  volume       = {27},
  number       = {10},
  pages        = {2291--2304},
  doi          = {10.1177/13591053211027631},
  pmid         = {34240650},
  pmcid        = {PMC9434257},
  keywords     = {ME/CFS, stigma, causal attributions, perceived stigma,
                  social roles, functional status},
  research_stream = {stigmatisation},
  certainty    = {0.72},
  note         = {n=499 self-diagnosed ME/CFS. Perceived stigma mediates
                  relationship between negative causal attributions and
                  lower satisfaction with social roles and functional status.
                  Higher attributions to controllable+unstable causes
                  predicted worse outcomes via higher perceived stigma.
                  Single study, adequate methodology, large sample.}
}

