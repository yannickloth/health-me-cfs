@article{Yamamoto2004serotonin,
  author = {Yamamoto, Shigeyuki and Ouchi, Yasuomi and Onoe, Hirotaka and Yoshikawa, Etsuji and Tsukada, Hideo and Takahashi, Hidetoshi and Iwase, Masao and Yamaguti, Kouzi and Kuratsune, Hirohiko and Watanabe, Yasuyoshi},
  title = {Reduction of serotonin transporters of patients with chronic fatigue syndrome},
  journal = {NeuroReport},
  year = {2004},
  volume = {15},
  number = {17},
  pages = {2571--2574},
  doi = {10.1097/00001756-200412030-00002},
  pmid = {15570154},
  url = {https://doi.org/10.1097/00001756-200412030-00002},
  keywords = {ME/CFS, serotonin transporter, 5-HTT, PET imaging, anterior cingulate cortex, neuroimaging},
  note = {PET imaging study using DASB ligand demonstrating significantly reduced serotonin transporter density in the rostral subdivision of the anterior cingulate cortex (ACC) in CFS patients compared to controls. One of the first direct demonstrations of serotonergic dysfunction in ME/CFS using in vivo neuroimaging. Supports the hypothesis that altered serotonin reuptake contributes to fatigue, mood, and cognitive symptoms.},
  research_stream = {neuroinflammation}
}

@article{deLange2004fMRI,
  author = {de Lange, Floris P. and Kalkman, Jo S. and Bleijenberg, Gijs and Hagoort, Peter and van der Werf, Silje P. and van der Meer, Jos W. M. and Toni, Ivan},
  title = {Neural correlates of the chronic fatigue syndrome---an {fMRI} study},
  journal = {Brain},
  year = {2004},
  volume = {127},
  number = {9},
  pages = {1948--1957},
  doi = {10.1093/brain/awh225},
  pmid = {15240435},
  url = {https://doi.org/10.1093/brain/awh225},
  keywords = {ME/CFS, fMRI, neural recruitment, motor imagery, brain activation, cognitive task},
  note = {fMRI study comparing 16 CFS patients with 16 healthy controls during motor and visual imagery tasks. CFS patients evoked stronger responses in visually related structures during motor imagery. Error-related brain activity differed between groups, suggesting motor planning dysfunction and motivational disturbances. Demonstrates that CFS involves recruitment of additional or atypical neural resources to achieve equivalent task performance, consistent with the concept of inefficient neural processing.},
  research_stream = {neuroinflammation}
}

@article{Kindlon2011GET,
  author = {Kindlon, Tom},
  title = {Reporting of Harms Associated with Graded Exercise Therapy and Cognitive Behavioural Therapy in Myalgic Encephalomyelitis/Chronic Fatigue Syndrome},
  journal = {Bulletin of the IACFS/ME},
  year = {2011},
  volume = {19},
  number = {2},
  pages = {59--111},
  keywords = {ME/CFS, graded exercise therapy, cognitive behavioural therapy, harms, adverse effects, patient survey, worsening, GET, CBT},
  note = {Systematic review of patient surveys and RCT reporting on harms from GET and CBT in ME/CFS. Meta-analysis of 10 patient surveys from four countries found 51\% of respondents reported GET worsened their health, versus 20\% for CBT. Highlights critical failure to report adverse events in trials. Essential reference for any discussion of GET safety in ME/CFS.},
  research_stream = {neuroinflammation}
}

@article{Noda2018glial,
  author = {Noda, Mami and Ifuku, Masataka and Hossain, Md Shamim and Katafuchi, Toshihiko},
  title = {Glial Activation and Expression of the Serotonin Transporter in Chronic Fatigue Syndrome},
  journal = {Frontiers in Psychiatry},
  year = {2018},
  volume = {9},
  pages = {589},
  doi = {10.3389/fpsyt.2018.00589},
  pmid = {30505285},
  pmcid = {PMC6250825},
  url = {https://pmc.ncbi.nlm.nih.gov/articles/PMC6250825/},
  keywords = {ME/CFS, glial activation, serotonin transporter, astrocyte, microglia, IL-1beta, neuroinflammation, blood-brain barrier},
  abstract = {Proposes a mechanistic pathway for immunologically-induced CFS: viral mimics increase blood-brain barrier permeability, activate microglia via TLR3 signaling, causing IL-1beta secretion. IL-1beta upregulates serotonin transporter (5-HTT) expression in astrocytes, reducing extracellular serotonin and impairing 5-HT1A receptor signaling. Neuroinflammation, especially via microglia and astrocyte activation, is proposed as a central mechanism in CFS pathogenesis.},
  research_stream = {neuroinflammation}
}

@article{Orr2009A2AMicroglia,
  author = {Orr, Anna G and Orr, Adam L and Li, Xiao-Jiang and Gross, Robert E and Traynelis, Stephen F},
  title = {Adenosine {A2A} receptor mediates microglial process retraction},
  journal = {Nature Neuroscience},
  year = {2009},
  volume = {12},
  number = {7},
  pages = {872--878},
  doi = {10.1038/nn.2341},
  pmid = {19525944},
  url = {https://doi.org/10.1038/nn.2341},
  keywords = {adenosine, A2A receptor, microglia, neuroinflammation, purinergic signaling, microglial activation},
  note = {Seminal Nature Neuroscience paper identifying that A2A adenosine receptor upregulation coincides with P2Y12 downregulation during microglial activation, causing chemotactic reversal: activated microglia retract their processes rather than extending toward ATP signals. Adenosine, as a breakdown product of extracellular ATP, drives A2A-mediated amoeboid transformation. Establishes the mechanistic link between elevated extracellular adenosine in neuroinflammation and microglial phenotype change. Directly relevant to ME/CFS neuroinflammation models.},
  research_stream = {neuroinflammation}
}

@article{Navia2020AdenosineReceptors,
  author = {Navia, Martina and others},
  title = {Adenosine Receptors as Neuroinflammation Modulators: Role of {A1} Agonists and {A2A} Antagonists},
  journal = {Cells},
  year = {2020},
  volume = {9},
  number = {7},
  pages = {1739},
  doi = {10.3390/cells9071739},
  pmid = {32708189},
  url = {https://doi.org/10.3390/cells9071739},
  keywords = {adenosine, A1 receptor, A2A receptor, neuroinflammation, antagonist, anti-inflammatory, mixed glial cells},
  note = {Demonstrates that A1 agonists prevent cytokine cocktail (TNF-alpha, IL-1beta, IFN-gamma) induced inflammation in mixed glial cells. A2A antagonism shows superior anti-inflammatory and antioxidant properties in both in vitro and in vivo neuroinflammation models. Authors conclude that A2A antagonism is a candidate therapeutic strategy for chronic neuroinflammation. Provides mechanistic rationale for A2A antagonist-based therapies in conditions with sustained neuroinflammation such as ME/CFS.},
  research_stream = {neuroinflammation}
}

@article{Chang2021AdenosineHomeostasis,
  author = {Chang, Ching-Pang and Wu, Kuo-Chen and Lin, Chien-Yu and Chern, Yijuang},
  title = {Emerging roles of dysregulated adenosine homeostasis in brain disorders with a specific focus on neurodegenerative diseases},
  journal = {Journal of Biomedical Science},
  year = {2021},
  volume = {28},
  number = {1},
  pages = {70},
  doi = {10.1186/s12929-021-00766-y},
  pmid = {34635103},
  url = {https://doi.org/10.1186/s12929-021-00766-y},
  keywords = {adenosine, adenosine homeostasis, ENT1, CD39, CD73, adenosine deaminase, A2A receptor, neuroinflammation, neurodegeneration},
  note = {Comprehensive review documenting that dysregulation of adenosine homeostasis through abnormal expression of ectonucleotidases (CD39, CD73), adenosine deaminase (ADA), and equilibrative nucleoside transporters (ENT1/ENT2) contributes to neuroinflammatory pathology across multiple brain disorders. Extracellular adenosine accumulation through impaired clearance mechanisms is a common finding. Establishes the framework for understanding how ME/CFS glial dysfunction could produce elevated basal adenosine and pathological sleep pressure. Adenosine functions as an endogenous anti-inflammatory agent whose dysregulation sustains microglial activation.},
  research_stream = {neuroinflammation}
}

@article{Nakatomi2014Neuroinflammation,
  author = {Nakatomi, Yasuhito and Mizuno, Kei and Ishii, Akira and Wada, Yoshiyuki and Tanaka, Masaaki and Tazawa, Shusaku and Onoe, Kayo and Fukuda, Sanae and Kawabe, Joji and Takahashi, Keiichiro and Kataoka, Yoshikatsu and Shiomi, Susumu and Yamaguti, Kouzi and Inaba, Michi and Kuratsune, Hirohiko and Watanabe, Yasuyoshi},
  title = {Neuroinflammation in Patients with Chronic Fatigue Syndrome/Myalgic Encephalomyelitis: An ${}^{11}${C}-(R)-{PK11195} {PET} Study},
  journal = {Journal of Nuclear Medicine},
  year = {2014},
  volume = {55},
  number = {6},
  pages = {945--950},
  doi = {10.2967/jnumed.113.131045},
  pmid = {24665088},
  url = {https://doi.org/10.2967/jnumed.113.131045},
  keywords = {ME/CFS, neuroinflammation, TSPO, PET, microglia, brain inflammation, cingulate cortex, hippocampus, amygdala, thalamus},
  note = {Landmark PET neuroimaging study demonstrating elevated translocator protein (TSPO) binding---a marker of microglial activation---in cingulate cortex, hippocampus, amygdala, thalamus, midbrain, and pons of ME/CFS patients vs. healthy controls (45--199\% higher BP values). Regional neuroinflammation correlated with cognitive impairment, pain, and depression severity. Provides direct in vivo evidence for the neuroinflammatory substrate that would drive A2A upregulation and adenosine dysregulation in ME/CFS. Study design: n=9 CFS/ME patients, n=10 controls.},
  research_stream = {neuroinflammation}
}

