@article{Balan2026taVNS,
  author  = {Balan, Adrian and Graham, Giles and Herban, Sorin and Marcu, Marius and Gheorghe, Nini and Mara, Gabriela and Rasinar, Florin Claudiu and Lascu, Ana and Mot, Cristian Ion and Dan, Traian Flavius and Mihaicuta, Stefan and Frent, Stefan Marian},
  title   = {Transcutaneous Auricular Vagus Nerve Stimulation for Post-COVID-19 Condition: A Systematic Review and Critical Appraisal of Clinical Evidence},
  journal = {Journal of Clinical Medicine},
  year    = {2026},
  volume  = {15},
  number  = {11},
  pages   = {4247},
  doi     = {10.3390/jcm15114247},
  pmid    = {42279108},
  pmcid   = {PMC13258778},
  note    = {PRISMA 2020 systematic review (PROSPERO: CRD420261287286). 5 studies (n=154), 3 RCTs + 2 single-arm. GRADE: efficacy "very low," safety "low." Only adequately double-blinded RCT found no between-group differences. Best-powered RCT (Percin 2025): sham > active taVNS for fatigue, despite HRV increases. 3/5 studies high RoB. Anchor citation for this research stream.},
  keywords = {taVNS, Long COVID, PCC, systematic review, GRADE, neuromodulation, dysautonomia, vagus nerve stimulation},
  research_stream = {tvns-pcc},
  certainty = {0.65}
}

