  year      = {2025},
  volume    = {24},
  number    = {10},
  pages     = {e70191},
  doi       = {10.1111/acel.70191},
  pmid      = {41061678},
  certainty = {0.60},
  research_stream = {taurine},
  note      = {NULL RESULT. n=137 men aged 20-93 (sedentary and active). No association between circulating taurine and age, muscle mass, strength, physical performance, or mitochondrial function. Directly contradicts Singh 2023 hypothesis in humans. Suggests species-specific effects; animal data may not translate directly. Critical caveat for any taurine-aging/fatigue hypothesis.}
}

@article{RossiSmith2025taurineNKA,
  author    = {Rossi-Smith, P and Kim, J and Skirlo, K and Ferris, T and Green, J P and Stek, C and Huse, K K and Mortimer, P M and Olona, A and Wieder, C and Moseki, R and Silva Dos Santos, M and MacRae, J I and Sriskandan, S and Ebbels, T M D and Wilkinson, R J and Denton, A E and Matheson, N J and Anand, P K and Meintjes, G and Thomas, D C and Lai, R P J},
  title     = {Taurine transport is a critical modulator of ionic fluxes during {NLRP3} inflammasome activation},
  journal   = {Cell Reports},
  year      = {2025},
  volume    = {44},
  number    = {10},
  pages     = {116317},
  doi       = {10.1016/j.celrep.2025.116317},
  pmid      = {40974575},
  certainty = {0.60},
  research_stream = {taurine},
  note      = {Mechanistic study (cell culture + tuberculosis patient cohort). Taurine exits cells via VRAC during inflammasome stimulation; intracellular depletion impairs Na/K-ATPase function, driving ionic dysregulation and NLRP3 activation and IL-1beta release. Blocking taurine efflux or supplementing taurine restores pump function and reduces inflammation. Directly relevant to AIMM cascade: Na/K-ATPase failure as downstream taurine-depletion consequence.}
}

@article{Suleiman1994taurineCardiac,
  author    = {Suleiman, M S},
  title     = {New concepts in the cardioprotective action of magnesium and taurine during the calcium paradox and ischaemia of the heart},
  journal   = {Magnesium Research},
  year      = {1994},
  volume    = {7},
  number    = {3--4},
  pages     = {295--312},
  pmid      = {7786694},
  certainty = {0.45},
  research_stream = {taurine},
  note      = {Review. Intracellular Na+ accumulation drives cardiac injury during calcium paradox via excessive Ca2+ loading (NCX reversal). Taurine protects via sodium efflux through taurine/sodium symport, maintaining ionic balance. Both taurine and Mg2+ act via Na/K-ATPase activity preservation. Classic mechanistic framework for taurine role upstream of NCX reversal. Foundational conceptual paper; predates modern molecular tools.}
}

