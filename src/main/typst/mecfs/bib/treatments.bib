}

@article{Singh2023taurineAging,
  author    = {Singh, Parminder and Gollapalli, Kishore and Mangiola, Stefano and Schumacher, Jonas and Adhikari, Pankaj and Garg, Dimpi and others},
  title     = {Taurine deficiency as a driver of aging},
  journal   = {Science},
  year      = {2023},
  volume    = {380},
  number    = {6649},
  pages     = {eabn9257},
  doi       = {10.1126/science.abn9257},
  pmid      = {37289866},
  certainty = {0.65},
  research_stream = {taurine},
  note      = {Multi-species landmark study. Taurine concentrations decline with age across mice, primates, and humans. Supplementation extended lifespan in rodents and improved healthspan in primates. Mechanisms: reduced cellular senescence, suppressed mitochondrial dysfunction, decreased DNA damage, attenuated inflammaging. Human clinical trials recommended. Partially contradicted by Marcangeli 2025 in human cohort.}
}

@article{Marcangeli2025taurineNull,
  author    = {Marcangeli, Vincent and Cefis, Marina and Hammad, Rami and Granet, Jordan and Leduc-Gaudet, Jean-Philippe and Gaudreau, Pierrette and Aubertin-Leheudre, Myl{\`e}ne and B{\'e}langer, Marc and Robitaille, Richard and Morais, Jos{\'e} A and Gouspillou, Gilles},
