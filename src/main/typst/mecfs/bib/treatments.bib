@article{Hochecker2025HyperthermiaMECFS,
  author       = {Hochecker, Barbara and Matt, Katja and Scherer, Melanie and
                  Me{\ss}mer, Alica and von Ardenne, Alexander and
                  Bergemann, J{\"o}rg},
  title        = {Heat vs. Fatigue: Hyperthermia as a Possible Treatment Option
                  for Myalgic Encephalomyelitis/Chronic Fatigue Syndrome
                  ({ME}/{CFS})},
  journal      = {International Journal of Molecular Sciences},
  year         = {2025},
  volume       = {26},
  number       = {11},
  pages        = {5339},
  doi          = {10.3390/ijms26115339},
  pmid         = {40508148},
  url          = {https://doi.org/10.3390/ijms26115339},
  keywords     = {ME/CFS, hyperthermia, whole-body hyperthermia, WBH,
                  autophagy, mitochondrial function, LC3-II, PBMCs,
                  thermal therapy, oxygenation},
  research_stream = {heat-cold-thermoregulation},
  certainty    = {0.55},
  note         = {Pilot study (n=9 ME/CFS patients, 38±10 years; 7F/2M).
                  Whole-body hyperthermia (WBH) to Tc max 39°C for 1 hour.
                  LC3-II autophagy marker decreased by 17.84% after WBH (p=0.0065);
                  ME/CFS basal levels 20.01% higher than healthy controls.
                  Mitochondrial respiration increased: basal +66.60% (p=0.0040),
                  ATP production +61.41% (p=0.0023), maximal +97.88% (p=0.0071),
                  spare capacity +112.35% (p=0.0086).
                  mRNA: HSPA5 (HSP70) increased 48.33%; IL-10 increased 37.33%.
                  Hypothesis: WBH restores oxygen supply via improved blood flow,
                  reducing hypoxia-induced autophagy and enhancing mitochondrial
                  function. All 9 participants showed response. Limitations:
                  very small sample, no standardized symptom measures,
                  treatment conditions not fully standardized (some patients
                  couldn't tolerate full protocol), only immediate effects
                  measured (no follow-up).}
}

@article{Stanculescu2021HeatStrokeMECFS,
  author       = {Stanculescu, Dominic and Sep{\'u}lveda, Nuno and
                  Lim, Chin Leong and Bergquist, Jonas},
  title        = {Lessons From Heat Stroke for Understanding Myalgic
                  Encephalomyelitis/Chronic Fatigue Syndrome},
  journal      = {Frontiers in Neurology},
  year         = {2021},
  volume       = {12},
  pages        = {789784},
  doi          = {10.3389/fneur.2021.789784},
  pmid         = {34966354},
  url          = {https://doi.org/10.3389/fneur.2021.789784},
  keywords     = {ME/CFS, heat stroke, pathophysiology, thermoregulation,
                  gut permeability, endotoxemia, systemic inflammation,
                  endothelial dysfunction, mitochondrial dysfunction,
                  heat shock proteins},
  research_stream = {heat-cold-thermoregulation},
  certainty    = {0.65},
  note         = {Narrative review comparing pathophysiological mechanisms
                  between heat stroke and ME/CFS. Shared mechanisms identified:
                  splanchnic vasoconstriction/hypoxia, gut permeability/leaky gut
                  (40-67% ME/CFS with elevated LPS antibodies), endotoxemia,
                  systemic inflammation (IL-6, TNF-α, NLRP3 inflammasomes),
                  CNS dysfunction/neuroinflammation, endothelial-cell injury,
                  mitochondrial dysfunction, heat shock protein deficiency.
                  Transcriptomic overlaps: heat stress downregulates
                  respiratory chain genes, switches to glycolysis, reduces ATP
                  production, increases oxidative stress—similar patterns
                  in ME/CFS PBMCs. Predisposing factor overlaps: pre-existing
                  inflammation/infection, viral reactivation (EBV, CMV),
                  immune suppression, cumulative stress, microbiome disturbances,
                  female predominance. Suggests therapeutic opportunities
                  from heat stroke research: gut barrier repair, anti-inflammatories,
                  anticoagulation, HSP induction. Provides framework for
                  understanding heat intolerance in ME/CFS.}
}

@article{Cambras2023SkinTemperatureEndothelin,
  author       = {Cambras, Trinitat and Castro-Marrero, Jes{\'u}s and
                  Zaragoza, Mar{\'i}a Carmen and D{\'i}ez-Noguera, Antoni and
                  Alegre, Jos{\'e}},
  title        = {Skin Temperature Circadian Rhythms and Dysautonomia in
                  Myalgic Encephalomyelitis/Chronic Fatigue Syndrome: The
                  Role of Endothelin-1 in the Vascular Tone Dysregulation},
  journal      = {International Journal of Molecular Sciences},
  year         = {2023},
  volume       = {24},
  number       = {5},
  pages        = {4835},
  doi          = {10.3390/ijms24054835},
  pmid         = {36902264},
  url          = {https://doi.org/10.3390/ijms24054835},
  keywords     = {ME/CFS, skin temperature, circadian rhythm, dysautonomia,
                  endothelin-1, ET-1, vascular tone, thermoregulation,
                  autonomic dysfunction},
  research_stream = {heat-cold-thermoregulation},
  certainty    = {0.60},
  note         = {Case-control study. ME/CFS patients exhibit modifications
                  in circadian rhythm of skin temperature. Circadian rhythm
                  alterations associated with endothelin-1 levels (p < 0.01).
                  ET-1 levels associated with temperature rhythm stability
                  and amplitude. Self-reported symptom questionnaires correlated
                  with ET-1 and temperature rhythm disruptions. Suggests vascular
                  tone dysregulation mediated by ET-1 underlies thermoregulatory
                  abnormalities. Links circadian disruption to vascular
                  dysfunction and autonomic failure. Provides potential biomarker
                  (ET-1) for thermoregulatory impairment. Sample size not clear
                  in available information; causality not established (ET-1 as
                  marker vs. driver).}
}

@article{Soejima2015WaonTherapyCFS,
  author       = {Soejima, Yuji and Munemoto, Takao and Masuda, Akinori and
                  Uwatoko, Yuuki and Miyata, Masaaki and Tei, Chuwa},
  title        = {Effects of Waon Therapy on Chronic Fatigue Syndrome:
                  A Pilot Study},
  journal      = {Internal Medicine},
  year         = {2015},
  volume       = {54},
  number       = {3},
  pages        = {333--338},
  doi          = {10.2169/internalmedicine.54.3042},
  pmid         = {25748743},
  url          = {https://doi.org/10.2169/internalmedicine.54.3042},
  keywords     = {CFS, chronic fatigue syndrome, Waon therapy, far-infrared
                  sauna, thermal therapy, fatigue, mood, performance status},
  research_stream = {heat-cold-thermoregulation},
  certainty    = {0.50},
  note         = {Pilot clinical trial (n=10 consecutive CFS inpatients).
                  Pre-post design (no control group). Waon therapy: far-infrared
                  dry sauna at 60°C for 15 minutes, followed by 30 minutes rest
                  under blanket. Frequency: once daily, 5 days/week for 4 weeks
                  (20 sessions total). Outcomes: perceived fatigue (NRS),
                  pain level (NRS), mood (Profile of Mood States), performance
                  status (CFS-specific scale). Results: perceived fatigue
                  significantly decreased after therapy (not at 2 weeks),
                  negative mood (anxiety, depression, fatigue) significantly
                  improved, performance status significantly improved,
                  pain levels and vigor did not change significantly,
                  no adverse effects reported. First evidence that passive heat
                  therapy may benefit ME/CFS without triggering PEM. Contrasts
                  with exercise-induced symptom exacerbation. Limitations:
                  very small sample (n=10), no control group, open-label,
                  no blinding, short duration (4 weeks), no follow-up after
                  treatment.}
}

