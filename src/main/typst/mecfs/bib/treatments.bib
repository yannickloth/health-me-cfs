  author  = {Percin, Aysun and Ozden, Ahmet Veli and Yenisehir, Selma and others},
  title   = {Effects of Transcutaneous Auricular Vagus Nerve Stimulation on Fatigue in Post-COVID Syndrome: A Randomized, Single-Blind, Sham-Controlled Study},
  journal = {International Journal of Clinical Practice},
  year    = {2025},
  volume  = {2025},
  pages   = {5641307},
  doi     = {10.1155/ijcp/5641307},
  note    = {Best-powered and most adequately blinded RCT in this domain (~n=50). Double-blind, sham-controlled. CRITICAL FINDING: sham stimulation produced significantly greater fatigue improvement than active taVNS, despite active taVNS producing significant HRV increases. FSS scores decreased in BOTH groups over time. Dissociation of autonomic engagement from clinical benefit.},
  keywords = {taVNS, post-COVID fatigue, sham-controlled, RCT, null result, paradoxical, HRV},
  research_stream = {tvns-pcc},
  certainty = {0.55}
}

