@article{MorrisMaes2014mitochondria,
  author   = {Morris, Gerwyn and Maes, Michael},
  title    = {Mitochondrial dysfunctions in myalgic encephalomyelitis/chronic fatigue syndrome explained by activated immuno-inflammatory, oxidative and nitrosative stress pathways},
  journal  = {Metabolic Brain Disease},
  year     = {2014},
  volume   = {29},
  number   = {1},
  pages    = {19--36},
  doi      = {10.1007/s11011-013-9435-x},
  pmid     = {24557875},
  keywords = {ME/CFS, mitochondrial dysfunction, oxidative stress, nitrosative stress, cytokines, ATP, electron transport chain, energy metabolism, ROS},
  note     = {Theoretical review establishing how activated immuno-inflammatory and oxidative/nitrosative stress pathways cause mitochondrial dysfunction in ME/CFS. Pro-inflammatory cytokines (IL-1, TNF-\(\alpha\)) and elastase inhibit mitochondrial respiration and decrease ETC activity and membrane potential. O\&NS damages mitochondrial DNA and membranes, reducing membrane fluidity. Lowered levels of antioxidants, zinc, CoQ10, and omega-3 PUFAs further aggravate pathways. Provides mechanistic framework linking inflammation to mitochondrial impairment and ATP deficiency.},
