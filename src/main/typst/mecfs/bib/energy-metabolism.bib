@article{ScheibenbogenWirth2024sarcopenia,
  author  = {Scheibenbogen, Carmen and Wirth, Klaus J.},
  title   = {Key Pathophysiological Role of Skeletal Muscle Disturbance in Post {COVID} and {Myalgic Encephalomyelitis/Chronic Fatigue Syndrome (ME/CFS)}: Accumulated Evidence},
  journal = {Journal of Cachexia, Sarcopenia and Muscle},
  year    = {2024},
  volume  = {16},
  number  = {1},
  pages   = {e13669},
  doi     = {10.1002/jcsm.13669},
  pmcid   = {PMC11671797},
  note    = {Comprehensive review: early PCS is dominated by microvascular disturbance (microclots, inflammatory capillary changes); mitochondrial damage appears later and selectively in patients who develop ME/CFS. Proposed transition mechanism: capillary hypoperfusion → ischemia/reperfusion → proton production → sodium-proton exchange → intracellular Na+ excess → NCX reversal → mitochondrial Ca2+ toxicity → mitochondrial damage. Low ATP and ROS then inhibit Na+/K+-ATPase creating a self-perpetuating cycle. Provides temporal evidence supporting vascular-primary causation.},
  keywords = {ME/CFS, post-COVID, skeletal muscle, microvascular, mitochondria, calcium toxicity, sodium, capillary, PEM, pathophysiology},
  research_stream = {energy-metabolism}
}

