  title        = {Mast Cells, Neuroinflammation and Pain in Fibromyalgia
                  Syndrome},
  journal      = {Frontiers in Cellular Neuroscience},
  year         = {2019},
  volume       = {13},
  pages        = {353},
  doi          = {10.3389/fncel.2019.00353},
  pmid         = {31427928},
  keywords     = {fibromyalgia, mast cell, substance P, hemokinin-1, CGRP,
                  neurogenic inflammation, MRGPRX2, IL-6, TNF,
                  inflammation-registry},
  research_stream = {inflammation-registry},
  certainty    = {0.65},
  note         = {Increased serum substance P and hemokinin-1 in FMS.
                  SP activates mast cells via MrgprB2/MRGPRX2 (non-IgE).
