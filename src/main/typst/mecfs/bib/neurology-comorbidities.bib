@article{Zametkin1990,
  author    = {Zametkin, Alan J and Nordahl, Thomas E and Gross, Martin and King, A Christina and Semple, William E and Rumsey, Judith and Hamburger, Susan and Cohen, Robert M},
  title     = {Cerebral glucose metabolism in adults with hyperactivity of childhood onset},
  journal   = {New England Journal of Medicine},
  year      = {1990},
  volume    = {323},
  number    = {20},
  pages     = {1361--1366},
  doi       = {10.1056/NEJM199011153232001},
  pmid      = {2233902},
  url       = {https://pubmed.ncbi.nlm.nih.gov/2233902/},
  keywords  = {ADHD, PET, glucose metabolism, prefrontal cortex, hypometabolism, brain energy},
  certainty = {0.80},
  research_stream = {adhd-energy-mecfs},
  note      = {Seminal PET [18F]FDG study (n=25 ADHD adults vs n=50 controls). Global cerebral glucose metabolism 8.1\% lower in ADHD adults; largest reductions in premotor cortex and superior prefrontal cortex—areas controlling attention and motor activity. Significant reduction in 30/60 brain regions. Foundational evidence for ADHD as a brain energy/metabolic deficit disorder. Relevant to ME/CFS predisposition hypothesis: pre-existing prefrontal hypometabolism lowers the metabolic reserve threshold above which infection-triggered neuroinflammation produces sustained ME/CFS phenotype.}
}

@article{Quadt2024neurodivergentfatigue,
  author    = {Quadt, Lisa and Csecs, Jenny and Bond, Robert and others},
  title     = {Childhood neurodivergent traits, inflammation and chronic disabling fatigue in adolescence: a longitudinal case-control study},
  journal   = {BMJ Open},
  year      = {2024},
  volume    = {14},
  number    = {7},
  pages     = {e084203},
  doi       = {10.1136/bmjopen-2024-084203},
  pmid      = {39038862},
  url       = {https://pubmed.ncbi.nlm.nih.gov/39038862/},
  keywords  = {ADHD, autism, neurodivergent, chronic fatigue, IL-6, inflammation, ALSPAC, cohort, adolescence},
  certainty = {0.75},
  research_stream = {adhd-energy-mecfs},
  note      = {ALSPAC longitudinal case-control (n=8,036--8,115 at ages 7--9; n=4,563 at age 18). ADHD traits: OR=2.18 (95\% CI 1.33--3.56, p=0.002) for chronic disabling fatigue at age 18. Autism traits: OR=1.78 (95\% CI 1.17--2.72, p=0.004). IL-6 at age 9 mediated the relationship independently of depressive symptoms. Most recent and largest prospective evidence linking neurodivergent traits to adolescent fatigue. Caution: fatigue outcome is "chronic disabling fatigue" not full ME/CFS diagnostic criteria.}
}

@article{SaezFrancas2012adhdcfs,
  author    = {S{\'a}ez-Franc{\`a}s, Naia and Alegre, Jos{\'e} and Calvo, Neus and others},
  title     = {Attention-deficit hyperactivity disorder in chronic fatigue syndrome patients},
  journal   = {Psychiatry Research},
  year      = {2012},
  volume    = {200},
  number    = {2--3},
  pages     = {748--753},
  doi       = {10.1016/j.psychres.2012.04.041},
  pmid      = {22648008},
  url       = {https://pubmed.ncbi.nlm.nih.gov/22648008/},
  keywords  = {ADHD, CFS, adult, comorbidity, childhood ADHD, fatigue severity, depression, suicide},
  certainty = {0.55},
  research_stream = {adhd-energy-mecfs},
  note      = {Cross-sectional study of 158 adult CFS patients. 29.7\% had childhood ADHD; 20.9\% had persistent adult ADHD. CFS patients with comorbid adult ADHD showed earlier onset, more anxiety and depression, and higher suicide risk. Depressive symptoms and ADHD severity were significant independent predictors of fatigue intensity. Primary source for the ~30\% childhood ADHD prevalence figure in CFS; note that bib key Rimes2015adhdcfs may overlap with this data.}
}

@article{Yokokura2021D1Rmicroglia,
  author    = {Yokokura, Masamichi and Takedera, Kenji and Kazumata, Ken and others},
  title     = {In vivo imaging of dopamine {D1} receptor and activated microglia in attention-deficit/hyperactivity disorder: a positron emission tomography study},
  journal   = {Molecular Psychiatry},
  year      = {2021},
  volume    = {26},
  number    = {9},
  pages     = {4958--4967},
  doi       = {10.1038/s41380-020-0784-1},
  pmid      = {32439845},
  url       = {https://pubmed.ncbi.nlm.nih.gov/32439845/},
  keywords  = {ADHD, D1R, dopamine, microglia, PET, ACC, prefrontal cortex, neuroinflammation},
  certainty = {0.62},
  research_stream = {adhd-energy-mecfs},
  note      = {Dual-tracer PET study (n=24 ADHD vs n=24 controls; drug-naive). Decreased D1R in anterior cingulate cortex (ACC), correlated with hyperactivity severity. Increased activated microglia in DLPFC and orbitofrontal cortex; correlated with processing speed deficits and attentional impairment. In ADHD only: positive correlation between D1R reduction and microglial activation. First in vivo co-imaging of dopaminergic deficit and neuroinflammation in same subjects; mechanistically bridges the shared ME/CFS--ADHD pathway.}
}

@article{Moffitt2015adhdadult,
  author    = {Moffitt, Terrie E and Houts, Renate and Asherson, Philip and Belsky, Daniel W and Corcoran, David L and others},
  title     = {Is adult {ADHD} a childhood-onset neurodevelopmental disorder? {Evidence} from a four-decade longitudinal cohort study},
  journal   = {American Journal of Psychiatry},
  year      = {2015},
  volume    = {172},
  number    = {10},
  pages     = {967--977},
  doi       = {10.1176/appi.ajp.2015.14101266},
  pmid      = {25998281},
  url       = {https://pubmed.ncbi.nlm.nih.gov/25998281/},
  keywords  = {ADHD, adult ADHD, childhood onset, developmental, Dunedin cohort, longitudinal, neurodevelopmental},
  certainty = {0.70},
  research_stream = {adhd-energy-mecfs},
  note      = {Dunedin birth cohort (n=1,037; 95\% retention to age 38). 90\% of adult ADHD cases had no childhood ADHD. Only 5\% of childhood ADHD cases met adult criteria at age 38. Adult-onset group showed no neuropsychological deficits and no polygenic risk for childhood ADHD. Challenges purely developmental framing; relevant to ME/CFS: "adult-onset ADHD" may in some cases represent acquired catecholaminergic depletion compatible with post-infectious trajectory. Controversy: findings contested by studies showing higher childhood-adult continuity.}
}

@article{Williams2025GCH1BH4,
  author    = {Williams, Grant E and Hausman-Cohen, Sharon and Sotos, Maryelaine and Gutierrez, Emily and Bilich, Carol and Mueller, Francis W and Jagshi, Shaun},
  title     = {The role of {GCH1} deficiency and tetrahydrobiopterin in mental health},
  journal   = {International Journal of Molecular Sciences},
  year      = {2025},
  volume    = {26},
  number    = {16},
  pages     = {8030},
  doi       = {10.3390/ijms26168030},
  pmid      = {40869351},
  url       = {https://pubmed.ncbi.nlm.nih.gov/40869351/},
  keywords  = {BH4, tetrahydrobiopterin, GCH1, ADHD, dopamine, norepinephrine, catecholamine, attention, mental health},
  certainty = {0.40},
  research_stream = {adhd-energy-mecfs},
  note      = {Narrative review + case reports. GCH1 rs841 homozygous variant associated with ADHD traits (impaired sustained attention and vigilance). GCH1 encodes the rate-limiting enzyme for BH4 synthesis; BH4 is essential cofactor for tyrosine hydroxylase (dopamine/NE), tryptophan hydroxylase (serotonin), and all NOS isoforms. Five case reports showing ADHD improvement with low-dose BH4 supplementation (0.088--0.292~mg/kg/day). Important mechanistic link connecting BH4 bottleneck to both ADHD and ME/CFS catecholamine deficit. Caution: COI risk (authors affiliated with genomic testing companies); clinical evidence is anecdotal.}
}

@article{Berthier2025cbfadhd,
  author    = {Berthier, J and Endomba, Francky Teddy and Lecendreux, Michel and others},
  title     = {Cerebral blood flow in attention deficit hyperactivity disorder: a systematic review},
  journal   = {Neuroscience},
  year      = {2025},
  volume    = {567},
  pages     = {67--76},
  doi       = {10.1016/j.neuroscience.2024.11.075},
  pmid      = {39631658},
  url       = {https://pubmed.ncbi.nlm.nih.gov/39631658/},
  keywords  = {ADHD, cerebral blood flow, SPECT, ASL, PET, perfusion, prefrontal, basal ganglia, methylphenidate},
  certainty = {0.62},
  research_stream = {adhd-energy-mecfs},
  note      = {Systematic review of 20 studies (n=1,652 ADHD, n=580 controls; SPECT, ASL, PET, BOLD-derived). Resting state: hypoperfusion in right orbitofrontal gyrus, temporal cortex, basal ganglia, putamen. Concurrent hyperperfusion in frontal, postcentral, occipital regions. Task state: hyperperfusion in frontal, cingulate, precuneus. Methylphenidate normalises striatal and thalamic blood flow. Converges with ME/CFS cerebral hypoperfusion literature; supports shared vascular-metabolic vulnerability hypothesis.}
}

@article{Almutairi2024mitoadhd,
  author    = {Almutairi, Mohammed M and Althekair, Abdulrahman and Almutairi, Fahad and Alatabani, Mohammed and Alsaikhan, Abdulaziz},
  title     = {Mitochondrial dysfunction and mitophagy in {ADHD}: Cellular and molecular mechanisms},
  journal   = {Saudi Pharmaceutical Journal},
  year      = {2024},
  volume    = {32},
  number    = {12},
  pages     = {102212},
  doi       = {10.1016/j.jsps.2024.102212},
  pmcid     = {PMC11664080},
  url       = {https://pmc.ncbi.nlm.nih.gov/articles/PMC11664080/},
  keywords  = {ADHD, mitochondria, mitophagy, oxidative stress, ATP, energy metabolism, methylphenidate, NDUFAF2, UCP2},
  certainty = {0.35},
  research_stream = {adhd-energy-mecfs},
  note      = {Narrative review. Decreased mitochondrial membrane potential and impaired oxidative phosphorylation in ADHD. Genetic variants in NDUFAF2 (Complex~I assembly), UCP2, and mitochondrial organization genes (Prps18c, Letm1, Uqcrc2) correlated with reduced respiratory capacity. Methylphenidate increases Parkin and reduces ROS. Monoaminergic gene variants (DAT, DRD4, SERT, NET) interact with mitochondrial dysfunction. Establishes mitochondrial energy failure as plausible ADHD mechanism parallel to ME/CFS literature. Caution: mostly preclinical; human data is limited.}
}

@article{Fanet2021BH4neuro,
  author    = {Fanet, Ha{\"i}l and Capuron, Lucile and Castanon, Nathalie and Calon, Fr{\'e}d{\'e}ric and Vancassel, Sylvie},
  title     = {Tetrahydrobiopterin ({BH4}) pathway: from metabolism to neuropsychiatry},
  journal   = {Current Neuropharmacology},
  year      = {2021},
  volume    = {19},
  number    = {5},
  pages     = {591--609},
  doi       = {10.2174/1570159X18666200729103529},
  pmid      = {32744952},
  url       = {https://pubmed.ncbi.nlm.nih.gov/32744952/},
  keywords  = {BH4, tetrahydrobiopterin, dopamine, serotonin, nitric oxide, neuropsychiatry, inflammation, oxidative stress, tyrosine hydroxylase},
  certainty = {0.50},
  research_stream = {adhd-energy-mecfs},
  note      = {Narrative review. BH4 cofactor for TH (dopamine/NE synthesis), TPH (serotonin synthesis), and all three NOS isoforms. Inflammatory cytokines paradoxically increase BH4 synthesis but drive its oxidation, causing net monoamine depletion. Reduced CSF BH4 associated with depression, Parkinson's, Alzheimer's, ADHD, autism. BH4 also has anti-inflammatory and anti-oxidant roles independent of neurotransmitter synthesis. Mechanistic bridge: infection/neuroinflammation → BH4 oxidative depletion → catecholamine deficiency → both ADHD-like and ME/CFS symptoms. Complements existing BH4 entries in bib (orthostatic intolerance).}
}

