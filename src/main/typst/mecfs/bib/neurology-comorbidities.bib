@article{moustardas2026ocular,
  author       = {Moustardas, Petros and Setterud, Helen and Meijer, Helena and Andersson, Gunnel and Roth, Jenny and Dashti, Ava and Johansson, Björn and Macedo, António Filipe and Lagali, Neil},
  title        = {Long-term ocular symptoms following {COVID-19} linked to immune dysregulation, dysautonomia and peripheral neuropathy},
  journal      = {Nature Communications},
  year         = {2026},
  volume       = {17},
  number       = {1},
  pages        = {5624},
  doi          = {10.1038/s41467-026-74858-4},
  pmid         = {42420292},
  note         = {Prospective cross-sectional study (n=100 non-hospitalised post-mild-COVID with 3mo-3yr ocular symptoms, n=32 mild-COVID controls without ocular symptoms). 1 in 3 on full/part-time sick leave. Standard ophthalmic exams normal; abnormalities only on specialised testing. Findings: near vision disturbances, adult-onset strabismus, impaired pupillary reflexes, corneal neurodegeneration, chronic dendritic/T-cell activation. Tear proteomics: CD4+ T-cell dysregulation signature matching severe/fatal COVID tissue patterns. Diagnostic models: 77-91% accuracy. Interpretation: immune dysregulation + dysautonomia + peripheral neuropathy manifesting in the eye.},
  research_stream = {postcovid-ocular-syndrome},
  certainty    = {0.75}
}

@article{smit2026pupillary,
  author       = {Smit, Alexander and Fleischmann, Philipp and Knauer, Thomas S and Mardin, Christian Y and Michelson, Georg and Zott, Julia and Güttes, Moritz and Sarmiento, Helena and Ilgner, Miriam and Jakobi, Marie and Rech, Jürgen and Hohberger, Bettina},
  title        = {Task-evoked pupillary dynamics are altered in post-{COVID} syndrome},
  journal      = {Medical Sciences},
  year         = {2026},
  volume       = {14},
  number       = {2},
  pages        = {269},
  doi          = {10.3390/medsci14020269},
