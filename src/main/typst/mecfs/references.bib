}

@article{Abdulrazzaq2022H3receptor,
  author = {Abdulrazzaq, Yousef M. and Bastaki, Salim M. A. and Adeghate, Ernest},
  title = {Histamine {H3} receptor antagonists -- Roles in neurological and endocrine diseases and diabetes mellitus},
  journal = {Biomedicine \& Pharmacotherapy},
  year = {2022},
  volume = {150},
  pages = {112947},
