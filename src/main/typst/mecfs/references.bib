@article{Gotts2015napCFS,
  author       = {Gotts, Zoe M. and Ellis, Jason G. and Deary, Vincent and Barclay, Nicola L. and Newton, Julia L.},
  title        = {The association between daytime napping and cognitive functioning in chronic fatigue syndrome},
  journal      = {PLoS ONE},
  year         = {2015},
  volume       = {10},
  number       = {1},
  pages        = {e0117136},
  doi          = {10.1371/journal.pone.0117136},
  pmid         = {25575044},
