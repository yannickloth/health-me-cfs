@article{Powers2021interoceptiveprecision,
  author  = {Smith, Ryan and Kuplicki, Rayus and Feinstein, Justin S and Forthman, Karen L and Stewart, Jennifer L and Paulus, Martin P and {Tulsa 1000 Investigators}},
  title   = {A Bayesian computational model reveals a failure to adapt interoceptive precision estimates across depression, anxiety, eating, and substance use disorders},
  journal = {PLOS Computational Biology},
  year    = {2020},
  volume  = {16},
  number  = {12},
  pages   = {e1008484},
  doi     = {10.1371/journal.pcbi.1008484},
  pmid    = {33382688},
  keywords = {interoception, precision, Bayesian, transdiagnostic, depression, anxiety, eating disorders, substance use, heartbeat, computational psychiatry},
  note    = {N=1,403 (Tulsa 1000 study). Used hierarchical Gaussian filter models during heartbeat counting and breath-holding perturbation tasks. All four clinical groups (depression, anxiety, eating disorders, substance use) showed transdiagnostic failure to adaptively update interoceptive precision estimates during perturbation, unlike healthy controls who dynamically increased precision-weighting on ascending cardiac signals. Foundational for understanding precision-weighting failure as a transdiagnostic mechanism applicable to ME/CFS interoceptive dysfunction.}
}

@article{Seth2016interoceptive,
  author  = {Seth, Anil K and Critchley, Hugo D},
  title   = {Active interoceptive inference and the emotional brain},
  journal = {Philosophical Transactions of the Royal Society B: Biological Sciences},
  year    = {2016},
  volume  = {371},
  number  = {1708},
