@article{GuoRBC2025microfluidic,
  author  = {Guo, Yuanbin and Zhou, Sitong and Ren, Shujie and Liu, Xin and Nemat-Gorgani, Mohsen and Gresser, Michael J. and Davis, Ronald W. and Wan, Jiandi},
  title   = {Microfluidic Assessment of {PO2}-Regulated {RBC} Capillary Velocity in {ME/CFS}},
  journal = {Blood: Red Cells \& Iron},
  year    = {2025},
  volume  = {1},
  number  = {3},
  pages   = {100019},
  doi     = {10.1182/bloodrci.2024.100019},
  note    = {Using microfluidic capillaries (5.05 μm × 5.94 μm, mimicking real capillaries) under reduced PO2 (0–34 mmHg), ME/CFS patient RBCs showed significantly compromised capillary velocity compared to healthy controls. Hypoxia-sensing mechanism of RBCs — normally triggering vasodilation and increased flow — is impaired in ME/CFS. Provides strong evidence for a cell-autonomous defect in oxygen delivery independent of tissue mitochondrial state.},
  keywords = {ME/CFS, red blood cells, capillary, microfluidics, oxygen, PO2, deformability, hypoxia sensing}
}

@article{RogersRBC2024covidoxygen,
  author  = {Rogers, Steven C. and Brummet, Marguerite and Safari, Zahra and Wang, Qilong and Rowden, Thomas and Boyer, Tyler and Doctor, Allan},
  title   = {{COVID-19} impairs oxygen delivery by altering red blood cell hematological, hemorheological, and oxygen transport properties},
