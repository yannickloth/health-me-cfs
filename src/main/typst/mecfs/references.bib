  journal = {Diagnostics},
  year = {2025},
  volume = {15},
  number = {22},
  pages = {2828},
  doi = {10.3390/diagnostics15222828},
  pmid = {41300853},
  keywords = {ME/CFS, mast cell activation, MCAS, orthostatic intolerance, POTS},
  certainty = {0.62},
  research_stream = {septad-diagnostic-map, mcas-isr},
  note = {Two-cohort study (n=687+383 ME/CFS patients). MCAS prevalence 16.7\% post-ME/CFS onset; 25.3\% met broader clinical MCA criteria. MCAS+ME/CFS patients had higher OI rates (89\% vs.\ 72\%, p<0.0001). Mediator lab testing in only 3.1\%. Mast cell-targeted therapy significantly more effective in MCAS+ME/CFS vs MCAS-negative (p<0.0001). Establishes MCAS as clinically relevant, therapeutically targetable ME/CFS subgroup. Supports MCAS--ISR crosstalk hypothesis: MCAS drives ER stress and potentially ISR activation via repeated degranulation cycles; no ISR biomarkers measured. Certainty revised upward from 0.52 to 0.62 to reflect full cohort analysis (2026-05-02).}
}

