  note = {Critical methodological review of neuroinflammation measurement in ME/CFS (PET, MRS, cytokine assays). Key argument: most neuroimaging studies inadequately target the brainstem despite its probable centrality to neuroinflammatory causes. Significant methodological inconsistencies undermine reliability of peripheral cytokine profiling. Essential reference for interpreting the heterogeneous neuroinflammation literature.}
}

@article{RenzPolster2022,
  author = {Renz-Polster, Herbert and Tremblay, Marie-Eve and Bienzle, Dorothee and Fischer, Johannes E},
  title = {The Pathobiology of Myalgic Encephalomyelitis/Chronic Fatigue Syndrome: The Case for Neuroglial Failure},
  journal = {Frontiers in Cellular Neuroscience},
  year = {2022},
  volume = {16},
  pages = {888232},
  doi = {10.3389/fncel.2022.888232},
  pmid = {35614970},
  pmcid = {PMC9126235},
  url = {https://pubmed.ncbi.nlm.nih.gov/35614970/},
  keywords = {ME/CFS, microglia, astrocytes, oligodendrocytes, neuroglial failure, neuroinflammation, post-exertional malaise, Long COVID},
  note = {Comprehensive hypothesis paper arguing that impaired or pathologically reactive neuroglia (astrocytes, microglia, oligodendrocytes) represent the common pathobiological denominator in ME/CFS. Proposes neuroglial dysfunction explains PEM, reduced cerebral blood flow, and cognitive symptoms. Mechanistic detail on microglial reactivity states (M1/M2-like), complement activation, synaptic pruning dysregulation, and relevance to Long COVID. High-quality theoretical synthesis.}
}

@article{Gottschalk2022ATG13,
  author = {Gottschalk, Carl G and Peterson, Daniel and Knox, Konstance and Maynard, Mary and Whelan, Robert J},
  title = {Elevated {ATG13} in serum of patients with {ME/CFS} stimulates oxidative stress response in microglial cells via activation of receptor for advanced glycation end products ({RAGE})},
  journal = {Molecular and Cellular Neuroscience},
  year = {2022},
  volume = {120},
  pages = {103731},
  doi = {10.1016/j.mcn.2022.103731},
  pmid = {35487443},
  url = {https://pubmed.ncbi.nlm.nih.gov/35487443/},
  keywords = {ME/CFS, microglia, ATG13, autophagy, RAGE, oxidative stress, reactive oxygen species, neuroinflammation, serum},
  note = {Mechanistic study demonstrating ME/CFS patient serum stimulates reactive oxygen species (ROS) and nitric oxide production in human HMC3 microglial cells. ATG13 (autophagy-related protein 13), elevated in ME/CFS serum, activates RAGE receptors to trigger microglial oxidative stress; ATG13 neutralization substantially reduced this response. Provides direct ex vivo evidence for circulating factors driving microglial activation in ME/CFS.}
}

@article{Miwa2021minocycline,
  author = {Miwa, Kunihisa},
  title = {Oral Minocycline Therapy Improves Symptoms of Myalgic Encephalomyelitis, Especially in the Initial Disease Stage},
  journal = {Internal Medicine},
  year = {2021},
  volume = {60},
  number = {16},
  pages = {2577--2584},
  doi = {10.2169/internalmedicine.6082-20},
  pmid = {33896862},
  url = {https://pubmed.ncbi.nlm.nih.gov/33896862/},
  keywords = {ME/CFS, myalgic encephalomyelitis, minocycline, neuroinflammation, microglia, treatment, open-label},
  note = {Open-label prospective study of oral minocycline (100 mg/day for 42 days) in 100 ME patients. Favorable response (performance status improvement ≥2 points) in 27 patients (27\%); best response in patients within 6 months of disease onset. Rationale: minocycline attenuates microglial activation and exerts anti-inflammatory, neuroprotective effects. 38\% discontinued due to adverse effects (nausea, dizziness). No control group. Low certainty due to design.}
}

@article{Numata2021minocycline,
  author = {Numata, Takehiro},
  title = {Could Minocycline Be a ``Magic Bullet'' for the Treatment of Myalgic Encephalomyelitis/Chronic Fatigue Syndrome?},
  journal = {Internal Medicine},
  year = {2021},
  volume = {60},
  number = {16},
  pages = {2527--2528},
  doi = {10.2169/internalmedicine.7182-21},
  pmid = {33814504},
  url = {https://pubmed.ncbi.nlm.nih.gov/33814504/},
  keywords = {ME/CFS, minocycline, microglia, neuroinflammation, heterogeneity, personalized medicine, commentary},
  note = {Editorial commentary on Miwa 2021 minocycline trial. Acknowledges minocycline's mechanism (microglial suppression, anti-inflammatory, neuroprotective) as theoretically sound for ME/CFS neuroinflammation. Argues against "magic bullet" framing due to disease heterogeneity. Advocates stratified patient classification by onset, duration, and confirmed pathology before testing targeted interventions.}
}

