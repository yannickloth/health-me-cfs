}

@article{Park2023AMPK,
  author       = {Park, Ji-Man and Lee, Da-Hye and Kim, Do-Hyung},
  title        = {Redefining the role of {AMPK} in autophagy and the energy stress response},
  journal      = {Nature Communications},
  year         = {2023},
  volume       = {14},
  number       = {1},
  pages        = {2994},
  doi          = {10.1038/s41467-023-38401-z},
  pmid         = {37225695},
  pmcid        = {PMC10209092},
  url          = {https://doi.org/10.1038/s41467-023-38401-z},
  keywords     = {AMPK, autophagy, ULK1, LKB1, energy stress, mitochondria, cell biology},
  certainty    = {0.65},
  research_stream = {ans-aging},
  note         = {Cell/mouse study. AMPK has dual role: inhibits ULK1 (suppresses autophagy during energy depletion via LKB1-AMPK axis) while protecting autophagy machinery from caspase degradation. Challenges prior model that AMPK promotes autophagy. Study used HCT116, HEK293T, MEFs, HeLa cells and mouse liver/muscle. Nature Communications. ME/CFS relevance: if PKA/cAMP (from SNS activation) inhibits AMPK, this cascades to blocked autophagy — mitochondrial quality control impaired, consistent with ME/CFS mitochondrial dysfunction.}
}

@article{Rajeevan2018telomere,
  author       = {Rajeevan, Mangalathu S. and Murray, Janna and Oakley, Lisa and Lin, Jin-Mann S. and Unger, Elizabeth R.},
