@article{Pall2001CommonEtiology,
  author = {Pall, Martin L},
  title = {Common Etiology of Posttraumatic Stress Disorder, Fibromyalgia, Chronic Fatigue Syndrome and Multiple Chemical Sensitivity via Elevated Nitric Oxide/Peroxynitrite},
  journal = {Medical Hypotheses},
  year = {2001},
  volume = {57},
  number = {2},
  pages = {139--145},
  doi = {10.1054/mehy.2001.1325},
  pmid = {11461161},
  keywords = {ME/CFS, fibromyalgia, PTSD, multiple chemical sensitivity, nitric oxide, peroxynitrite, NO/ONOO cycle, common etiology},
  note = {Extension of Pall 2000 hypothesis proposing NO/ONOO- vicious cycle as common etiology for CFS, FM, MCS and PTSD. Evidence: shared symptoms, frequent comorbidity, common short-term stressor induction, similar biochemical findings. Six positive feedback loops proposed to sustain elevated peroxynitrite. Mechanism: iNOS induction by stressors -> NO + superoxide -> peroxynitrite -> NF-kB activation -> more iNOS. Medical Hypotheses -- low certainty, not empirically tested in RCTs.}
}

