  year = {2021},
  volume = {7},
  number = {1--2},
  pages = {19--33},
  doi = {10.1159/000515066},
  pmid = {35141700},
  keywords = {kynurenine pathway, KMO inhibitor, kynurenic acid, NMDA receptor, galantamine, memantine, IDO inhibitor, neuropsychiatric, tryptophan},
  note = {Reviews therapeutic strategies targeting the kynurenine pathway to reduce quinolinic acid excitotoxicity. KMO inhibitors reduce QUIN while raising kynurenic acid (KYNA). KYNA blocks NMDA receptors at the glycine-B site and GluN2 subunit. Galantamine-memantine combination may complement KP enzyme inhibitors. Relevant to ME/CFS treatment implications for IDO inhibition and NMDA modulation.}
}

