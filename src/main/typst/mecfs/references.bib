@article{Banellis2025bodywandering,
  author  = {Banellis, Leah and Nikolova, Niia and Br{\ae}ndholdt, Malthe and Vejl{\o}, Melina and Fardo, Francesca and Smallwood, Jonathan and Allen, Micah G},
  title   = {Body-wandering reveals an embodied dimension of thought with distinct affective and neural signatures},
  journal = {Proceedings of the National Academy of Sciences},
  year    = {2025},
  doi     = {10.1073/pnas.2520822123},
  keywords = {body-wandering, interoception, mind-wandering, thalamocortical, ADHD, depression, predictive processing, embodied cognition},
  note    = {N=536 healthy participants, resting-state fMRI + experience sampling. Cross-validated CCA identified body-wandering as distinct from cognitive mind-wandering, with somatomotor-interoceptive-thalamocortical neural signature. Higher habitual body-wandering associated with lower ADHD severity and lower depression. Canonical loadings: stomach 0.576, arousal 0.442, breathing 0.345, movement 0.300, negative affect 0.286. Key finding: paradoxical protective effect of body-wandering (aversive in moment, protective for mental health).}
}

@article{Volkow2011adhddopamine,
  author  = {Volkow, Nora D and Wang, Gene-Jack and Newcorn, Jeffrey H and Kollins, Scott H and Wigal, Timothy L and Telang, Frank and Fowler, Joanna S and Goldstein, Rita Z and Klein, Natalie and Logan, Jean and Wong, Christopher and Swanson, James M},
