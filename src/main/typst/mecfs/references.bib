@article{Westman2021nfl_nmdar,
  author  = {Westman, Gabriel and Aurelius, Elisabeth and Glimaker, Martin and Ahlm, Clas and Schliamser, Silvia and Studahl, Marie},
  title   = {{CSF} biomarkers of brain injury, inflammation and synaptic autoimmunity predict long-term neurocognitive outcome in herpes simplex encephalitis},
