  journal = {Amino Acids},
  year = {2011},
  volume = {40},
  number = {5},
  pages = {1325--1331},
  doi = {10.1007/s00726-011-0853-y},
  pmid = {21387089},
  keywords = {creatine, SAM, S-adenosylmethionine, GAMT, methylation, guanidinoacetate, methyl groups},
  note = {Comprehensive review establishing that creatine synthesis via GAMT consumes approximately 40\% of all SAM-derived methyl groups in humans (revised from the earlier Mudd 1980 estimate of ~70\%, which did not account for methyl-group recycling). Regardless of the exact fraction, creatine synthesis is the single largest consumer of labile methyl groups in human metabolism. Direct creatine supplementation bypasses GAMT entirely, reducing SAM consumption. Clinically relevant for populations with methylation impairment (MTHFR variants, B12/folate deficiency).},
  certainty = {0.85},
  research_stream = {creatine-shuttle}
}

