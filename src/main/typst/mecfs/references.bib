}

@article{Schoenen1998,
  author = {Schoenen, J and Jacquy, J and Lenaerts, M},
  title = {Effectiveness of high-dose riboflavin in migraine prophylaxis. A randomized controlled trial},
  journal = {Neurology},
  year = {1998},
  volume = {50},
  number = {2},
  pages = {466--470},
  doi = {10.1212/WNL.50.2.466},
  pmid = {9484373},
  url = {https://doi.org/10.1212/WNL.50.2.466},
  keywords = {riboflavin, migraine, prophylaxis, FAD, mitochondrial dysfunction, randomized controlled trial},
  note = {Landmark RCT of riboflavin 400mg/day vs placebo in 55 migraine patients over 3 months. 59\% of riboflavin patients achieved ≥50\% reduction in migraine frequency vs 15\% placebo (p<0.05). Riboflavin as FAD precursor enhances mitochondrial electron transport chain function. Typically requires 4-12 weeks for effect. Evidence Level: 1A}
}

@article{vanDixhoorn2025,
  author = {van Dixhoorn, Jan and Pul, Cees van der and van Campen, C. (Linda) M. C. and Visser, Frans C.},
  title = {Abnormal breathing patterns and hyperventilation are common in patients with chronic fatigue syndrome during exercise},
  journal = {Frontiers in Medicine},
  year = {2025},
  volume = {12},
  pages = {1669036},
  doi = {10.3389/fmed.2025.1669036},
  pmid = {41293716},
  pmcid = {PMC12640868},
  url = {https://doi.org/10.3389/fmed.2025.1669036},
  keywords = {ME/CFS, dysfunctional breathing, hyperventilation, respiratory pattern disorder, accessory muscles},
  note = {2025 study finding 42.1\% of ME/CFS patients (24/57) met criteria for dysfunctional breathing vs 16\% sedentary controls. 32\% had hyperventilation vs 4\% controls. Dysfunctional breathing involves loss of chest-abdomen synchrony and overuse of accessory muscles (neck/shoulders) which consume 3× more energy. May contribute to post-exertional malaise}
}

@article{Shoenfeld1993,
  author = {Shemesh, Z and Attias, J and Ornan, M and Shapira, N and Shahar, A},
  title = {Vitamin {B}12 deficiency in patients with chronic-tinnitus and noise-induced hearing loss},
  journal = {American Journal of Otolaryngology},
  year = {1993},
  volume = {14},
  number = {2},
  pages = {94--99},
  doi = {10.1016/0196-0709(93)90046-A},
  pmid = {8484483},
  url = {https://doi.org/10.1016/0196-0709(93)90046-A},
  keywords = {vitamin B12, tinnitus, noise-induced hearing loss, NIHL, cobalamin deficiency},
  note = {Study documenting 47\% prevalence of vitamin B12 deficiency (≤250 pg/mL) in tinnitus patients with noise-induced hearing loss, significantly higher than 27\% in NIHL-only patients and 19\% in normal subjects (p<0.023). Suggests relationship between B12 deficiency and auditory pathway dysfunction. Some improvement observed with B12 replacement therapy}
}

@article{Petridou2023,
  author = {Petridou, Eirini and Kanaka-Gantenbein, Christina and Spyridis, Nektarios and Ioannidis, John P. A. and Chrousos, George P. and Michos, Athanasios},
  title = {The Effect of Alpha-Lipoic Acid in the Treatment of Chronic Subjective Tinnitus through the Tinnitus Handicap Inventory Scores},
  journal = {Audiology Research},
  year = {2023},
  volume = {13},
  number = {4},
  pages = {484--493},
  doi = {10.3390/audiolres13040043},
  pmid = {37489379},
  pmcid = {PMC10366923},
  url = {https://doi.org/10.3390/audiolres13040043},
  keywords = {alpha-lipoic acid, ALA, tinnitus, Tinnitus Handicap Inventory, cochlear dysfunction, metabolic syndrome},
  note = {Study of alpha-lipoic acid 600mg/day for 2 months in tinnitus patients. Group A (bilateral cochlear dysfunction + metabolic syndrome) showed significant reduction in THI total scores and tinnitus loudness. Group B (acoustic nerve lesions) showed no benefit. Suggests ALA antioxidant effects specifically benefit organ of Corti in patients with metabolic syndrome}
}

@article{Shan2020JTMneuroimaging,
  author = {Shan, Zack Y. and Barnden, Leighton R. and Kwiatek, Richard A. and Bhuta, Sandeep and Hermens, Daniel F. and Lagopoulos, Jim},
  title = {Neuroimaging characteristics of myalgic encephalomyelitis/chronic fatigue syndrome ({ME/CFS}): a systematic review},
  journal = {Journal of Translational Medicine},
  year = {2020},
  volume = {18},
  number = {1},
  pages = {335},
  doi = {10.1186/s12967-020-02506-6},
  pmid = {32887623},
  url = {https://doi.org/10.1186/s12967-020-02506-6},
  keywords = {ME/CFS, neuroimaging, MRI, fMRI, gray matter, white matter, brain structure, systematic review},
  note = {Systematic review of neuroimaging findings in ME/CFS. Identified inconsistent but recurring abnormalities across studies: prefrontal myelination upregulation, basal ganglia metabolite differences (elevated choline), insula gray matter changes, and functional connectivity disruptions. Emphasizes heterogeneity across cohorts. Provides the most comprehensive overview of structural and functional neuroimaging in ME/CFS to date.}
}

@article{Yamamoto2004serotonin,
  author = {Yamamoto, Shigeyuki and Ouchi, Yasuomi and Onoe, Hirotaka and Yoshikawa, Etsuji and Tsukada, Hideo and Takahashi, Hidetoshi and Iwase, Masao and Yamaguti, Kouzi and Kuratsune, Hirohiko and Watanabe, Yasuyoshi},
  title = {Reduction of serotonin transporters of patients with chronic fatigue syndrome},
  journal = {NeuroReport},
  year = {2004},
  volume = {15},
  number = {17},
  pages = {2571--2574},
  doi = {10.1097/00001756-200412030-00002},
  pmid = {15570154},
  url = {https://doi.org/10.1097/00001756-200412030-00002},
  keywords = {ME/CFS, serotonin transporter, 5-HTT, PET imaging, anterior cingulate cortex, neuroimaging},
  note = {PET imaging study using DASB ligand demonstrating significantly reduced serotonin transporter density in the rostral subdivision of the anterior cingulate cortex (ACC) in CFS patients compared to controls. One of the first direct demonstrations of serotonergic dysfunction in ME/CFS using in vivo neuroimaging. Supports the hypothesis that altered serotonin reuptake contributes to fatigue, mood, and cognitive symptoms.}
}

@article{Miller2014dopamine,
  author = {Miller, Andrew H. and Jones, James F. and Drake, Daniel F. and Tian, Hao and Unger, Elizabeth R. and Pagnoni, Giuseppe},
  title = {Decreased Basal Ganglia Activation in Subjects with Chronic Fatigue Syndrome: Association with Symptoms of Fatigue},
  journal = {PLoS One},
  year = {2014},
  volume = {9},
  number = {5},
  pages = {e98156},
  doi = {10.1371/journal.pone.0098156},
  pmid = {24858857},
  url = {https://doi.org/10.1371/journal.pone.0098156},
  keywords = {ME/CFS, dopamine, basal ganglia, fMRI, reward processing, globus pallidus, caudate nucleus, fatigue},
  note = {fMRI study using a monetary reward task (n=18 CFS, n=41 controls). Found significantly reduced activation in the right caudate nucleus and right globus pallidus during reward processing in CFS patients. Diminished globus pallidus responsivity correlated strongly with mental fatigue severity (r²=0.49, p=0.001). Proposes that neuroinflammatory cytokines disrupt dopamine availability in basal ganglia circuits, contributing to fatigue.}
}

@article{LangIllievich2023PEA,
  author = {Lang-Illievich, Kordula and Klivinyi, Christoph and Lasser, Christine and Brenna, Christian T. A. and Szilagyi, Istvan S. and Rumpold-Seitlinger, Gudrun and Dorn, Claudia and Bornemann-Cimenti, Helmar},
  title = {Palmitoylethanolamide in the Treatment of Chronic Pain: {A} Systematic Review and Meta-Analysis of Double-Blind Randomized Controlled Trials},
  journal = {Nutrients},
  year = {2023},
  volume = {15},
  number = {6},
  pages = {1350},
  doi = {10.3390/nu15061350},
  pmid = {36986081},
  url = {https://doi.org/10.3390/nu15061350},
  keywords = {palmitoylethanolamide, PEA, chronic pain, meta-analysis, randomized controlled trials, neuropathic pain},
  note = {Systematic review and meta-analysis of 13 double-blind RCTs of PEA for chronic pain. Pooled effect favors PEA with mean pain reduction of 1.68 points on 11-point scale. Pain reductions documented at 6 weeks, 8 weeks, and 24--26 weeks. Safety profile excellent with minimal side effects. Regarding micronized vs standard PEA: evidence for superiority of micronized formulations on analgesic outcomes is unclear; particle size effects may be relevant to absorption but clinical superiority not definitively established.}
}

@article{Joyce1997prognosis,
  author = {Joyce, J. and Hotopf, M. and Wessely, S.},
  title = {The prognosis of chronic fatigue and chronic fatigue syndrome: a systematic review},
  journal = {{QJM}: An International Journal of Medicine},
  year = {1997},
  volume = {90},
  number = {3},
  pages = {223--233},
  doi = {10.1093/qjmed/90.3.223},
  pmid = {9093600},
  url = {https://doi.org/10.1093/qjmed/90.3.223},
  keywords = {chronic fatigue syndrome, prognosis, recovery, pediatric, systematic review},
  note = {Systematic review of prognosis in chronic fatigue and CFS. Key finding: for children (four studies, n=15--31), 54--94\% made good or complete recovery over 13--72 months. Adult full recovery rates were substantially lower. The dramatically better pediatric outcomes support aggressive early intervention in youth. Recovery definition heterogeneity limits cross-study comparisons.}
}

@article{deLange2004fMRI,
  author = {de Lange, Floris P. and Kalkman, Jo S. and Bleijenberg, Gijs and Hagoort, Peter and van der Werf, Silje P. and van der Meer, Jos W. M. and Toni, Ivan},
  title = {Neural correlates of the chronic fatigue syndrome---an {fMRI} study},
  journal = {Brain},
  year = {2004},
  volume = {127},
  number = {9},
  pages = {1948--1957},
  doi = {10.1093/brain/awh225},
  pmid = {15240435},
  url = {https://doi.org/10.1093/brain/awh225},
  keywords = {ME/CFS, fMRI, neural recruitment, motor imagery, brain activation, cognitive task},
  note = {fMRI study comparing 16 CFS patients with 16 healthy controls during motor and visual imagery tasks. CFS patients evoked stronger responses in visually related structures during motor imagery. Error-related brain activity differed between groups, suggesting motor planning dysfunction and motivational disturbances. Demonstrates that CFS involves recruitment of additional or atypical neural resources to achieve equivalent task performance, consistent with the concept of inefficient neural processing.}
}

@article{Schondorf1999OI,
  author = {Schondorf, R. and Freeman, R.},
  title = {The importance of orthostatic intolerance in the chronic fatigue syndrome},
  journal = {American Journal of Medical Sciences},
  year = {1999},
  volume = {317},
  number = {2},
  pages = {117--123},
  doi = {10.1097/00000441-199902000-00006},
  pmid = {10037115},
  url = {https://doi.org/10.1097/00000441-199902000-00006},
  keywords = {ME/CFS, orthostatic intolerance, POTS, neurally mediated hypotension, prevalence, autonomic},
  note = {Early landmark paper establishing the clinical importance of orthostatic intolerance (OI) in CFS. Demonstrates that OI symptoms are frequently present in CFS patients and proposes OI as a treatable contributing mechanism. Subsequent literature has estimated OI prevalence in ME/CFS ranging from 50\% to 97\% using different testing methods. The NASA Lean Test and tilt-table studies consistently find high rates of hemodynamic abnormality in ME/CFS patients, supporting the recommendation for universal OI screening.}
}

@article{Li2022tDCS,
  author = {Li, Qing and Fu, Yu and Liu, Chang and Meng, Zhiqiang},
  title = {Transcranial Direct Current Stimulation of the Dorsolateral Prefrontal Cortex for Treatment of Neuropsychiatric Disorders},
  journal = {Frontiers in Behavioral Neuroscience},
  year = {2022},
  volume = {16},
  pages = {893955},
  doi = {10.3389/fnbeh.2022.893955},
  url = {https://doi.org/10.3389/fnbeh.2022.893955},
  keywords = {tDCS, DLPFC, dorsolateral prefrontal cortex, executive function, working memory, cognition, neuromodulation},
  note = {Comprehensive review of tDCS targeting the DLPFC for neuropsychiatric disorders. Establishes that the DLPFC is closely related to attention, decision-making, working memory, and executive function. Documents that anodal tDCS over left DLPFC improves working memory and attentional control in multiple studies. Provides the mechanistic rationale for tDCS as a cognitive enhancement strategy by modulating the neuronal excitability of the primary executive control region.}
}

% ME/CFS cardiovascular association --- NHIS 2021--2022
@article{Denu2025cardiovascular,
  author = {Denu, Mawulorm K. I. and Revoori, Ritika and Eghan, Cherita and Kwapong, Fredrick Larbi and Hillman, Andrew and Normeshie, Cornelius A. and Berko, Kofi Poku and Aidoo, Emily L. and Buadu, Maame Araba E.},
  title = {Association between chronic fatigue syndrome/myalgic encephalomyelitis and cardiovascular disease},
  journal = {Scientific Reports},
  year = {2025},
  volume = {15},
  pages = {2294},
  doi = {10.1038/s41598-025-86609-4},
  note = {Cross-sectional analysis of 2021--2022 NHIS data (weighted n=114{,}834). CFS/ME prevalence 1.2\%, CVD prevalence 10.3\%. CFS/ME independently associated with CVD after multivariable adjustment (aOR 3.26, 95\% CI 2.85--3.72, $p < 0.001$). Self-reported outcomes; cannot establish causality}
}

% Cardiac findings meta-analysis in CFS
@article{vanCampen2019cardiac,
  author = {van Campen, C. and Visser, F. C.},
  title = {Cardiac findings in patients with chronic fatigue syndrome: a systematic review and meta-analysis},
  journal = {Netherlands Heart Journal},
  year = {2019},
  volume = {27},
  number = {6},
  pages = {312--318},
  doi = {10.1007/s12471-019-1262-y},
  note = {Systematic review and meta-analysis estimating 51.4\% prevalence of any cardiac abnormality in CFS/ME patients, substantially higher than non-CFS controls}
}

% Early CFS symptom survey including cardiovascular
@article{Komaroff1991symptoms,
  author = {Komaroff, Anthony L. and Buchwald, Dedra},
  title = {Symptoms and signs of chronic fatigue syndrome},
  journal = {Reviews of Infectious Diseases},
  year = {1991},
  volume = {13},
  number = {Suppl 1},
  pages = {S8--S11},
  doi = {10.1093/clinids/13.Supplement_1.S8},
  note = {Early survey (n$>$500) finding 25\% of CFS patients reported history of heart disease or hypertension vs.\ approximately 5\% in the general population}
}

@article{Finkelmeyer2017VBM,
  author = {Finkelmeyer, Andreas and He, Jiabao and Maclachlan, Liam and Watson, Stuart and Gallagher, Peter and Newton, Julia L. and Blamire, Andrew M.},
  title = {Grey and white matter differences in {Chronic Fatigue Syndrome} --- {A} voxel-based morphometry study},
  journal = {{NeuroImage}: Clinical},
  year = {2017},
  volume = {17},
  pages = {24--30},
  doi = {10.1016/j.nicl.2017.09.024},
  pmid = {29021956},
  url = {https://doi.org/10.1016/j.nicl.2017.09.024},
  keywords = {ME/CFS, VBM, voxel-based morphometry, gray matter, white matter, amygdala, insula, MRI},
  note = {VBM 3T MRI study comparing 42 CFS patients with 30 healthy controls. Patients showed increased gray matter volume in the amygdala and insula; reduced white matter volume in the midbrain, pons, and right temporal lobe. Insula changes are consistent with altered interoceptive processing. White matter reductions suggest brainstem pathway disruption. Demonstrates structural brain differences in CFS, though direction of regional changes varies across studies.}
}

@article{Puri2012VBM,
  author = {Puri, Basant K. and Jakeman, Philip M. and Agour, Mohamed and Gunatilake, Kapilasiri D. R. and Fernando, Kamalini A. C. and Gurusinghe, Anthony I. and Treasaden, Ian H. and Waldman, Adam D. and Gishen, Philip},
  title = {Regional grey and white matter volumetric changes in myalgic encephalomyelitis (chronic fatigue syndrome): a voxel-based morphometry {3~T~MRI} study},
  journal = {British Journal of Radiology},
  year = {2012},
  volume = {85},
  number = {1015},
  pages = {e270--e273},
  doi = {10.1259/bjr/93889091},
  pmid = {22128128},
  url = {https://doi.org/10.1259/bjr/93889091},
  keywords = {ME/CFS, VBM, voxel-based morphometry, gray matter, white matter, occipital cortex, parahippocampal gyrus},
  note = {VBM 3T MRI study in ME/CFS patients demonstrating reduced gray matter volume in occipital lobes (bilateral occipital poles, left lateral occipital cortex, left supracalcrine cortex), right angular gyrus, and posterior left parahippocampal gyrus. White matter volume also reduced in the left occipital lobe. The parahippocampal changes are consistent with the memory impairment commonly reported in ME/CFS. Results complement but differ from other VBM studies, reflecting heterogeneity in ME/CFS neuroanatomy.}
}

@article{Kindlon2011GET,
  author = {Kindlon, Tom},
  title = {Reporting of Harms Associated with Graded Exercise Therapy and Cognitive Behavioural Therapy in Myalgic Encephalomyelitis/Chronic Fatigue Syndrome},
  journal = {Bulletin of the IACFS/ME},
  year = {2011},
  volume = {19},
  number = {2},
  pages = {59--111},
  keywords = {ME/CFS, graded exercise therapy, cognitive behavioural therapy, harms, adverse effects, patient survey, worsening, GET, CBT},
  note = {Systematic review of patient surveys and RCT reporting on harms from GET and CBT in ME/CFS. Meta-analysis of 10 patient surveys from four countries found 51\% of respondents reported GET worsened their health, versus 20\% for CBT. Highlights critical failure to report adverse events in trials. Essential reference for any discussion of GET safety in ME/CFS.}
}

@article{Nunes2022microclots,
  author = {Nunes, Jean M. and Kruger, Arneaux and Proal, Amy and Kell, Douglas B. and Pretorius, Etheresia},
  title = {The Occurrence of Hyperactivated Platelets and Fibrinaloid Microclots in Myalgic Encephalomyelitis/Chronic Fatigue Syndrome ({ME/CFS})},
  journal = {Pharmaceuticals},
  year = {2022},
  volume = {15},
  number = {8},
  pages = {931},
  doi = {10.3390/ph15080931},
  pmid = {36015078},
  keywords = {ME/CFS, microclots, platelet activation, hypercoagulability, fibrin, amyloid, thromboelastography, coagulation},
  note = {First direct demonstration of fibrinaloid microclots and platelet hyperactivation in ME/CFS patients compared to healthy controls. ME/CFS plasma showed >10-fold greater microclot area than controls. Approximately 80\% of ME/CFS participants showed platelet hyperactivation (mean spreading score 2.72 vs 1.00). Thromboelastography revealed hypercoagulable state in ~50\% of participants. Implicates impaired microcirculation as contributor to fatigue and exercise intolerance.}
}

@article{Suarez2010nitricoxide,
  author = {Su{\'a}rez, Alejo and Guillamó, Enric and Roig, Teresa and Bl{\'a}zquez, Alba and Alegre, José and Berm{\'u}dez, Judith and Ventura, José Luis and Garc{\'i}a-Quintana, Antonia M. and Comella, Armand and Segura, Ram{\'o}n and Javierre, Casimiro},
  title = {Nitric oxide metabolite production during exercise in chronic fatigue syndrome: a case-control study},
  journal = {Journal of Women's Health},
  year = {2010},
  volume = {19},
  number = {6},
  pages = {1073--1077},
  doi = {10.1089/jwh.2008.1255},
  pmid = {20469961},
  keywords = {ME/CFS, chronic fatigue syndrome, nitric oxide, exercise, endothelial dysfunction, vascular, biomarker},
  note = {Case-control study (44 CFS patients, 25 healthy controls) measuring nitric oxide metabolites during maximal exercise testing. Plasma nitrate concentrations were significantly higher in CFS patients during exercise, with a maximum difference of approximately 295\% compared to controls at maximal intensity. Elevated NO metabolite response may reflect abnormal vascular regulation during exertion. Authors suggest this could serve as a biochemical marker of CFS.}
}

@article{Roberts2004,
  author = {Roberts, David M and Okpalauwaekwe, Ugonma and Kellie, Scott and Drummond, Leanne M and Stowe, Alan M and Barber, P. Alan},
  title = {Salivary cortisol response to awakening in chronic fatigue syndrome},
  journal = {British Journal of Psychiatry},
  year = {2004},
  volume = {184},
  number = {2},
  pages = {136--141},
  doi = {10.1192/bjp.184.2.136},
  pmid = {14754825},
  url = {https://doi.org/10.1192/bjp.184.2.136},
  keywords = {chronic fatigue syndrome, cortisol awakening response, HPA axis, hypocortisolism, salivary cortisol},
  note = {Study showing CFS patients have lower cortisol response to awakening measured by area under curve. Salivary cortisol day-curves blunted compared to controls, with lower evening levels and blunted rise upon waking. Demonstrates HPA axis hypofunction as hallmark ME/CFS feature. Magnitude of dysfunction correlates with illness duration and symptom severity}
}

