@article{Russo2004CECD,
  author = {Russo, Ethan B},
  title = {Clinical Endocannabinoid Deficiency ({CECD}): Can This Concept Explain Therapeutic Benefits of Cannabis in Migraine, Fibromyalgia, Irritable Bowel Syndrome and Other Treatment-Resistant Conditions?},
  journal = {Neuro Endocrinology Letters},
  year = {2004},
  volume = {25},
  number = {1-2},
  pages = {31--39},
  pmid = {15159679},
  keywords = {clinical endocannabinoid deficiency, CECD, fibromyalgia, migraine, irritable bowel syndrome, cannabis, endocannabinoid system, anandamide, 2-AG, central sensitization},
  note = {Original CECD hypothesis paper by Russo. Proposes that deficient endocannabinoid tone (low anandamide/2-AG, impaired CB receptor signaling) underlies fibromyalgia, migraine, IBS and related conditions. Evidence: cannabinoids block spinal, peripheral and GI pain mechanisms; anandamide active in periaqueductal gray (migraine generator); THC modulates NMDA receptors. Fibromyalgia conceptualized as central sensitization state. Suggests CSF examination and neuroimaging for objective CECD testing. Medical Hypotheses quality; later supported by CSF anandamide data in migraineurs.}
}

@article{Russo2016CECDReconsidered,
  author = {Russo, Ethan B},
  title = {Clinical Endocannabinoid Deficiency Reconsidered: Current Research Supports the Theory in Migraine, Fibromyalgia, Irritable Bowel, and Other Treatment-Resistant Syndromes},
  journal = {Cannabis and Cannabinoid Research},
  year = {2016},
  volume = {1},
  number = {1},
  pages = {154--165},
  doi = {10.1089/can.2016.0009},
  pmid = {28861491},
  pmcid = {PMC5576607},
  keywords = {clinical endocannabinoid deficiency, CECD, fibromyalgia, migraine, IBS, cannabis, endocannabinoid system, CSF anandamide, ECS hypofunction},
  note = {Updated CECD review 12 years after original paper. New evidence: statistically significant CSF anandamide reductions in migraineurs; advanced imaging showing ECS hypofunction in PTSD. Central sensitization/hyperalgesia common to migraine, FM, IBS -- consistent with ECS hypofunction. Additional evidence for decreased pain, improved sleep with cannabinoid treatment. Discusses adjunctive lifestyle approaches affecting ECS tone (exercise, sleep, stress reduction). Open access. Peer-reviewed.}
}

@article{YangCBD2024MastCell,
  author = {Yang, Xiaoxin and Lee, Dabin and Kim, Hyun Wook and Park, Byung-Hyun and Lim, Chaekyun and Bae, Eun Ju},
  title = {Cannabidiol Inhibits {IgE}-Mediated Mast Cell Degranulation and Anaphylaxis in Mice},
  journal = {Molecular Nutrition and Food Research},
  year = {2024},
  volume = {68},
  number = {3},
  pages = {e2300136},
  doi = {10.1002/mnfr.202300136},
  pmid = {38059783},
  keywords = {cannabidiol, CBD, mast cell, degranulation, IgE, FcεRI, CB1, CB2, anaphylaxis},
  note = {Mechanistic study in mouse/human primary mast cells. CBD suppresses antigen-stimulated mast cell degranulation concentration-dependently by inhibiting FcεRI downstream signaling and calcium mobilization. Importantly, suppressive effects are CB1- and CB2-independent (preserved in receptor-depleted cells), suggesting novel non-canonical mechanisms. CBD also inhibits mast cell development in long-term culture. In vivo: CBD suppresses passive cutaneous anaphylaxis. Highly relevant to MCAS-subset ME/CFS with mast cell brake failure.}
}

