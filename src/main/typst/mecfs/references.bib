  year     = {1986},
  volume   = {66},
  number   = {2},
  pages    = {399--405},
  pmid     = {3028680},
  keywords = {adenine nucleotide translocase, ANT, PBC, primary biliary cirrhosis, antimitochondrial antibody, AMA, specificity, cross-reactive, SLE},
  note     = {Specificity assessment of anti-ANT antibodies in primary biliary cirrhosis (PBC). Using ELISA and immunoblotting with rat liver ANT, PBC antibodies against ANT were detectable. However, patients with SLE, chronic active hepatitis, and healthy controls showed comparable or higher anti-ANT titres. Conclusion: rat liver ANT is not a specific antigen for PBC autoantibodies. ANT is not a good candidate for PBC diagnosis. This is the key null/specificity finding: anti-ANT antibodies lack disease specificity and are found in non-autoimmune individuals. Critical for G28 reasoning — ELISA assays must use human cardiac ANT1 with strict controls, not rat liver ANT. Limitations: uses rat liver ANT (not human cardiac ANT1); cross-reactivity may differ with isoform-specific antigen.},
  certainty = {0.65},
  research_stream = {ant-autoantibodies}
}

