@article{Naas2023hse_proteome,
  author  = {N{\"{a}}{\"{a}}s, Anja and Li, Peng and Ahlm, Clas and Aurelius, Elisabeth and J{\"{a}}rhult, Josef D. and Schliamser, Silvia and Studahl, Marie and Xiao, Wenzhong and Bergquist, Jonas and Westman, Gabriel},
