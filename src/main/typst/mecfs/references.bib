@article{Ristow2009oxidativehormesis,
  author   = {Ristow, Michael and Zarse, Kim},
  title    = {How increased oxidative stress promotes longevity and metabolic health: the concept of mitochondrial hormesis (mitohormesis)},
  journal  = {Experimental Gerontology},
  year     = {2010},
  volume   = {45},
  number   = {6},
  pages    = {410--418},
  doi      = {10.1016/j.exger.2010.03.014},
  pmid     = {20350594},
  note     = {Establishes the concept of mitohormesis: mild increases in reactive oxygen species (ROS) serve as essential signals for mitochondrial quality control pathways, including PINK1/Parkin-mediated mitophagy. Scavenging ROS with high-dose antioxidants during exercise may abolish beneficial ROS signaling and impair mitochondrial adaptation. Key reference for the antioxidant-mitophagy tradeoff in the Emergency PEM Protocol.},
  keywords = {mitohormesis, ROS, antioxidants, mitophagy, PINK1, Parkin, exercise, adaptation, oxidative stress}
}

% --- Steinkirchner et al. 2026: Perioperative outcomes in ME/CFS under general anesthesia ---

@article{Steinkirchner2026anesthesia,
  author   = {Steinkirchner, Felix M. and Kaufmann, Christina and Kraus, Richard Felix and Kaess, Maximilian and Schieffer, Elisabeth and Graf, Bernhard M. and Lassen, Christoph and Kimmerling, Viktoria and Dejaco, Alexander},
  title    = {Perioperative outcomes in patients with myalgic encephalomyelitis/chronic fatigue syndrome undergoing general anesthesia: a retrospective matched-pair study},
  journal  = {medRxiv},
  year     = {2026},
  doi      = {10.64898/2026.04.06.26348924},
  url      = {https://www.medrxiv.org/content/10.64898/2026.04.06.26348924v1},
  note     = {PREPRINT — not yet peer reviewed. Retrospective matched-pair study (n=15 ME/CFS, n=15 controls), University Hospital Regensburg. Key findings: (1) Intraoperative nadir systolic BP lower in ME/CFS (90 vs 100 mmHg, p=0.044) and nadir heart rate lower (50 vs 60 bpm, p=0.012) but no clinically significant hemodynamic instability, no excess vasopressor use. (2) Postoperative pain substantially higher: NRS 5.0 vs 1.0 (p=0.008); opioid rescue analgesia required by 80\% vs 33\% of controls (p=0.039). Authors attribute hemodynamic differences to autonomic dysfunction and elevated pain to central sensitization. Post-exertional malaise as a perioperative outcome was not captured. First study to empirically examine anesthetic safety in ME/CFS.},
  keywords = {ME/CFS, anesthesia, perioperative, pain, autonomic dysfunction, central sensitization, POTS, hemodynamics}
}

% --- Nunes et al. 2026: Virus-induced endothelial senescence as cause of ME/CFS and long COVID ---

@article{Nunes2026endothelialSenescence,
  author   = {Nunes, Massimo and Kell, Loren and Slaghekke, Anouk and W{\"u}st, Rob CI and Fielding, Burtram C and Kell, Douglas B and Pretorius, Etheresia},
  title    = {Virus-induced endothelial senescence as a cause and driving factor for {ME/CFS} and long {COVID}: mediated by a dysfunctional immune system},
  journal  = {Cell Death \& Disease},
  year     = {2026},
  volume   = {17},
  number   = {1},
  pages    = {16},
  doi      = {10.1038/s41419-025-08162-2},
  pmid     = {41513611},
  pmcid    = {PMC12789617},
  url      = {https://doi.org/10.1038/s41419-025-08162-2},
  note     = {Theoretical framework proposing virus-induced endothelial senescence (and the resulting SASP: proinflammatory, pro-oxidative, procoagulant, vasoconstriction-primed) as the unifying mechanistic cause of ME/CFS and long COVID. Central insight: NK cell dysfunction and T cell exhaustion (documented in ME/CFS) prevent clearance of senescent endothelial cells, creating a self-sustaining bidirectional loop between SASP and immune dysfunction. Tissue-specific endothelial senescence at the BBB, cerebral arteries, GI tract, and skeletal muscle microvasculature maps to specific ME/CFS symptom clusters. Implies senolytics and immune restoration as therapeutic targets. Review/theory paper — endothelial senescence not yet directly measured in ME/CFS patient tissue.},
  keywords = {ME/CFS, long COVID, endothelial senescence, SASP, endothelial dysfunction, post-viral, NK cell, immune dysfunction, cerebral blood flow, PEM, senolytics, vascular}
}

