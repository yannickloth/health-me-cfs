  research_stream = {ans-aging},
  note         = {Mouse study (n=4-6/group young vs aged). Aged brainstem showed 32-fold increase p16 mRNA (senescence marker); glial cells 90-fold increase. Elevated NF-kB activity in aged brainstem. Serum norepinephrine elevated in aged animals. Multiple SASP cytokines elevated (IL-1beta, MCP1, TNFalpha). Limitations: associative only; cannot establish causality; mouse model; small n; no neuronal analysis. Provides mechanistic link: brainstem glial senescence may drive age-related sympathetic overactivity — relevant to ME/CFS brainstem findings.}
}

@article{Kim2023cGASSTING,
  author       = {Kim, Jeonghan and Kim, Ho-Shik and Chung, Jay H.},
