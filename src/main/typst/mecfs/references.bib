@article{Dantzer2000neural,
  author = {Dantzer, Robert and Konsman, Jan P and Bluth{\'e}, Rose-Marie and Kelley, Keith W},
  title = {Neural and humoral pathways of communication from the immune system to the brain: parallel or convergent?},
  journal = {Autonomic Neuroscience},
  year = {2000},
  volume = {85},
  number = {1-3},
  pages = {60--65},
  doi = {10.1016/S1566-0702(00)00220-4},
  pmid = {11189027},
  keywords = {sickness behavior, vagus nerve, circumventricular organs, blood-brain barrier, cytokines, prostaglandins, humoral pathway, neural pathway},
  note = {Foundational review establishing two parallel routes for peripheral cytokine signaling to brain: (1) fast neural pathway via vagal afferents from infection sites; (2) slower humoral pathway via circumventricular organs (OVLT, area postrema) and choroid plexus. Local brain cytokine induction via prostaglandins then mediates downstream sickness behavior circuits.}
}


@article{Capuron2002,
  author = {Capuron, Lucile and Gumnick, James F and Musselman, Dominique L and Lawson, David H and Reemsnyder, Ashley and Nemeroff, Charles B and Miller, Andrew H},
  title = {Neurobehavioral effects of interferon-alpha in cancer patients: phenomenology and paroxetine responsiveness of symptom dimensions},
  journal = {Neuropsychopharmacology},
  year = {2002},
  volume = {26},
  number = {5},
  pages = {643--652},
  doi = {10.1016/S0893-133X(01)00407-9},
  pmid = {11927189},
  keywords = {interferon-alpha, IFN-alpha, fatigue, somnolence, cytokine, neurovegetative, depression, cancer, melanoma, paroxetine},
  note = {Double-blind RCT (n=40 melanoma patients) during 12-week IFN-alpha therapy. Neurovegetative and somatic symptoms (fatigue, anorexia, pain) appeared within 2 weeks of IFN-alpha initiation and were distinct from later mood/cognitive symptoms. Fatigue was less responsive to paroxetine than mood symptoms, indicating distinct neurobiological pathways. Establishes IFN-alpha as a direct fatigogenic cytokine through non-serotonergic mechanisms.}
}

