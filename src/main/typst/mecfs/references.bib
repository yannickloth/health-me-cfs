% --- Grossberg et al.\ 2011: Inflammation-induced lethargy via orexin suppression ---
@article{Grossberg2011orexinLethargy,
  author   = {Grossberg, Aaron J. and Zhu, XinXia and Leinninger, Gina M. and Levasseur, Peter R. and Braun, Theodore P. and Myers, Martin G. Jr. and Marks, Daniel L.},
  title    = {Inflammation-induced lethargy is mediated by suppression of orexin neuron activity},
  journal  = {Journal of Neuroscience},
  year     = {2011},
  volume   = {31},
  number   = {31},
  pages    = {11376--11386},
  doi      = {10.1523/JNEUROSCI.2311-11.2011},
  pmid     = {21813697},
  url      = {https://doi.org/10.1523/JNEUROSCI.2311-11.2011},
  keywords = {orexin, inflammation, lethargy, sickness behavior, lateral hypothalamus, IL-1, neurotensin, cytokine},
  research_stream = {orexin-hypothalamic-dysfunction},
  certainty = {0.65},
  note     = {Animal study (rats/mice). Demonstrates that inflammatory signaling suppresses orexin neuron activity in the perifornical hypothalamus, causing lethargy. LPS reduces CSF orexin-A and blocks dark-phase Ox neuron activation. Central orexin-A replacement reverses lethargy. Orexin neurons lack direct cytokine receptors — indirect signaling via lateral hypothalamic neurotensin neurons established. Mechanistic foundation for inflammation-driven orexin suppression in ME/CFS sickness behavior.},
}

% --- Gaykema & Goehler 2009: LPS suppresses Fos in orexin neurons ---
@article{Gaykema2009orexinSickness,
