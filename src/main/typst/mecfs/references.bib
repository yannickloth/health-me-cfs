  number       = {4},
  pages        = {341--353},
  doi          = {10.1053/smrv.2000.0098},
  pmid         = {12531174},
  url          = {https://doi.org/10.1053/smrv.2000.0098},
  keywords     = {sleep inertia, post-sleep performance, arousal, napping, slow-wave sleep},
  certainty    = {0.75},
  research_stream = {sleep-nap-pathophysiology},
  note         = {Narrative review of sleep inertia physiology. Duration: 1 min to 4 hours depending on conditions; rarely exceeds 30 min without major sleep deprivation. Most severe after SWS awakening (naps >30 min entering deep sleep produce worse inertia than <20 min naps). Dose-dependent with prior sleep debt. Circadian modulation (worse near core body temperature trough). Different cognitive tasks show different sensitivity. Foundational reference for ME/CFS nap guidance — predicts amplified sleep inertia in patients with pre-existing energy deficits and sleep architecture disruption.}
}

