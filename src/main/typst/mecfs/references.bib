  url      = {https://doi.org/10.3390/biomedicines13030545},
  keywords = {orexin, PASC, Long COVID, autonomic nervous system, POTS, cardiometabolic, baroreflex, sympathetic},
  research_stream = {orexin-hypothalamic-dysfunction},
