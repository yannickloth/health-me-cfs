% --- Sonn et al. 2022: PRDX3 deficiency impairs mitophagy via PINK1 ---

@article{Sonn2022prdx3cardiac,
  author   = {Sonn, Sung Kyun and Song, Eun Ji and Seo, Seungwoon and Kim, Young Yeon and Um, Ji-Hoon and Yeo, Fei-Yei and Lee, Da Som and Jeon, Hyeong Rok and Kim, Mi Young and Yun, Jeanho and Lee, Young-Ho and Oh, Goo Taeg},
