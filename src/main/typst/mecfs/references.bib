}

@article{Giunta2023ANSinflamaging,
  author       = {Giunta, Sergio and Xia, Shijin and Pelliccioni, Giuseppe and Olivieri, Fabiola},
  title        = {Autonomic nervous system imbalance during aging contributes to impair endogenous anti-inflammaging strategies},
