  year    = {2016},
  volume  = {10},
  pages   = {550},
  doi     = {10.3389/fnhum.2016.00550},
  pmid    = {27877120},
  keywords = {allostasis, self-efficacy, fatigue, depression, interoception, predictive coding, ME/CFS, dyshomeostasis, metacognition},
  note    = {Formal framework proposing that depression and fatigue arise from accumulated evidence of allostatic self-inefficacy: the brain infers it cannot regulate its own physiological state. Directly maps onto ME/CFS depression mechanism: persistent failed allostatic predictions (via corrupted interoceptive hierarchy) generate learned helplessness as a rational Bayesian inference. Distinguishes this from primary depression.}
}

@article{Raison2006cytokines,
  author  = {Raison, Charles L and Capuron, Lucile and Miller, Andrew H},
  title   = {Cytokines sing the blues: inflammation and the pathogenesis of depression},
  journal = {Trends in Immunology},
  year    = {2006},
  volume  = {27},
  number  = {1},
  pages   = {24--31},
  doi     = {10.1016/j.it.2005.11.006},
  pmid    = {16316783},
  keywords = {cytokines, depression, inflammation, IDO, serotonin, kynurenine, neuroinflammation, quinolinic acid, tryptophan},
  note    = {Key review establishing the IDO/kynurenine pathway as the mechanistic link between inflammation and depression: cytokine activation of IDO depletes tryptophan (serotonin precursor) and produces neurotoxic quinolinic acid. Explains why ME/CFS depression is neurobiologically distinct from primary depression and may not respond to SSRIs alone. Foundational for Architecture B (ME/CFS -> depression via inflammatory cascade).}
}

@article{Dunn2019neuroinflammationadhd,
