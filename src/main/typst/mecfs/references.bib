@article{SzekeresBartho2019progestogens,
  author       = {Szekeres-Bartho, Julia and Schindler, Axel E},
  title        = {Progestogens and immunology},
  journal      = {Best Practice \& Research Clinical Obstetrics \& Gynaecology},
  year         = {2019},
  volume       = {60},
  pages        = {16--24},
  doi          = {10.1016/j.bpobgyn.2019.07.001},
  pmid         = {31345741},
  url          = {https://doi.org/10.1016/j.bpobgyn.2019.07.001},
  keywords     = {progesterone, PIBF, Th2, NK cells, immune tolerance,
                  progesterone-mecfs},
  research_stream = {progesterone-mecfs},
  certainty    = {0.58},
  note         = {Authoritative review of progesterone immunomodulatory mechanisms via
                  progesterone-induced blocking factor (PIBF). PIBF: (1) increases
                  production of Th2 cytokines (IL-4, IL-6, IL-10), (2) inhibits NK cell
                  degranulation. This Th2 shift and NK suppression is the proposed
                  mechanism by which pregnancy improves ME/CFS in ~30\% of patients.
                  Relevant to: oral micronized progesterone hypothesis as a route to
                  recapitulating these pregnancy-associated immune changes.}
}

