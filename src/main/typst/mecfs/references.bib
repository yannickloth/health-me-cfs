% --- Smith & Verkman 2018: Critique of the glymphatic hypothesis ---

@article{SmithVerkman2018glymphatic,
  author   = {Smith, Alex J. and Verkman, Alan S.},
  title    = {The ``glymphatic'' mechanism for solute clearance in {Alzheimer}'s disease: game changer or unproven speculation?},
  journal  = {FASEB Journal},
  year     = {2018},
  volume   = {32},
  number   = {2},
  pages    = {543--551},
  doi      = {10.1096/fj.201700999},
  pmid     = {28935818},
  note     = {Critical methodological review of the glymphatic hypothesis. Argues that the bulk convective cerebrospinal fluid flow through perivascular spaces proposed by Iliff et al. is inconsistent with the physical properties of brain parenchyma and likely reflects artefacts of dye injection experimental techniques. Proposes that diffusion rather than bulk flow explains tracer spread. Does not invalidate associations between slow-wave sleep and brain waste clearance, but challenges the aquaporin-4/AQP4-dependent convection mechanism specifically.},
  keywords = {glymphatic, sleep, brain, cerebrospinal fluid, aquaporin, critique, methodology}
}

