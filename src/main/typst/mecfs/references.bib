@article{Myhill2009mitochondrial,
  author = {Myhill, Sarah and Booth, Norman E and McLaren-Howard, John},
  title = {Chronic fatigue syndrome and mitochondrial dysfunction},
  journal = {International Journal of Clinical and Experimental Medicine},
  year = {2009},
  volume = {2},
  number = {1},
  pages = {1--16},
  pmid = {19436827},
  pmcid = {PMC2680051},
  keywords = {ME/CFS, mitochondrial dysfunction, ATP, oxidative phosphorylation, biomarkers},
  note = {Demonstrated strong correlation (P<0.001) between mitochondrial dysfunction and CFS severity. Measured five ATP-related factors in neutrophils; 98.6\% (70/71) CFS patients scored below normal on Mitochondrial Energy Score. Identified reduced ATP availability, impaired oxidative phosphorylation efficiency, and deficient ADP/ATP translocator function. ATP profile test differentiates energy deficiency from psychological causes.}
}

@article{Yamano2016tca_urea,
  author = {Yamano, Emi and Sugimoto, Masahiro and Hirayama, Akiyoshi and Kume, Shigeru and Yamato, Masanori and Jin, Guangxin and Tajima, Sanae and Goda, Nariaki and Iwai, Kazuhiro and Fukuda, Sanae and Yamaguti, Kei and Kuratsune, Hirohiko and Soga, Tomoyoshi and Watanabe, Yasuyoshi and Kataoka, Yukei},
  title = {Index markers of chronic fatigue syndrome with dysfunction of TCA and urea cycles},
  journal = {Scientific Reports},
  year = {2016},
  volume = {6},
  pages = {34990},
  doi = {10.1038/srep34990},
  pmid = {27725685},
  pmcid = {PMC5057083},
  keywords = {ME/CFS, metabolomics, TCA cycle, urea cycle, citrulline, malate, biomarkers},
  note = {Metabolomic study identified significant dysfunction in TCA (Krebs) cycle and urea cycle. Found decreased citrulline, elevated ornithine, and reduced TCA intermediates (citrate, isocitrate, malate) in CFS patients. Developed diagnostic model using pyruvate/isocitrate and ornithine/citrulline ratios with discrimination accuracy suitable for clinical screening. Provides mechanistic basis for L-citrulline-malate supplementation addressing both energy production and ammonia detoxification.}
}

@article{Shungu2012glutathione,
  author = {Shungu, Dikoma C and Weiduschat, Nora and Murrough, James W and Mao, Xiangling and Pillemer, Sarah and Dyke, Jonathan P and Medow, Marvin S and Natelson, Benjamin H and Stewart, Julian M and Mathew, Sanjay J},
  title = {Increased ventricular lactate in chronic fatigue syndrome. {III}. {Relationships} to cortical glutathione and clinical symptoms implicate oxidative stress in disorder pathophysiology},
  journal = {NMR in Biomedicine},
  year = {2012},
  volume = {25},
  number = {9},
  pages = {1073--1087},
  doi = {10.1002/nbm.2772},
  pmid = {22281935},
  pmcid = {PMC3896084},
  keywords = {ME/CFS, glutathione, oxidative stress, lactate, MRS, brain imaging, NAC},
  note = {First MRS documentation of significantly reduced cortical glutathione (GSH) in CFS patients. Strong negative correlation between ventricular lactate and GSH (r = -0.545, p = 0.001). GSH positively correlated with physical functioning ($\rho$ = 0.506, p = 0.001) and energy levels ($\rho$ = 0.606, p < 0.001). Recommends N-acetylcysteine (NAC) over direct GSH supplementation due to blood-brain barrier crossing. Pilot data: 1800 mg/day NAC normalized GSH, lactate, and symptoms. Implicates oxidative stress as central pathophysiological mechanism.}
}

@article{Ogawa1998arginine_nk,
  author = {Ogawa, Masayuki and Nishiura, Tadao and Yoshimura, Makoto and Horikawa, Yoshinori and Yoshida, Harumi and Okajima, Yoshiyuki and Matsumura, Munetoshi and Ogino, Tsuneaki and Watanabe, Takashi and Takishima, Tamotsu},
  title = {Decreased nitric oxide-mediated natural killer cell activation in chronic fatigue syndrome},
  journal = {European Journal of Clinical Investigation},
  year = {1998},
  volume = {28},
  number = {11},
  pages = {937--943},
  doi = {10.1046/j.1365-2362.1998.00373.x},
  pmid = {9824439},
  keywords = {ME/CFS, L-arginine, nitric oxide, natural killer cells, immune dysfunction, iNOS},
  note = {In vitro study (n=20 CFS, n=21 controls) demonstrated that L-arginine treatment (24h) significantly enhanced NK cell activity in healthy controls but failed to produce any effect in CFS patients. Even direct NO donor compounds did not activate NK cells in patients. While iNOS gene expression was normal in both groups, the functional NO-mediated immune activation pathway was impaired. Indicates that L-arginine supplementation alone may be insufficient; suggests need for combination therapy addressing downstream pathway dysfunction (e.g., BH4 cofactor).}
}

@article{Myhill2012audit,
  author = {Myhill, Sarah and Booth, Norman E and McLaren-Howard, John},
  title = {Targeting mitochondrial dysfunction in the treatment of {Myalgic Encephalomyelitis/Chronic Fatigue Syndrome (ME/CFS)} -- a clinical audit},
  journal = {International Journal of Clinical and Experimental Medicine},
  year = {2012},
  volume = {6},
  number = {1},
  pages = {1--15},
  pmcid = {PMC3515971},
  keywords = {ME/CFS, mitochondrial dysfunction, treatment, L-carnitine, glutathione, CoQ10, clinical audit},
  note = {Clinical audit of comprehensive mitochondrial support protocol in 138 ME/CFS patients. All 30 compliant patients (with follow-up testing) showed improvements in mitochondrial function: average 4.14x increase in Mitochondrial Energy Score, 100\% improved in oxidative phosphorylation, 93\% improved in ATP availability. Protocol included stone-age diet, sleep optimization, comprehensive supplementation (L-carnitine, glutathione, CoQ10, niacinamide, B12, D-ribose, magnesium), and pacing. Four non-compliant patients showed minimal improvement, demonstrating requirement for sustained adherence. Limitation: not RCT, specific dosages not provided.}
}

