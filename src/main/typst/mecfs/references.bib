% Sasso/Nunes 2025 oxidative stress PNAS — oxidativestress2025 key
@article{oxidativestress2025,
  author = {Sasso, Etianne M. and Muraki, Katsuhiko and Eaton-Fitch, Natalie and Smith, Peter and Lesslar, Olaf L. and Deed, Gary and Marshall-Gradisnik, Sonya},
  title = {Oxidative stress is a shared characteristic of {ME/CFS} and {Long COVID}},
