  number   = {10},
  pages    = {e70984},
  doi      = {10.1002/brb3.70984},
  pmid     = {41076550},
  url      = {https://doi.org/10.1002/brb3.70984},
  keywords = {narcolepsy, orexin, hypocretin, OX2R, danavorexton, HLA-DQB1, autoimmune, molecular mechanisms},
  research_stream = {orexin-hypothalamic-dysfunction},
  certainty = {0.60},
  note     = {Narrative review. Establishes that $>$90\% of NT1 patients have CSF orexin-A below 110 pg/mL and carry HLA-DQB1*06:02. Autoimmune destruction of up to 95\% of hypothalamic orexin neurons. Emerging therapies: danavorexton (OX2R-selective agonist) improved MWT by 11.1 points vs modafinil. H1N1 influenza and Pandemrix vaccination trigger temporal clustering of NT1 onset, confirming post-infectious orexin loss mechanism. Relevant to ME/CFS: post-infectious onset pattern and partial orexin deficiency overlap.},
}

