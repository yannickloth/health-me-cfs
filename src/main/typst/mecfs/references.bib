  pmid    = {27619189},
  keywords = {interoception, predictive processing, active inference, emotion, allostasis, depression, autonomic, anterior insula},
  note    = {Key review proposing emotions as active interoceptive inferences: the brain predicts causes of visceral afferent signals rather than passively receiving them. Persistent interoceptive prediction errors produce anxiety; learned prediction of allostatic failure produces depressive affect. Directly relevant to ME/CFS depression as accumulated prediction error.}
}

@article{Barrett2015interoceptive,
  author  = {Barrett, Lisa Feldman and Simmons, W Kyle},
  title   = {Interoceptive predictions in the brain},
  journal = {Nature Reviews Neuroscience},
  year    = {2015},
  volume  = {16},
  number  = {7},
  pages   = {419--429},
  doi     = {10.1038/nrn3950},
  pmid    = {26016744},
  keywords = {interoception, prediction, brain, allostasis, emotion, visceral, body, predictive coding},
  note    = {Seminal review establishing interoception as fundamentally predictive: the brain generates top-down predictions of visceral states and processes afferent signals as prediction errors. Introduces the allostatic interoceptive control framework. Foundation for understanding how ME/CFS disrupts the interoceptive hierarchy from brainstem through prefrontal cortex.}
}

@article{Pellicano2012autism,
  author  = {Pellicano, Elizabeth and Burr, David},
  title   = {When the world becomes 'too real': a Bayesian explanation of autistic perception},
  journal = {Trends in Cognitive Sciences},
  year    = {2012},
  volume  = {16},
  number  = {10},
  pages   = {504--510},
  doi     = {10.1016/j.tics.2012.08.009},
  pmid    = {22959875},
  keywords = {autism, predictive coding, Bayesian, perception, prior, sensory, precision, ASD},
  note    = {Influential proposal that autism involves "hypo-prior" or unstable prior beliefs, causing the sensory world to appear overly detailed and literal. Under this model, high sensory precision (underdamped priors) creates information overload and resistance to contextual integration. Contrasts with ME/CFS-acquired interoceptive disruption where lower-level signal corruption (not prior instability) drives sensory difficulties.}
}

@article{Stephan2015depressionallostasis,
  author  = {Stephan, Klaas Enno and Manjaly, Zina-Mary and Mathys, Christoph D and Weber, Lilian A E and Paliwal, Sudhir and Gard, Tim and Tittgemeyer, Marc and Fleming, Stephen M and Haker, Helene and Seth, Anil K and Petzschner, Frederike H},
  title   = {Allostatic self-efficacy: a metacognitive theory of dyshomeostasis-induced fatigue and depression},
