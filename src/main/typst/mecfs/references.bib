  note     = {Narrative review. Proposes orexin system dysregulation as mechanistic link between SARS-CoV-2 infection and PASC autonomic/cardiometabolic symptoms. Orexin regulates baroreflex, sympathetic tone, catecholamine release, electrolyte balance, and circadian rhythms — disruption plausibly explains POTS and orthostatic intolerance in PASC. Acknowledges most mechanistic evidence is animal-derived; human PASC-specific orexin measurements absent. Mechanistic rationale is plausible and internally consistent.},
}

% --- Heinicke et al.\ 2025: Plasma orexin-A in severe COVID-19 ICU patients ---
@article{Heinicke2025orexinCOVID,
  author   = {Heinicke, Ulrike and Talbot, Steven R. and Thanasis, Filippos and Adam, Elisabeth H. and von Knethen, Andreas and Steinbicker, Andrea U. and Zinn, Sebastian and Zacharowski, Kai and Flinspach, Armin N.},
  title    = {Systemic role of orexin {A}, substance {P}, bradykinin, and {DABK} in severe {COVID-19} and 2.5-yr follow-ups: an observational study},
  journal  = {BJA Open},
  year     = {2025},
  volume   = {14},
  pages    = {100415},
  doi      = {10.1016/j.bjao.2025.100415},
  pmid     = {40529720},
  url      = {https://doi.org/10.1016/j.bjao.2025.100415},
  keywords = {orexin-A, COVID-19, PASC, Long COVID, ICU, bradykinin, substance P, survival, plasma measurement},
  research_stream = {orexin-hypothalamic-dysfunction},
  certainty = {0.50},
  note     = {Observational cohort. 78 ICU COVID-19 patients (June 2020--November 2021), 14 survivors at 2.5-yr follow-up, 14 healthy controls. 423 ELISA measurements of plasma orexin-A, substance P, bradykinin, DABK. Orexin-A correlated with ICU survival (Cohen's $d$=0.4) and inversely with length of stay ($r$=--0.26, $p$=0.02). Substance P remained elevated at 2.5-yr follow-up, potentially linking to Long COVID neuropsychological symptoms. Limitations: single-centre, heterogeneous medication exposure, cross-sectional.},
}

% --- Ito et al.\ 2023: Orexin deficiency and REM sleep architecture in narcolepsy ---
@article{Ito2023orexinREM,
  author   = {Ito, Hiroto and Fukatsu, Noriaki and Rahaman, Sheikh Mizanur and Mukai, Yasutaka and Izawa, Shuntaro and Ono, Daisuke and Kilduff, Thomas S. and Yamanaka, Akihiro},
  title    = {Deficiency of orexin signaling during sleep is involved in abnormal {REM} sleep architecture in narcolepsy},
  journal  = {Proceedings of the National Academy of Sciences U.S.A.},
  year     = {2023},
  volume   = {120},
  number   = {41},
  pages    = {e2301951120},
  doi      = {10.1073/pnas.2301951120},
  pmid     = {37796986},
  url      = {https://doi.org/10.1073/pnas.2301951120},
  keywords = {orexin, REM sleep, narcolepsy, sleep architecture, optogenetics, NREM-REM transition, cataplexy},
  research_stream = {orexin-hypothalamic-dysfunction},
  certainty = {0.65},
  note     = {Mouse study using optogenetic control and calcium imaging. Orexin neurons are highly active during wakefulness, show synchronized bursting during NREM, become silent before REM transitions. A subpopulation active during REM suppresses subsequent REM sleep and cataplexy. Disruption of this circuit causes excessive REM intrusions. Provides mechanistic basis for sleep-wake instability in orexin deficiency states including ME/CFS-relevant unrefreshing sleep.},
}

% --- Rauf et al.\ 2025: Orexin deficiency in narcolepsy mechanisms and emerging therapeutics ---
@article{Rauf2025narcolepsyOrexin,
  author   = {Rauf, R. and Asif, S. and AlSaafeen, A. and others},
  title    = {Orexin deficiency in narcolepsy: molecular mechanisms, clinical phenotypes, and emerging therapeutic frontiers},
  journal  = {Brain and Behavior},
  year     = {2025},
