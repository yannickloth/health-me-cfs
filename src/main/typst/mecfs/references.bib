  journal = {Frontiers in Immunology},
  year = {2020},
  volume = {11},
  pages = {388},
  doi = {10.3389/fimmu.2020.00388},
  pmid = {32194572},
  pmcid = {PMC7076627},
  keywords = {IDO1, kynurenine pathway, quinolinic acid, kynurenic acid, neuroinflammation, tryptophan, CNS disorders, autoimmune},
  note = {Comprehensive review of IDO1/IDO2 activity in peripheral and CNS inflammatory disorders. Inflammatory cytokines (IFN-gamma, IL-1beta, TNF-alpha) induce IDO1, diverting tryptophan toward kynurenine metabolites. Quinolinic acid (NMDA agonist) drives excitotoxicity; kynurenic acid (NMDA antagonist) is neuroprotective. Covers role in Huntington's, Alzheimer's, multiple sclerosis, and autoimmune conditions. KMO inhibitors reduce quinolinic acid synthesis as a therapeutic strategy.}
}

@article{LugoHuitron2013quinolinic,
  author = {Lugo-Huitr\'on, Rafael and Ugalde Mu\~niz, Perla and Pineda, Benjam\'in and Pedraza-Chaverr\'i, Jos\'e and R\'ios, Camilo and P\'erez-de la Cruz, Ver\'onica},
  title = {Quinolinic Acid: An Endogenous Neurotoxin with Multiple Targets},
  journal = {Oxidative Medicine and Cellular Longevity},
  year = {2013},
  volume = {2013},
  pages = {104024},
  doi = {10.1155/2013/104024},
  pmid = {24089628},
  pmcid = {PMC3780648},
  keywords = {quinolinic acid, NMDA receptor, excitotoxicity, neurotoxin, kynurenine, oxidative stress, neurodegeneration},
  note = {Detailed mechanistic review of quinolinic acid (QUIN) neurotoxicity. QUIN is an NMDA receptor agonist that at sub-threshold concentrations triggers excitotoxic cascades through: NMDA receptor overactivation, oxidative stress, mitochondrial dysfunction, cytoskeletal disruption, and apoptosis. Multiple non-NMDA targets explain why QUIN toxicity exceeds pure receptor pharmacology. Directly relevant to ME/CFS kynurenine excitotoxicity hypothesis.}
}

@article{Bai2021kynurenineTherapy,
  author = {Bai, Margaret Y. and Lovejoy, David B. and Guillemin, Gilles J. and Kozak, Ron and Stone, Trevor W. and Koola, Maju Mathew},
