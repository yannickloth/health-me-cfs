@article{BillingRoss2016mtDNA,
  author    = {Billing-Ross, Paul and Germain, Arnaud and Ye, Ketian and Keinan, Alon and Gu, Zhenglong and Hanson, Maureen R},
  title     = {Mitochondrial {DNA} variants correlate with symptoms in myalgic encephalomyelitis/chronic fatigue syndrome},
  journal   = {Journal of Translational Medicine},
  year      = {2016},
  volume    = {14},
  pages     = {19},
  doi       = {10.1186/s12967-016-0771-6},
  pmid      = {26791940},
  pmcid     = {PMC4719218},
  url       = {https://doi.org/10.1186/s12967-016-0771-6},
  keywords  = {ME/CFS, mtDNA, mitochondrial DNA, haplogroup, heteroplasmy, symptoms, susceptibility},
  certainty = {0.55},
  research_stream = {mitochondrial-predisposition},
  note      = {Complete mitochondrial genome sequencing, 193 ME/CFS cases vs 196 controls. No association between mtDNA variants and ME/CFS susceptibility (disease onset). However, haplogroups J, U, H and 8 specific SNPs significantly associated with symptom severity and type (joint pain, bloating, post-exertional "feeling dead"). Heteroplasmy levels low and comparable. Key null finding: inherited mtDNA variants do not predispose to ME/CFS but may modulate symptom expression. Requires independent replication.}
}

@article{Venter2019mtDNA,
  author    = {Venter, Mareke and Tomas, Cara and Pienaar, Ilse S and Strassheim, Victoria and Erasmus, Engela and Ng, Wan-Fai and Howell, Neil and Newton, Julia L and van der Westhuizen, Francois H and Elson, Joanna L},
  title     = {{MtDNA} population variation in Myalgic Encephalomyelitis/{Chronic} Fatigue Syndrome in two populations: a study of mildly deleterious variants},
  journal   = {Scientific Reports},
  year      = {2019},
  volume    = {9},
  pages     = {2914},
  doi       = {10.1038/s41598-019-39060-1},
  pmid      = {30814539},
  pmcid     = {PMC6393470},
  url       = {https://doi.org/10.1038/s41598-019-39060-1},
  keywords  = {ME/CFS, mtDNA, mildly deleterious variants, haplogroup, population genetics, UK, South Africa},
  certainty = {0.52},
  research_stream = {mitochondrial-predisposition},
  note      = {Whole mitochondrial genome sequencing in two independent cohorts: UK (118 patients, 64 controls), South Africa (143 patients, 98 controls). No clinically proven pathogenic mutations. Unexpected finding: ME/CFS patients had significantly fewer computationally-predicted mildly deleterious variants (UK: 55\% vs 27\% controls p=0.0008; SA: 56\% vs 41\% p=0.03). Suggests protective purifying selection or altered susceptibility landscape rather than classic mitochondrial disease mechanism. Replication of pattern across independent cohorts strengthens reliability.}
}

@article{Albright2011heritability,
  author    = {Albright, Frederick and Light, Kathleen and Light, Alan and Bateman, Lucinda and Cannon-Albright, Lisa A},
  title     = {Evidence for a heritable predisposition to Chronic Fatigue Syndrome},
  journal   = {BMC Neurology},
  year      = {2011},
  volume    = {11},
  pages     = {62},
  doi       = {10.1186/1471-2377-11-62},
  pmid      = {21619629},
  pmcid     = {PMC3128000},
  url       = {https://doi.org/10.1186/1471-2377-11-62},
  keywords  = {ME/CFS, CFS, heritability, family clustering, genealogy, Utah Population Database, genetic predisposition},
  certainty = {0.62},
  research_stream = {mitochondrial-predisposition},
  note      = {Population-based genealogical study using Utah Population Database, 811 CFS cases. First-degree relatives: RR=2.70 (p=0.001); second-degree: RR=2.34 (p=0.008); third-degree: RR=1.93 (p=0.009). Excess relatedness persisted when excluding close relatives (p=0.010), arguing against purely shared-environment explanation. Does not distinguish maternal vs paternal inheritance, so mitochondrial contribution cannot be inferred directly. Establishes that a heritable component exists; molecular basis undetermined.}
}

@article{Chang2020haploADHD,
  author    = {Chang, Xiao and Liu, Yichuan and Mentch, Frank and Glessner, Joseph and Qu, Huiqi and Nguyen, Kenny and Sleiman, Patrick M A and Hakonarson, Hakon},
  title     = {Mitochondrial {DNA} haplogroups and risk of attention deficit and hyperactivity disorder in {European Americans}},
  journal   = {Translational Psychiatry},
  year      = {2020},
  volume    = {10},
  pages     = {370},
  doi       = {10.1038/s41398-020-01064-1},
  pmid      = {33139694},
  pmcid     = {PMC7608630},
  url       = {https://doi.org/10.1038/s41398-020-01064-1},
  keywords  = {ADHD, mtDNA, haplogroup, European, K, U, HHV, mitochondrial dysfunction, risk, protective},
  certainty = {0.65},
  research_stream = {mitochondrial-predisposition},
  note      = {Case-control study, 2076 ADHD cases and 5078 controls across three independent European cohorts; haplogroups inferred from SNP arrays. Meta-analysis: haplogroups K and U protective (reduced ADHD risk); haplogroup HHV* increased risk. Haplogroups K/U overlap with ME/CFS symptom-modifying haplogroups from Billing-Ross 2016 (haplogroup U associated with less severe bloating in ME/CFS). Limitation: all cohorts from same institution; haplogroups inferred not sequenced.}
}

@article{Giannoulis2024sysrevmtADHD,
  author    = {Giannoulis, Stavroula V and M{\"u}ller, Daniel and Kennedy, James L and Gon{\c{c}}alves, Vanessa},
  title     = {Systematic review of mitochondrial genetic variation in attention-deficit/hyperactivity disorder},
  journal   = {European Child \& Adolescent Psychiatry},
  year      = {2024},
  volume    = {33},
  number    = {6},
  pages     = {1675--1685},
  doi       = {10.1007/s00787-022-02030-6},
  pmid      = {35796884},
  url       = {https://doi.org/10.1007/s00787-022-02030-6},
  keywords  = {ADHD, mtDNA, mitochondrial genetic variation, copy number, haplogroup, SNP, systematic review},
  certainty = {0.58},
  research_stream = {mitochondrial-predisposition},
  note      = {Systematic review; 507 articles screened, 10 primary studies selected. Findings: increased mtDNA copy number, specific SNP associations, and haplogroup effects documented across ADHD populations. Mitochondrial genetic variation in both mtDNA and nuclear-encoded mitochondrial genes may contribute to ADHD pathophysiology. Methodological limitations of primary studies noted (small samples, diverse populations, different measurement methods). Identifies the field as underdeveloped relative to other psychiatric disorders.}
}

@article{Verma2016ADHDcybrid,
  author    = {Verma, Poonam and Singh, Alpana and Nthenge-Ngumbau, Dominic Ngima and Rajamma, Usha and Sinha, Swagata and Mukhopadhyay, Kanchan and Mohanakumar, Kochupurackal P},
  title     = {Attention deficit-hyperactivity disorder suffers from mitochondrial dysfunction},
  journal   = {BBA Clinical},
  year      = {2016},
  volume    = {6},
  pages     = {153--158},
  doi       = {10.1016/j.bbacli.2016.10.003},
  pmid      = {27896136},
  pmcid     = {PMC5121149},
  url       = {https://doi.org/10.1016/j.bbacli.2016.10.003},
  keywords  = {ADHD, mitochondrial dysfunction, cybrid, Complex V, ATPase, oxidative stress, bioenergetics},
  certainty = {0.30},
  research_stream = {mitochondrial-predisposition},
  note      = {Cybrid cell lines created by fusing ADHD patient platelets with mitochondria-depleted neuroblastoma cells (n=3 ADHD, 4 controls, ages 5--13). Found significantly lower cellular and mitochondrial respiration, reduced ATPase6/8 transcripts, decreased Complex V activity, loss of mitochondrial membrane potential, elevated oxidative stress. First direct evidence that ADHD-associated mitochondrial dysfunction is transferable via patient mitochondria. Very small sample; cybrid model limitations include nuclear-cytoplasmic mismatch artifacts. Low certainty due to n=3, but mechanistically important.}
}

@article{Ogutlu2022ADHDmito,
  author    = {{\"O}g{\"u}tl{\"u}, Hakan and Ka{\c{s}}ak, Meryem and Tabur, Selin Tutku},
  title     = {Mitochondrial Dysfunction in Attention Deficit Hyperactivity Disorder},
  journal   = {Eurasian Journal of Medicine},
  year      = {2022},
  volume    = {54},
  number    = {Suppl 1},
  pages     = {S187--S195},
  doi       = {10.5152/eurasianjmed.2022.22187},
  pmid      = {36655466},
  pmcid     = {PMC11163340},
  url       = {https://doi.org/10.5152/eurasianjmed.2022.22187},
  keywords  = {ADHD, mitochondrial dysfunction, mtDNA copy number, oxidative stress, haplogroup B4, haplogroup K, haplogroup U, cybrid, biomarker},
  certainty = {0.45},
  research_stream = {mitochondrial-predisposition},
  note      = {Narrative review synthesizing human and animal studies on ADHD and mitochondrial dysfunction. Key data points: mtDNA copy number ~1.3x higher in ADHD vs controls; haplogroup B4 increases ADHD risk; haplogroups K and U reduce risk in European populations; 10398 A/G polymorphism significantly associated with ADHD in Korean cohort. Mitochondrial apoptotic signaling identified as second strongest mechanism in ADHD cases via GWAS. Notes parallel with ME/CFS: both conditions share reduced spare respiratory capacity, elevated oxidative stress, altered monoaminergic function. Haplogroup U appears protective in both ADHD (Chang 2020) and symptom-modifying in ME/CFS (Billing-Ross 2016).}
}

@article{Fanet2021BH4neuro,
  author    = {Fanet, Ha{\"i}l and Capuron, Lucile and Castanon, Nathalie and Calon, Fr{\'e}d{\'e}ric and Vancassel, Sylvie},
  title     = {Tetrahydrobiopterin ({BH4}) pathway: from metabolism to neuropsychiatry},
  journal   = {Current Neuropharmacology},
  year      = {2021},
  volume    = {19},
  number    = {5},
  pages     = {591--609},
  doi       = {10.2174/1570159X18666200729103529},
  pmid      = {32744952},
  url       = {https://pubmed.ncbi.nlm.nih.gov/32744952/},
  keywords  = {BH4, tetrahydrobiopterin, dopamine, serotonin, nitric oxide, neuropsychiatry, inflammation, oxidative stress, tyrosine hydroxylase},
  certainty = {0.50},
  research_stream = {adhd-energy-mecfs},
  note      = {Narrative review. BH4 cofactor for TH (dopamine/NE synthesis), TPH (serotonin synthesis), and all three NOS isoforms. Inflammatory cytokines paradoxically increase BH4 synthesis but drive its oxidation, causing net monoamine depletion. Reduced CSF BH4 associated with depression, Parkinson's, Alzheimer's, ADHD, autism. BH4 also has anti-inflammatory and anti-oxidant roles independent of neurotransmitter synthesis. Mechanistic bridge: infection/neuroinflammation → BH4 oxidative depletion → catecholamine deficiency → both ADHD-like and ME/CFS symptoms. Complements existing BH4 entries in bib (orthostatic intolerance).}
}

% --- Lower-baseline predisposition research stream ---
@article{Frye2024ASDmitochondria,
  author   = {Frye, Richard E and Rincon, Nicole and McCarty, Patrick J and Brister, Danielle and Scheck, Adrienne C and Rossignol, Daniel A},
  title    = {Biomarkers of mitochondrial dysfunction in autism spectrum disorder: {A} systematic review and meta-analysis},
  journal  = {Neurobiology of Disease},
  year     = {2024},
  volume   = {197},
  pages    = {106520},
  doi      = {10.1016/j.nbd.2024.106520},
  pmid     = {38703861},
  url      = {https://pubmed.ncbi.nlm.nih.gov/38703861/},
  keywords = {autism, ASD, mitochondrial dysfunction, lactate, pyruvate, ATP, creatine kinase, energy metabolism, meta-analysis},
  certainty = {0.70},
  research_stream = {lower-baseline-predisposition},
  note     = {Systematic review and meta-analysis, 204 studies. Elevated lactate (17\%), pyruvate (41\%), alanine (15\%), creatine kinase (9\%) in ASD. Significant ATP deficit and elevated lactate:pyruvate ratio (moderate-to-large effect sizes). Mitochondrial dysfunction linked to GI symptoms, oxidative stress, immune dysfunction. Carnitine and ubiquinol showed benefit. Core evidence: ASD involves systemic mitochondrial dysfunction that would reduce metabolic reserve prior to any infectious trigger.}
}

@article{Kindgren2021hEDSadhd,
  author   = {Kindgren, Erik and Qui{\~n}ones Perez, Antonia and Knez, Rajna},
  title    = {Prevalence of {ADHD} and Autism Spectrum Disorder in Children with Hypermobility Spectrum Disorders or Hypermobile {Ehlers-Danlos} Syndrome: A Retrospective Study},
  journal  = {Neuropsychiatric Disease and Treatment},
  year     = {2021},
  volume   = {17},
  pages    = {379--388},
  doi      = {10.2147/NDT.S290494},
  pmid     = {33603376},
  pmcid    = {PMC7882457},
  url      = {https://pmc.ncbi.nlm.nih.gov/articles/PMC7882457/},
  keywords = {hEDS, HSD, hypermobility, ADHD, autism, neurodevelopmental, comorbidity, pediatric},
  certainty = {0.60},
  research_stream = {lower-baseline-predisposition},
  note     = {Retrospective study n=201 children (ages 6--18) with hEDS or HSD. ADHD verified diagnosis 16\%, additional 7\% under investigation. ASD 6\%. In age group 17--18 years, ADHD present in 46\%. hEDS showed significantly higher ADHD rate than HSD. Establishes the neurodivergent-hypermobility axis; children with hEDS/HSD should be routinely screened for neuropsychiatric symptoms.}
}

@article{Csecs2022hypermobility,
  author   = {Csecs, Jenny L L and Iodice, Valeria and Rae, Charlotte L and Brooke, Anna and Simmons, Rosie and Quadt, Lisa and Savage, Ginny K and Dowell, Nicholas G and Prowse, Florence and Themelis, Konstantinos and Mathias, Christopher J and Critchley, Hugo D and Eccles, Jessica A},
  title    = {Joint Hypermobility Links Neurodivergence to Dysautonomia and Pain},
  journal  = {Frontiers in Psychiatry},
  year     = {2022},
  volume   = {12},
  pages    = {786916},
  doi      = {10.3389/fpsyt.2021.786916},
  pmid     = {35185636},
  pmcid    = {PMC8847158},
  url      = {https://pmc.ncbi.nlm.nih.gov/articles/PMC8847158/},
  keywords = {hypermobility, neurodivergence, autism, ADHD, Tourette syndrome, dysautonomia, orthostatic intolerance, pain, connective tissue},
  certainty = {0.65},
  research_stream = {lower-baseline-predisposition},
  note     = {n=109 neurodivergent adults (autism, ADHD, Tourette syndrome). Generalized joint hypermobility 51\% vs.\ 20\% in general population. Female prevalence 69\%. Joint hypermobility mediated the association between neurodivergence and both dysautonomia symptoms and pain. Establishes the neurodivergence--hypermobility--dysautonomia triangle: connective tissue variation as unifying predisposing feature across these comorbid conditions.}
}

@article{BaezaVelasco2025autismEDS,
  author   = {Baeza-Velasco, Carolina and Vergne, Judith and Poli, Marianna and Kalisch, Larissa and Calati, Raffaella},
  title    = {Autism in the context of joint hypermobility, hypermobility spectrum disorders, and {Ehlers-Danlos} syndromes: {A} systematic review and prevalence meta-analyses},
  journal  = {Autism},
  year     = {2025},
  volume   = {29},
  number   = {8},
  pages    = {1939--1958},
  doi      = {10.1177/13623613251328059},
  pmid     = {40145613},
  url      = {https://pubmed.ncbi.nlm.nih.gov/40145613/},
  keywords = {autism, ASD, hypermobility, hEDS, EDS, connective tissue, comorbidity, meta-analysis, prevalence},
  certainty = {0.70},
  research_stream = {lower-baseline-predisposition},
  note     = {Systematic review and meta-analyses, 20 studies. Prevalence of JH in autistic individuals: 22.3\% overall, 31\% when assessed clinically. Prevalence of HSD/EDS in autistic samples: 27.9\% overall, 39\% when assessed clinically. 12/15 studies found significant ASD--JH association. Autistic individuals are 7.4 times more likely to have EDS than comparison groups. Confirms the autism--hypermobility cluster as a high-risk phenotype for ME/CFS-adjacent conditions.}
}

@article{Lau2015migraineCFS,
  author   = {Lau, Chi-In and Lin, Che-Chen and Chen, Wu-Hsien and Wang, Hsin-Chuan and Kao, Chia-Hung},
  title    = {Increased risk of chronic fatigue syndrome in patients with migraine: {A} retrospective cohort study},
  journal  = {Journal of Psychosomatic Research},
  year     = {2015},
  volume   = {79},
  number   = {6},
  pages    = {514--518},
  doi      = {10.1016/j.jpsychores.2015.10.005},
  pmid     = {26505533},
  url      = {https://pubmed.ncbi.nlm.nih.gov/26505533/},
  keywords = {migraine, chronic fatigue syndrome, risk factor, cohort, epidemiology, mitochondrial dysfunction, central sensitization},
  certainty = {0.60},
  research_stream = {lower-baseline-predisposition},
  note     = {Retrospective cohort, Taiwan National Health Insurance Database, n=6,902 migraine patients vs.\ n=27,608 controls (2006--2010). CFS incidence 52.72 vs.\ 28.85 per 10,000 person-years in migraine vs.\ controls (IRR~1.5). Age $\geq$65: IRR=2.11. Proposed mechanisms: mitochondrial dysfunction and central sensitization as shared substrate. Limitation: older cohort, Taiwan database, ICD-based diagnoses without clinical validation.}
}

@article{Wang2023migraineMito,
  author   = {Wang, Yicheng and Wang, Yongli and Yue, Guangxin and Zhao, Yonglie},
  title    = {Energy metabolism disturbance in migraine: {From} a mitochondrial point of view},
  journal  = {Frontiers in Physiology},
  year     = {2023},
  volume   = {14},
  pages    = {1133528},
  doi      = {10.3389/fphys.2023.1133528},
  pmid     = {37123270},
  pmcid    = {PMC10133718},
  url      = {https://pubmed.ncbi.nlm.nih.gov/37123270/},
  keywords = {migraine, mitochondria, energy metabolism, lactate, NAA, cytochrome c oxidase, oxidative phosphorylation, cortical spreading depression},
  certainty = {0.60},
  research_stream = {lower-baseline-predisposition},
  note     = {Narrative review. Migraineurs show elevated blood lactate, lower NAA, decreased activities of NADH dehydrogenase, citrate synthase, and cytochrome c oxidase. 95\% of cellular energy from mitochondrial respiratory chain; impaired oxidative phosphorylation lowers pain threshold and neuronal excitability. Many migraine triggers (stress, sleep deprivation, fasting, exercise) are also ME/CFS triggers — shared energy metabolism vulnerability. Establishes migraine as a condition of reduced mitochondrial reserve.}
}

@article{ColpaniFilho2025BH4ASD,
  author   = {Colpani Filho, C and Melfior, L and Ramos, S L and Pizi, M S O and Taruhn, L F and Muller, M E and Nunes, T K and Schmitt, L O and Gaspar, J M and de Oliveira, M A and Tassinari, G and Cruz, L and Latini, A},
  title    = {Tetrahydrobiopterin and Autism Spectrum Disorder: {A} Systematic Review of a Promising Therapeutic Pathway},
  journal  = {Brain Sciences},
  year     = {2025},
  volume   = {15},
  number   = {2},
  pages    = {151},
  doi      = {10.3390/brainsci15020151},
  pmid     = {40002484},
  pmcid    = {PMC11853471},
  url      = {https://pubmed.ncbi.nlm.nih.gov/40002484/},
  keywords = {BH4, tetrahydrobiopterin, autism, ASD, GCH1, dopamine, serotonin, nitric oxide, neurotransmitter, neurodevelopmental},
  certainty = {0.60},
  research_stream = {lower-baseline-predisposition},
  note     = {Systematic review. Lower BH4 levels consistently found in biological samples from ASD individuals vs.\ controls. Elevated neopterin in plasma/urine but decreased in CSF; elevated NO. BH4 is cofactor for dopamine, serotonin, norepinephrine, and NO synthesis. BH4 supplementation shows potential to improve ASD symptoms. Connects to existing BH4-ME/CFS literature: shared GCH1 pathway may predispose ASD individuals to ME/CFS-like metabolic fragility.}
}

@article{DelRosso2026ironNeurodevelopmental,
  author   = {DelRosso, Lourdes M and Estrada Chaverri, Luis and Ceballos Fuentes, Francisco A},
  title    = {Iron Deficiency Across Neurodevelopmental Disorders: Comparative Insights from {ADHD} and Autism Spectrum Disorder},
  journal  = {Children (Basel)},
  year     = {2026},
  volume   = {13},
  number   = {2},
  pages    = {180},
  doi      = {10.3390/children13020180},
  pmid     = {41749537},
  url      = {https://pubmed.ncbi.nlm.nih.gov/41749537/},
  keywords = {iron deficiency, ADHD, autism, ASD, ferritin, dopamine, mitochondrial, sleep, restless legs, fatigue, neurodevelopmental},
  certainty = {0.60},
  research_stream = {lower-baseline-predisposition},
  note     = {Narrative review. Iron deficiency (ID) common in ADHD and ASD; reduced brain iron in dopaminergic regions on neuroimaging in ADHD. In ASD: ferritin <50 ng/mL linked to sleep-related motor symptoms. ID reduces hippocampal mitochondrial motility and size. Iron is cofactor for dopamine/serotonin/NE synthesis and mitochondrial complex I/II. Ferritin thresholds recommended: <30 ng/mL for ADHD, <50 ng/mL for ASD. ID as a modifiable metabolic reserve reducer in neurodivergent populations.}
}

@article{Raw2025neurodivergencePostCOVID,
  author   = {Raw, Rachael K and Rees, Jon and Pearson, Amy and Chadwick, David R},
  title    = {Neurodivergence as a Risk Factor for {Post-COVID-19} Syndrome},
  journal  = {COVID},
  year     = {2025},
  volume   = {6},
  number   = {1},
  pages    = {1--7},
  doi      = {10.3390/covid6010001},
  url      = {https://www.mdpi.com/2673-8112/6/1/1},
  keywords = {neurodivergence, autism, autistic traits, sensory reactivity, Long COVID, post-COVID syndrome, central sensitization, risk factor, healthcare workers},
  certainty = {0.45},
  research_stream = {lower-baseline-predisposition},
  note     = {Cross-sectional study n=267 healthcare workers. Higher autistic trait scores predicted COVID-19 symptoms lasting >12 weeks regardless of formal autism diagnosis. Sensory reactivity subscale was the strongest predictor. Proposed mechanism: central sensitization in neurodivergent individuals amplifies post-viral symptom burden. LIMITATION: small sample, healthcare workers only, self-reported autism traits (not clinical diagnosis), no biomarker data.}
}

