@article{Friston2010FreeEnergy,
  author = {Friston, Karl},
  title = {The Free-Energy Principle: A Unified Brain Theory?},
  journal = {Nature Reviews Neuroscience},
  year = {2010},
  volume = {11},
  number = {2},
  pages = {127--138},
  doi = {10.1038/nrn2787},
  pmid = {20068583},
  keywords = {free energy principle, predictive coding, Bayesian brain, prediction error, perception, action, optimization},
  note = {Landmark review by Friston proposing free energy minimization as a unified principle for perception, action and learning. Key concept: brain as a generative model minimizing surprise (free energy/prediction error). Perception = updating beliefs to match sensory data; action = changing sensory data to match beliefs. Underpins active inference and predictive coding frameworks. Foundational theory for interoceptive prediction error model of ME/CFS symptoms. Nature Reviews Neuroscience, high impact.}
}

@article{Kadota2010Interoception,
  author = {Kadota, Yoshiko and Cooper, Geoffrey and Burton, Allan R and Lemon, Jessica and Schall, Ulrich and Lloyd, Andrew and Vollmer-Conna, Uté},
  title = {Autonomic Hyper-Vigilance in Post-Infective Fatigue Syndrome},
  journal = {Biological Psychology},
  year = {2010},
  volume = {85},
  number = {1},
  pages = {97--103},
  doi = {10.1016/j.biopsycho.2010.05.009},
  pmid = {20678991},
  keywords = {chronic fatigue syndrome, post-infective fatigue, interoception, heartbeat discrimination, autonomic, hypervigilance, pain threshold, cardiac},
  note = {Case-control study (23 post-infective fatigue syndrome, 25 healthy controls). PIFS associated with: higher heartbeat discrimination accuracy (heightened interoceptive sensitivity), lower pressure pain threshold, insensitivity to Stroop task difficulty in cardiac response, lack of cardiac habituation. Heightened interoceptive sensitivity strongly correlated with current symptoms. First evidence of autonomic hyper-vigilance in post-infective fatigue -- consistent with attentional bias toward internal body signals predicted by interoceptive inference model. Directly supports section 15.15.}
}

