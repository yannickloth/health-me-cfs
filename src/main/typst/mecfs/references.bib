  keywords = {histamine H3 receptor, presynaptic autoreceptor, dopamine, acetylcholine, neurotransmitter, cognitive, brain, heteroreceptor},
  note = {Review of H3 receptor pharmacology and therapeutic applications. H3R acts as a presynaptic autoreceptor and heteroreceptor, regulating histamine synthesis/release and modulating dopamine, acetylcholine, norepinephrine, and GABA release. H3R antagonists enhance neurotransmitter release and improve cognitive function. Relevant to ME/CFS: mast-cell-derived histamine activating H3R inhibits acetylcholine and dopamine release, potentially contributing to cognitive dysfunction and fatigue.}
}



% --- 15.10 Glymphatic Dysfunction ---

@article{Wostyn2018glymphatic,
  author = {Wostyn, Peter and De Deyn, Peter Paul},
  title = {The Putative Glymphatic Signature of Chronic Fatigue Syndrome: A New View on the Disease Pathogenesis and Therapy},
  journal = {Medical Hypotheses},
  year = {2018},
  volume = {118},
  pages = {142--145},
  doi = {10.1016/j.mehy.2018.07.007},
  pmid = {30037603},
