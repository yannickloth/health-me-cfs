@article{Yang2020GPR81,
  author = {Yang, Kun and Xu, Jiaming and Fan, Mingying and Tu, Fang and Wang, Xuejing and Ha, Tuanzhu and Williams, David L and Li, Chuanfu},
  title = {Lactate Suppresses Macrophage Pro-Inflammatory Response to {LPS} Stimulation by Inhibition of {YAP} and {NF}-$\kappa${B} Activation via {GPR81}-Mediated Signaling},
  journal = {Frontiers in Immunology},
  year = {2020},
  volume = {11},
  pages = {587913},
  doi = {10.3389/fimmu.2020.587913},
  pmid = {33123172},
  pmcid = {PMC7573489},
  keywords = {lactate, GPR81, HCAR1, macrophage, NF-kB, YAP, anti-inflammatory, innate immunity},
  note = {Mechanistic study in Raw 264.7 and bone marrow-derived macrophages. Lactate via GPR81 activates AMPK and LATS to phosphorylate and inactivate YAP transcriptional co-activator; YAP inactivation disrupts YAP-NF-kB p65 interaction, reducing TNF-alpha and IL-6 production. GPR81 (HCA1/HCAR1) is the lactate receptor. Provides mechanistic basis for the anti-inflammatory paradox of lactate at high exercise loads in ME/CFS: the GPR81 brake may be desensitized or dysfunctional. Foundational for section 15.13 metabolic danger signals.}
}

