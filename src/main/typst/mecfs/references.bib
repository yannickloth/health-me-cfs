}

@article{Sobecki2021NKWoundHypoxia,
  author   = {Sobecki, Michal and Krzywinska, Ewelina and Nagarajan, Suresh and Audig{\'e}, Annelise and Hu{\`y}nh, Khai and Zacharjasz, Julien and Debbache, Julien and Kerdiles, Yann and Gotthardt, Dagmar and Takeda, Norihiko and Fandrey, Joachim and Sommer, Lukas and Sexl, Veronika and Stockmann, Christian},
  title    = {{NK} cells in hypoxic skin mediate a trade-off between wound healing and antibacterial defence},
  journal  = {Nature Communications},
  year     = {2021},
  volume   = {12},
  pages    = {4700},
  doi      = {10.1038/s41467-021-25065-w},
  pmid     = {34349124},
  url      = {https://doi.org/10.1038/s41467-021-25065-w},
  keywords = {NK cell, wound healing, HIF-1alpha, IFN-gamma, GM-CSF, skin, hypoxia},
  note     = {Mechanistic mouse study. NK cells are required participants in wound closure: their HIF-1alpha/IFN-gamma/GM-CSF output directly modulates healing rate. NK-depleted or NK-exhausted contexts impair tissue repair. Certainty: 0.75 (high-quality mechanistic study, Nature Comms; mouse model — human translation indirect).}
}

@article{Xue2018ANSWoundHealing,
  author   = {Xue, Yujing and He, Jing and Xiao, Chunhong and Guo, Yao and Fu, Ting and Liu, Jie and Lin, Chunyang and Wu, Minhao and Yang, Ye and Dong, Dong and Pan, Haiting and Xia, Chunqing and Ren, Liying and Li, Zongfang},
  title    = {The mouse autonomic nervous system modulates inflammation and epithelial renewal after corneal abrasion through the activation of distinct local macrophages},
  journal  = {Mucosal Immunology},
  year     = {2018},
  volume   = {11},
  number   = {5},
  pages    = {1496--1511},
  doi      = {10.1038/s41385-018-0031-6},
  pmid     = {29988115},
  url      = {https://doi.org/10.1038/s41385-018-0031-6},
  keywords = {autonomic nervous system, sympathetic, wound healing, macrophage, dysautonomia},
  note     = {Mechanistic mouse study. Sympathetic activation inhibits reepithelialization and increases neutrophil influx; parasympathetic activation promotes healing via distinct macrophage subsets. ME/CFS sympathetic overactivation (POTS, dysautonomia) thus predicts impaired wound healing. Certainty: 0.70 (strong mechanistic evidence; mouse cornea model — epithelial repair mechanisms broadly conserved).}
}

@article{Barrenas2019SIVWoundHealing,
  author   = {Barre{\~n}as, Fredrik and Raehtz, Kevin and Xu, Changxi and Law, Lynn and Green, Richard R and Silvestri, Guido and Bosinger, Steven E and Nishida, Andrew and Li, Qingsheng and Lu, Wuxun and Zhang, Jieliang and Thomas, Matthew J and Chang, Jean and Smith, Elise and Weiss, Joseph M and Dawoud, Reem A and Richter, Gisela H and Trichel, Anita and Ma, Di and Peng, Xuan and Komorowski, Jan and Apetrei, Cristian and Pandrea, Ivona and Gale, Michael Jr},
  title    = {Macrophage-associated wound healing contributes to {African} green monkey {SIV} pathogenesis control},
  journal  = {Nature Communications},
  year     = {2019},
  volume   = {10},
  pages    = {5101},
  doi      = {10.1038/s41467-019-12987-9},
  pmid     = {31704931},
  url      = {https://doi.org/10.1038/s41467-019-12987-9},
  keywords = {wound healing, immune exhaustion, tissue repair, macrophage, SIV, TGF-beta},
  note     = {Transcriptomics/comparative immunology. Failure to activate regenerative wound healing mechanisms during chronic viral infection predicts immune exhaustion and pathology. Mucosal tissue repair is an active requirement for immune homeostasis — not a passive autonomous process. Certainty: 0.70 (Nature Comms; non-human primate model; indirect relevance to ME/CFS via immune exhaustion analog).}
}

@article{Stanojcic2016ImmuneExhaustionBurns,
  author   = {Stanojcic, Mile and Chen, Peter and Xiu, Fangming and Jeschke, Marc G},
  title    = {Impaired Immune Response in Elderly Burn Patients: New Insights Into the Immune-senescence Phenotype},
  journal  = {Annals of Surgery},
  year     = {2016},
  volume   = {264},
  number   = {1},
  pages    = {195--202},
  doi      = {10.1097/SLA.0000000000001408},
  pmid     = {26649579},
  url      = {https://doi.org/10.1097/SLA.0000000000001408},
  keywords = {immune exhaustion, wound healing, NK cell, elderly, burn, sepsis},
  note     = {Prospective clinical study; n=130 (94 adults + 36 elderly) + 10 controls. Immune exhaustion phenotype predicts impaired early wound healing response and higher sepsis/mortality. Pattern mirrors ME/CFS immune profile (blunted early response, dysregulated later response). Certainty: 0.70 (clinical, adequately powered; burn patients not directly analogous to ME/CFS but immune exhaustion mechanism is shared).}
}

@article{Petri2017MSCNKTGFb,
  author   = {Petri, Ruth M and Hackel, Annette and Hahnel, Kathrin and Dumitru, Claudia A and Bruderek, Kirsten and Floh{\'e}, Stefanie B and Paschen, Annette and Lang, Stephan and Brandau, Sven},
  title    = {Activated Tissue-Resident Mesenchymal Stromal Cells Regulate the Immune Response in the Tumor Microenvironment},
  journal  = {Stem Cell Reports},
  year     = {2017},
  volume   = {9},
  number   = {3},
  pages    = {985--998},
  doi      = {10.1016/j.stemcr.2017.06.020},
  pmid     = {28781075},
  url      = {https://doi.org/10.1016/j.stemcr.2017.06.020},
  keywords = {NK cell, TGF-beta, MSC, wound healing, angiogenesis, regulatory NK},
  note     = {In vitro mechanistic. TGF-beta and IL-6 drive NK cells into regulatory senescent-like state; these NK cells then promote MSC pro-angiogenic properties for repair. In ME/CFS, chronically elevated TGF-beta may constitutively activate this suppressive circuit, locking NK cells in a non-cytotoxic state and impairing repair completion. Certainty: 0.60 (in vitro only; indirect inference for ME/CFS).}
}

@article{Abhimanyu2021PostInfectiousEpigenetics,
  author   = {Abhimanyu and Ontiveros, Carlos O and Guerra-Resendez, Roberto S and Nishiguchi, Tomoki and Ladki, Muneeb and Hilton, Isaac B and Schlesinger, Larry S and DiNardo, Andrew R},
