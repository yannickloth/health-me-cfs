@article{Woolf2011CentralSensitization,
  author = {Woolf, Clifford J},
  title = {Central Sensitization: Implications for the Diagnosis and Treatment of Pain},
  journal = {Pain},
  year = {2011},
  volume = {152},
  number = {3 Suppl},
  pages = {S2--S15},
  doi = {10.1016/j.pain.2010.09.030},
  pmid = {20961685},
  pmcid = {PMC3268359},
  keywords = {central sensitization, pain, wind-up, NMDA receptor, dorsal horn, fibromyalgia, allodynia, hyperalgesia},
  note = {Landmark Harvard review by Woolf defining central sensitization: nociceptor-driven increase in excitability of central nociceptive neurons. Key mechanisms: wind-up (temporal summation), LTP-like synaptic plasticity in dorsal horn, NMDA receptor activation. Demonstrates central sensitization in fibromyalgia, musculoskeletal disorders, visceral pain syndromes. Comorbidity pattern suggests shared central mechanism. Foundational reference for nociplastic pain framework.}
}

@article{Nijs2012painCFS,
  author = {Nijs, Jo and Crombez, Geert and Meeus, Mira and Knoop, Hans and Damme, Stefaan Van and Cauwenbergh, Veerle and Bleijenberg, Gijs},
  title = {Pain in Patients with Chronic Fatigue Syndrome: Time for Specific Pain Treatment?},
  journal = {Pain Physician},
  year = {2012},
  volume = {15},
  number = {5},
  pages = {E677--E686},
  pmid = {22996861},
  keywords = {ME/CFS, chronic fatigue syndrome, pain, central sensitization, hyperalgesia, endogenous analgesia, exercise, pain education},
  note = {Narrative review establishing pain as a central sensitization feature of ME/CFS rather than a peripheral musculoskeletal phenomenon. Key findings: generalized hyperalgesia (mechanical, thermal, electrical), dysfunctional endogenous analgesia (conditioned pain modulation failure), exercise-induced pain amplification without normal analgesia, ASIC/P2X receptor upregulation post-exercise. Concludes pain in CFS shares central sensitization mechanisms with fibromyalgia. Advocates pain-specific treatment protocols.}
}

@article{Kosek2024Nociplastic,
  author = {Kosek, Eva},
  title = {The Concept of Nociplastic Pain---Where to from Here?},
  journal = {Pain},
  year = {2024},
  volume = {165},
  number = {11S},
  pages = {S50--S57},
  doi = {10.1097/j.pain.0000000000003305},
  pmid = {39560415},
  keywords = {nociplastic pain, IASP, central sensitization, fibromyalgia, allodynia, hyperalgesia, nociceptive, neuropathic, pain phenotype},
  note = {2024 IASP perspective by Kosek on nociplastic pain (third mechanistic descriptor, adopted 2017). Defined as pain from altered nociception not fully explained by nociceptive or neuropathic mechanisms. Clinical criteria for musculoskeletal nociplastic pain: >3 months duration, regional/widespread distribution, not explained by other mechanisms, clinical signs of hypersensitivity. Fibromyalgia as prototype. Peripheral sensitization (autoreactive antibodies at DRG) and central mechanisms (aberrant brain network architecture) may both contribute. Advocates opioid avoidance; pharmacological approaches resemble neuropathic pain treatment.}
}

@article{Baraniuk2025NociplasticMECFS,
  author = {Chen, Emily and Rudder, Terran and Nwankwere, Chibueze and Baraniuk, James N},
  title = {Fatigue, Interoplastic and Nociplastic Distress in Myalgic Encephalomyelitis/Chronic Fatigue Syndrome, {Gulf War Illness}, and Chronic Idiopathic Fatigue},
  journal = {Frontiers in Neuroscience},
  year = {2025},
  volume = {19},
  pages = {1530652},
  doi = {10.3389/fnins.2025.1530652},
  pmid = {40927423},
  pmcid = {PMC12415031},
  keywords = {ME/CFS, Gulf War Illness, central sensitization, nociplastic pain, interoception, descending inhibition, dolorimetry, tenderness, fatigue, post-exertional malaise},
  note = {Georgetown University cohort study (ME/CFS, GWI, sedentary controls). ME/CFS and GWI patients significantly more tender than controls (females p<0.0045, males p<1e-6 by dolorimetry). Pain and interoception highly correlated. Proposes midbrain/medullary regulatory pathway injury causing dual loss of descending antiinteroceptive and antinociceptive inhibition. Coins "interoplastic distress" parallel to nociplastic pain for visceral hypersensitivity. Disease reconceptualized as chronic disabling fatigue with heightened interoceptive and nociceptive symptoms.}
}

% --- Section 15.12: Oxidative/Nitrosative Stress ---

@article{Pall2000Peroxynitrite,
  author = {Pall, Martin L},
