@article{Pimentel2009prokinetics,
  author = {Pimentel, Mark and Morales, Walter and Lezcano, Sheila and Sun-Chuan, Dai and Low, Kimberly and Yang, Janet},
  title = {Low-dose nocturnal tegaserod or erythromycin delays symptom recurrence after treatment of irritable bowel syndrome based on presumed bacterial overgrowth},
  journal = {Gastroenterology {\&} Hepatology (N Y)},
  year = {2009},
  volume = {5},
  number = {6},
  pages = {435--442},
  pmid = {20574504},
  url = {https://pmc.ncbi.nlm.nih.gov/articles/PMC2886395/},
  note = {Retrospective chart review. n=64 IBS-SIBO patients with documented breath test and symptom resolution post-antibiotic. Days to relapse: no prevention 59.7, low-dose nocturnal erythromycin 138.5, low-dose nocturnal tegaserod 241.6 (tegaserod > erythromycin, p<0.05). Prokinetics stimulate MMC to prevent bacterial re-accumulation. Note: tegaserod withdrawn from US market; prucalopride is current substitute. Low-Medium certainty: retrospective, small subgroups, IBS-SIBO proxy},
  keywords = {SIBO, IBS, prokinetics, relapse prevention, MMC, migrating motor complex, erythromycin, tegaserod, recurrence},
  certaintyscore = {0.35},
  research_stream = {treatments}
}

@article{Deloose2012MMCreview,
  author = {Deloose, Eveline and Janssen, Pieter and Depoortere, Inge and Tack, Jan},
  title = {The migrating motor complex: control mechanisms and its role in health and disease},
  journal = {Nature Reviews Gastroenterology {\&} Hepatology},
  year = {2012},
  volume = {9},
  number = {5},
  pages = {271--285},
  doi = {10.1038/nrgastro.2012.57},
  pmid = {22450306},
  url = {https://doi.org/10.1038/nrgastro.2012.57},
  note = {Definitive review of MMC physiology and pathophysiology. Key finding: vagus nerve modulates gastric MMC phase III but does NOT regulate small bowel periodicity (enteric nervous system dominant). MMC absence associated with gastroparesis, pseudo-obstruction, and SIBO. Motilin, ghrelin, erythromycin induce phase III. Implication for ME/CFS: vagal dysfunction alone insufficient to explain MMC failure; enteric neuropathy or motilin disruption required},
  keywords = {migrating motor complex, MMC, SIBO, gut motility, vagus nerve, autonomic, motilin, ghrelin, enteric nervous system},
  certaintyscore = {0.80},
  research_stream = {pathophysiology}
}

@article{Szabo2014H2Smito,
  author = {Szabo, Csaba and Ransy, Céline and Módis, Katalin and Andriamihaja, Miadana and Murghes, Béla and Coletta, Ciro and Olah, Gabor and Yanagi, Kazunori and Bouillaud, Frédéric},
  title = {Regulation of mitochondrial bioenergetic function by hydrogen sulfide. {Part I.} {Biochemical} and physiological mechanisms},
  journal = {British Journal of Pharmacology},
  year = {2014},
  volume = {171},
  number = {8},
  pages = {2099--2122},
  doi = {10.1111/bph.12369},
  pmid = {23991830},
  url = {https://doi.org/10.1111/bph.12369},
  note = {Biochemical review with experimental evidence. H2S has biphasic mitochondrial effects: at low-physiological concentrations donates electrons via SQR stimulating ETC; at high-toxic concentrations competitively inhibits Complex IV (cytochrome c oxidase) at cytochrome a3, blocking O2 binding, causing electron backup, inner membrane potential collapse, and cessation of aerobic ATP synthesis. Mechanism identical to cyanide at high dose. Colonocytes normally metabolise H2S as barrier; ISO (intestinal sulfide overproduction) overwhelms this barrier. Relevance: SIBO-derived H2S → systemic exposure → Complex IV inhibition → ME/CFS-relevant mitochondrial dysfunction},
  keywords = {hydrogen sulfide, H2S, mitochondria, Complex IV, cytochrome c oxidase, SQR, ATP, SIBO, ISO, electron transport chain},
  certaintyscore = {0.80},
  research_stream = {pathophysiology}
}

@article{Rezaie2017breathConsensus,
  author = {Rezaie, Ali and Buresi, Michelle and Lembo, Anthony and Lin, Henry and McCallum, Richard and Rao, Satish and Schmulson, Max and Valdovinos, Miguel and Zakko, Salam and Pimentel, Mark},
  title = {Hydrogen and methane-based breath testing in gastrointestinal disorders: the {North American Consensus}},
  journal = {American Journal of Gastroenterology},
  year = {2017},
  volume = {112},
  number = {5},
  pages = {775--784},
  doi = {10.1038/ajg.2017.46},
  pmid = {28323273},
  url = {https://doi.org/10.1038/ajg.2017.46},
  note = {26-statement expert consensus on breath testing standards. SIBO positive: hydrogen rise ≥20 ppm by 90 min on glucose or lactulose BT. Methane positive: ≥10 ppm at any time. Substrate doses: lactulose 10g, glucose 75g. H2S not measurable by standard 2-gas devices (identified as gap, predating trio-smart). Useful for carbohydrate maldigestion and methane-constipation; NOT recommended for oro-cecal transit assessment. This consensus is the diagnostic standard cited by most SIBO breath test literature 2017--2024},
  keywords = {SIBO, breath testing, hydrogen, methane, lactulose, glucose, consensus, diagnosis, North American},
  certaintyscore = {0.75},
  research_stream = {biomarkers}
}

@article{Pimentel2020ACGguideline,
  author = {Pimentel, Mark and Saad, Richard J and Long, Millie D and Rao, Satish S C},
  title = {{ACG} clinical guideline: small intestinal bacterial overgrowth},
  journal = {American Journal of Gastroenterology},
  year = {2020},
  volume = {115},
  number = {2},
  pages = {165--178},
  doi = {10.14309/ajg.0000000000000501},
  pmid = {32023228},
  url = {https://doi.org/10.14309/ajg.0000000000000501},
  note = {GRADE-based ACG official guideline. Breath testing recommended for: IBS, symptomatic motility disorders, post-GI-surgery patients. Rifaximin 550 mg TID × 14 days for H2-dominant SIBO; rifaximin + neomycin for CH4-dominant (IMO). Nutrient malabsorption documented: B12 (bacterial consumption of intrinsic factor-bound B12), fat-soluble vitamins A/D/E/K (bile salt deconjugation impairs fat absorption), iron (mucosal inflammation + competitive uptake). Prokinetics recommended post-eradication as prevention. Covers motility disorders, anatomical abnormalities, and immune deficiency as predisposing conditions},
  keywords = {SIBO, guideline, ACG, rifaximin, diagnosis, treatment, nutrient malabsorption, B12, iron, vitamin D, prokinetics},
  certaintyscore = {0.80},
  research_stream = {treatments}
}

@article{Wielgosz2024SIBOnutrition,
  author = {Wielgosz-Grochowska, Justyna Paulina and Domanski, Nicole and Drywien, Malgorzata Ewa},
  title = {Identification of {SIBO} subtypes along with nutritional status and diet as key elements of {SIBO} therapy},
  journal = {International Journal of Molecular Sciences},
  year = {2024},
  volume = {25},
  number = {13},
  pages = {7341},
  doi = {10.3390/ijms25137341},
  pmid = {39000446},
  url = {https://doi.org/10.3390/ijms25137341},
  note = {Observational study, n=67. Three SIBO subtypes: H+ (18\%), M+ (31\%), H+/M+ (51\%). H+/M+ group: lowest serum vitamin D, lowest serum ferritin, highest fat intake. M+ group: elevated folate (bacterial production), reduced fiber. 87--97\% of all subtypes below vitamin D AI. Subtype-specific nutritional deficits inform targeted supplementation. Not ME/CFS-specific. Medium certainty: small n, single-centre Polish cohort, observational design},
  keywords = {SIBO, nutritional status, vitamin D, ferritin, iron, folate, B12, fat malabsorption, subtypes, hydrogen, methane},
  certaintyscore = {0.45},
  research_stream = {gut-microbiome}
}

@article{Kashyap2024SIBOcritique,
  author = {Kashyap, Purna and Moayyedi, Paul and Quigley, Eamonn M M and Simren, Magnus and Vanner, Stephen},
  title = {Critical appraisal of the {SIBO} hypothesis and breath testing: a clinical practice update endorsed by the {European Society of Neurogastroenterology and Motility (ESNM)} and the {American Neurogastroenterology and Motility Society (ANMS)}},
  journal = {Neurogastroenterology {\&} Motility},
  year = {2024},
  volume = {36},
  number = {6},
  pages = {e14817},
  doi = {10.1111/nmo.14817},
  pmid = {38798120},
  url = {https://doi.org/10.1111/nmo.14817},
  note = {Critical appraisal endorsed by ESNM and ANMS. Core conclusion: "after two decades, this hypothesis remains unproven." LHBT measures oro-cecal transit not bacterial overgrowth; transit range 25--200 min creates widespread false positives. No time point discriminates IBS from healthy controls (3 independent teams). Diagnostic criteria have changed repeatedly without validation. Breath test normalisation does not reliably predict clinical improvement. Raises antimicrobial stewardship concerns. IMPORTANT: critiques SIBO-IBS hypothesis and breath test validity; does not negate SIBO as a pathological entity or its relevance to ME/CFS-specific cohorts},
  keywords = {SIBO, breath testing, critical appraisal, negative result, IBS, methodology, false positive, antimicrobial stewardship, ESNM, ANMS},
  certaintyscore = {0.80},
  research_stream = {gut-microbiome}
}
