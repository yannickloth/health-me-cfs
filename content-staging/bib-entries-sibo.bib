  year = {2000},
  volume = {118},
  number = {4},
  pages = {A414},
  doi = {10.1016/S0016-5085(00)83765-8},
  note = {Conference abstract (Digestive Disease Week 2000). n=31 CFS patients; 77\% SIBO-positive by lactulose hydrogen breath test. Double-blind RCT of neomycin vs placebo; no statistically significant difference between arms (underpowered). First controlled study linking SIBO prevalence to CFS. Low certainty: conference abstract only, not peer-reviewed full paper, small sample, null primary endpoint},
  keywords = {ME/CFS, chronic fatigue syndrome, SIBO, small intestinal bacterial overgrowth, breath test, neomycin, treatment, prevalence},
  certaintyscore = {0.25},
  research_stream = {gut-microbiome}
