  note = {TARGET 1 and 2 trials. Phase 3 double-blind RCT. Rifaximin 550 mg TID × 14 days vs placebo in IBS-D (n≈1,200 combined). Adequate global IBS symptom relief: 40.7\% vs 31.7\% (p<0.001). Sustained to 10 weeks post-treatment. High certainty for IBS-D, not ME/CFS-specific. Commercial funding (Salix Pharmaceuticals) disclosed},
  keywords = {IBS-D, rifaximin, SIBO, randomized controlled trial, TARGET, gut dysbiosis, treatment},
