@article{Pimentel2000SIBOcfs,
  author = {Pimentel, Mark and Hallegua, David and Chow, Evelyn J and Wallace, Daniel and Bonorris, George and Lin, Henry C},
  title = {Eradication of small intestinal bacterial overgrowth decreases symptoms in chronic fatigue syndrome: a double blind, randomized study},
