  research_stream = {gpcr-autoantibodies-azcue2026},
  certainty    = {0.60},
  note         = {n=24 post-COVID ME/CFS patients with elevated β2-adrenergic receptor
                   autoantibodies. Repeated immunoadsorption (RIA) over 5 days.
