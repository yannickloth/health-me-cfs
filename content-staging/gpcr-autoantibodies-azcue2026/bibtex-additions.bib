% --- GPCR Autoantibodies - Azcue 2026 Integration ---
% Primary paper

@article{Azcue2026gpcr,
  author       = {Azcue, N. and Prada, A. and Del Pino, R. and Acera, M. and
                   Fernández-Valle, T. and Ayo-Mentxakatorre, N. and
                   Pérez-Concha, T. and Murueta-Goyena, A. and Lafuente, J. V. and
                   López de Munain, A. and Ruiz Irastorza, G. and Ribacoba, L. and
                   Gabilondo, I. and Tijero-Merino, B. and Gómez-Esteban, J. C.},
  title        = {Involvement of autoantibodies against G protein-coupled receptors in
                   post-COVID condition and Chronic Fatigue Syndrome},
  journal      = {Scientific Reports},
  year         = {2026},
  volume       = {16},
  pages        = {in press},
  doi          = {10.1038/s41598-026-49131-9},
  pmid         = {},
  url          = {https://doi.org/10.1038/s41598-026-49131-9},
  keywords     = {ME/CFS, Long COVID, PCC, autoantibodies, GPCR, beta-adrenergic
                   receptor, muscarinic receptor, autonomic dysfunction, cognitive
                   impairment, ELISA},
  research_stream = {gpcr-autoantibodies-azcue2026},
  certainty    = {0.55},
  note         = {n=59 ME/CFS, n=96 PCC, n=36 HC. ME/CFS: significantly higher
                   β2-adrenergic AAb titers vs PCC and HCs (F₂,₁₈₆=3.15, p=0.046).
                   β2 AAb correlated with sympathovagal imbalance in ME/CFS (r=0.45,
                   p=0.001). M1, M3, M4 AAb titers positively correlated with verbal and
                   working memory in ME/CFS. PCC: more borderline/pathological M3
                   muscarinic AAb results vs HCs. β2 AAb correlated with autonomic
                   symptoms in PCC (r=0.27, p=0.048). Distinct AAb profiles in PCC vs
                   ME/CFS suggest different immunological mechanisms. Used CellTrend
                   ELISA methodology with comprehensive autonomic (COMPASS-31, Sudoscan,
                   hemodynamic tests, HRV) and cognitive (7 domains) testing. Moderate
                   sample size, ELISA specificity limitations noted.}
}

% Null/negative replication

@article{Germain2025autoantibody,
  author       = {Germain, A. and Jaycox, J. R. and Emig, C. J. and Ring, A. M. and
                   Hanson, M. R.},
  title        = {An In-Depth Exploration of the Autoantibody Immune Profile in
                   {ME/CFS} Using Novel Antigen Profiling Techniques},
  journal      = {International Journal of Molecular Sciences},
  year         = {2025},
  volume       = {26},
  number       = {6},
  pages        = {2799},
  doi          = {10.3390/ijms26062799},
  pmid         = {40141440},
  url          = {https://doi.org/10.3390/ijms26062799},
  keywords     = {ME/CFS, autoantibodies, REAP, Luminex, GPCR, beta-adrenergic, null
                   finding, methodology, high-throughput},
  research_stream = {gpcr-autoantibodies-azcue2026},
  certainty    = {0.70},
  note         = {Largest autoantibody screen in ME/CFS: 172 participants, 7542
                   antibody-antigen interactions via REAP (6183 exoproteome proteins) and
                   Luminex (1134 autoantigens). Complete null: no q-value below 0.68.
                   GPCR-specific (ADRB1-3, CHRM1-4) all negative. Notable secondary:
                   elevated EBV gp42 and HSV-1 gL reactivity. Limitation: REAP displays
                   extracellular domains only; conformational multi-loop GPCR epitopes
                   may be missed. Cohort was chronic (11-14 yr), pre-COVID. High-
                   certainty null result suggesting CellTrend ELISA may detect low-
                   affinity/polyreactive antibodies not pathologically relevant.}
}

