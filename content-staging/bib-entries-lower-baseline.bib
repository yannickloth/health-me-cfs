% ── 1. Quadt et al. 2024 — Neurodivergent traits, IL-6, chronic disabling fatigue ──────────────
@article{Quadt2024neurodivergentFatigue,
  author   = {Quadt, Lisa and Csecs, Jenny and Bond, Rod and Harrison, Neil A and Critchley, Hugo D and Davies, Kevin A and Eccles, Jessica},
  title    = {Childhood neurodivergent traits, inflammation and chronic disabling fatigue in adolescence: a longitudinal case--control study},
  journal  = {BMJ Open},
  year     = {2024},
  volume   = {14},
  number   = {7},
  pages    = {e084203},
  doi      = {10.1136/bmjopen-2024-084203},
  pmid     = {39038862},
  pmcid    = {PMC11733788},
  url      = {https://pmc.ncbi.nlm.nih.gov/articles/PMC11733788/},
  keywords = {ADHD, autism, neurodivergent, chronic fatigue, IL-6, inflammation, ALSPAC, longitudinal, predisposition},
  certainty = {0.65},
  research_stream = {lower-baseline-predisposition},
  note     = {ALSPAC longitudinal cohort n=4,563. Autism traits at age 7: OR=1.78 (95\% CI 1.17--2.72, p=0.008) for chronic disabling fatigue at 18. ADHD traits at age 9: OR=2.18 (95\% CI 1.33--3.56, p=0.002). IL-6 at age 9 mediated the effect (OR=1.54, p=0.006). Inflammation as mechanistic bridge between neurodivergent traits and later fatigue. Key lower-baseline evidence: neuroinflammation as pre-existing state reducing reserve.}
}

% ── 2. Frye et al. 2024 — ASD mitochondrial biomarkers meta-analysis ───────────────────────────
@article{Frye2024ASDmitochondria,
  author   = {Frye, Richard E and Rincon, Nicole and McCarty, Patrick J and Brister, Danielle and Scheck, Adrienne C and Rossignol, Daniel A},
  title    = {Biomarkers of mitochondrial dysfunction in autism spectrum disorder: {A} systematic review and meta-analysis},
  journal  = {Neurobiology of Disease},
  year     = {2024},
  volume   = {197},
  pages    = {106520},
  doi      = {10.1016/j.nbd.2024.106520},
  pmid     = {38703861},
  url      = {https://pubmed.ncbi.nlm.nih.gov/38703861/},
  keywords = {autism, ASD, mitochondrial dysfunction, lactate, pyruvate, ATP, creatine kinase, energy metabolism, meta-analysis},
  certainty = {0.70},
  research_stream = {lower-baseline-predisposition},
  note     = {Systematic review and meta-analysis, 204 studies. Elevated lactate (17\%), pyruvate (41\%), alanine (15\%), creatine kinase (9\%) in ASD. Significant ATP deficit and elevated lactate:pyruvate ratio (moderate-to-large effect sizes). Mitochondrial dysfunction linked to GI symptoms, oxidative stress, immune dysfunction. Carnitine and ubiquinol showed benefit. Core evidence: ASD involves systemic mitochondrial dysfunction that would reduce metabolic reserve prior to any infectious trigger.}
}

