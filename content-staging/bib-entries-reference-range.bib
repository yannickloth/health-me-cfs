@article{RuizNunez2018,
  author  = {Ruiz-N\'u{\~n}ez, Bego{\~n}a and Tarasse, Rabab and Vogelaar, Emar F and Dijck-Brouwer, D A Janneke and Muskiet, Frits A J},
  title   = {Higher prevalence of ``{Low T3 Syndrome}'' in patients with chronic fatigue syndrome: a case--control study},
  journal = {Frontiers in Endocrinology},
  year    = {2018},
  volume  = {9},
  pages   = {97},
  doi     = {10.3389/fendo.2018.00097},
  pmid    = {29615976},
  url     = {https://pmc.ncbi.nlm.nih.gov/articles/PMC5869352/},
  keywords = {ME/CFS, low T3 syndrome, non-thyroidal illness syndrome, euthyroid sick syndrome, TSH, reverse T3, deiodinase, reference range},
  note    = {Case-control (n=98 ME/CFS, 99 healthy controls). FT3 below reference range in 16/98 CFS vs 7/99 controls (OR 2.56, p=0.035). TSH normal in all. Elevated reverse T3, reduced deiodination function. Pattern resembles mild non-thyroidal illness syndrome. Demonstrates thyroid abnormalities in ME/CFS invisible to TSH-based screening.}
}

@article{Ott2011,
  author  = {Ott, Johannes and Promberger, Regina and Kober, Friedrich and Neuhold, Nikolaus and Tea, Maria and Huber, Johannes C and Hermann, Michael},
  title   = {{Hashimoto's} thyroiditis affects symptom load and quality of life unrelated to hypothyroidism: a prospective case-control study in women undergoing thyroidectomy for benign goiter},
  journal = {Thyroid},
  year    = {2011},
  volume  = {21},
  number  = {2},
  pages   = {161--167},
  doi     = {10.1089/thy.2010.0191},
  pmid    = {21186954},
  url     = {https://pubmed.ncbi.nlm.nih.gov/21186954/},
  keywords = {Hashimoto thyroiditis, fatigue, TSH, autoimmune, anti-TPO, reference range, euthyroid, quality of life},
  note    = {Prospective case-control (n=426 euthyroid women; 28 histology-confirmed Hashimoto's). Anti-TPO cutoff for true inflammation: 121.0 IU/mL. Hashimoto's group: higher symptom load (6.7±2.5 vs 4.1±2.8, p<0.001) including chronic fatigue. TSH identical between groups (1.7 vs 1.5 µU/mL). Autoimmune activity, not hypothyroidism, drives fatigue — invisible to TSH-based screening.}
}

@article{Joustra2017,
  author  = {Joustra, Monica L and Minovic, Isidor and Janssens, Karin A M and Bakker, Stephan J L and Rosmalen, Judith G M},
