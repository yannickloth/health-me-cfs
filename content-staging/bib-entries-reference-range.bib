}

@article{Charoenngam2020,
  author  = {Charoenngam, Nipith and Holick, Michael F},
  title   = {Immunologic effects of vitamin {D} on human health and disease},
  journal = {Nutrients},
  year    = {2020},
  volume  = {12},
  number  = {7},
  pages   = {2097},
  doi     = {10.3390/nu12072097},
  pmid    = {32679784},
  url     = {https://www.mdpi.com/2072-6643/12/7/2097},
  keywords = {vitamin D, immune function, reference range, 25-hydroxyvitamin D, threshold, bone health, T-cell, B-cell},
  note    = {Narrative review. Classical bone-health threshold: 20 ng/mL (most lab reference ranges). Optimal immune function threshold: 40--60 ng/mL. Vitamin D modulates T/B-cell activity, cathelicidin production, anti-inflammatory cytokines. Significant inter-individual variation in VDR gene expression means identical serum levels yield different cellular responses. COI: Holick has commercial speaking relationships.}
}

