@article{Vaucher2012,
  author  = {Vaucher, Paul and Druais, Pierre-Louis and Waldvogel, Sophie and Favrat, Bernard},
  title   = {Effect of iron supplementation on fatigue in nonanemic menstruating women with low ferritin: a randomized controlled trial},
  journal = {CMAJ},
  year    = {2012},
  volume  = {184},
  number  = {11},
  pages   = {1247--1254},
  doi     = {10.1503/cmaj.110950},
  pmid    = {22777991},
  url     = {https://www.cmaj.ca/content/184/11/1247},
  keywords = {iron deficiency without anemia, ferritin threshold, fatigue, RCT, reference range, subclinical deficiency},
  note    = {Multicentre RCT (n=198) in France. Ferrous sulfate 80 mg/day × 12 weeks reduced fatigue by 47.7\% vs 28.8\% placebo (p=0.02) in nonanemic menstruating women with ferritin <50 µg/L. Key reference range implication: WHO iron deficiency cutoff is <15 µg/L; this trial demonstrates fatigue benefit up to 3× that threshold.}
}

@article{Krayenbuehl2011,
  author  = {Krayenbuehl, Pierre-Auguste and Battegay, Edouard and Breymann, Christian and Furrer, Juerg and Schulthess, Gabriela},
