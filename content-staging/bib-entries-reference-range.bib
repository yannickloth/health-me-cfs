  number  = {4},
  pages   = {e0176631},
  doi     = {10.1371/journal.pone.0176631},
  pmid    = {28453534},
  url     = {https://journals.plos.org/plosone/article?id=10.1371/journal.pone.0176631},
  keywords = {ME/CFS, fibromyalgia, vitamins, minerals, deficiency, meta-analysis, systematic review, serum levels},
  note    = {Systematic review + meta-analysis, 45 studies (5 RCTs, 40 observational). No consistent differences in vitamin D, magnesium, B12, iron between CFS/FMS patients and controls using standard serum measures. Conclusion: little evidence for vitamin/mineral deficiency role using serum testing. Key caveat: used serum/plasma assays, which are the specific tests identified as inadequate for intracellular/functional deficiency.}
